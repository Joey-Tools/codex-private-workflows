  "terminal_result": {
    "additional_fields": false,
    "required_fields": [
      "type",
      "subtype",
      "is_error"
    ],
    "optional_fields": [
      "result",
      "modelUsage",
      "duration_ms",
      "duration_api_ms",
      "num_turns",
      "session_id",
      "total_cost_usd",
      "usage",
      "uuid",
      "stop_reason",
      "structured_output",
      "error",
      "errors",
      "api_error_status",
      "permission_denials"
    ],
    "optional_field_contracts": {
      "result": {
        "rule": "variant_specific",
        "failure": "inconclusive"
      },
      "modelUsage": {
        "rule": "variant_specific",
        "failure": "classify"
      },
      "duration_ms": {
        "rule": "nonnegative_integer",
        "failure": "inconclusive"
      },
      "duration_api_ms": {
        "rule": "nonnegative_integer",
        "failure": "inconclusive"
      },
      "num_turns": {
        "rule": "positive_integer",
        "failure": "inconclusive"
      },
      "session_id": {
        "rule": "nonempty_string",
        "failure": "inconclusive"
      },
      "total_cost_usd": {
        "rule": "nonnegative_finite_number",
        "failure": "inconclusive"
      },
      "usage": {
        "rule": "object",
        "failure": "inconclusive"
      },
      "uuid": {
        "rule": "nonempty_string",
        "failure": "inconclusive"
      },
      "stop_reason": {
        "rule": "enum",
        "accepted_values": [
          null,
          "end_turn"
        ],
        "failure": "blocked"
      },
      "structured_output": {
        "rule": "null",
        "failure": "inconclusive"
      },
      "error": {
        "rule": "explicitly_empty",
        "failure": "classify"
      },
      "errors": {
        "rule": "explicitly_empty",
        "failure": "classify"
      },
      "api_error_status": {
        "rule": "null_or_whitespace_string",
        "failure": "classify"
      },
      "permission_denials": {
        "rule": "empty_array",
        "failure": "blocked"
      }
    },
    "variants": {
      "success": {
        "match": {
          "subtype": "success",
          "is_error": false
        },
        "required_fields": [
          "result",
          "modelUsage"
        ],
        "field_contracts": {
          "result": {
            "rule": "nonempty_string",
            "failure": "inconclusive"
          },
          "modelUsage": {
            "rule": "requested_model_usage",
            "failure": "classify"
          }
        }
      },
      "failure": {
        "match": {
          "subtype": {
            "rule": "profile_enum",
            "profile_field": "failure_subtypes"
          },
          "is_error": true
        },
        "required_fields": [],
        "optional_fields": [
          "result",
          "modelUsage"
        ],
        "field_contracts": {
          "result": {
            "rule": "string",
            "failure": "inconclusive"
          },
          "modelUsage": {
            "rule": "requested_model_usage",
            "failure": "classify"
          }
        },
        "recognized_failure_classes": {
          "authentication": {
            "classification": "blocked-authentication",
            "reason": "terminal.authentication-error"
          },
          "model_entitlement": {
            "classification": "blocked",
            "reason": "terminal.model-entitlement-denial"
          },
          "organization_policy": {
            "classification": "blocked",
            "reason": "terminal.organization-policy-denial"
          },
          "mixed_or_ambiguous": {
            "classification": "inconclusive",
            "reason": "terminal.unclassified-error"
          }
        },
        "unclassified_failure": "inconclusive"
      }
    },
    "profiles": {
      "selector": "claude_code_version",
      "variants": {
        "legacy-base": {
          "version_range": {
            "minimum_inclusive": "2.1.211",
            "maximum_exclusive": "2.1.216"
          },
          "profile_fields": [],
          "failure_subtypes": [
            "error"
          ]
        },
        "extended-2x": {
          "version_range": {
            "minimum_inclusive": "2.1.216",
            "maximum_exclusive": "3.0.0"
          },
          "profile_fields": [
            "fast_mode_state",
            "terminal_reason",
            "time_to_request_ms",
            "ttft_ms",
            "ttft_stream_ms"
          ],
          "failure_subtypes": [
            "error"
          ],
          "success": {
            "required_fields": [
              "fast_mode_state",
              "terminal_reason",
              "time_to_request_ms",
              "ttft_ms",
              "ttft_stream_ms"
            ],
            "field_contracts": {
              "fast_mode_state": {
                "rule": "constant",
                "value": "off"
              },
              "terminal_reason": {
                "rule": "constant",
                "value": "completed"
              },
              "time_to_request_ms": {
                "rule": "nonnegative_integer"
              },
              "ttft_ms": {
                "rule": "nonnegative_integer"
              },
              "ttft_stream_ms": {
                "rule": "nonnegative_integer"
              }
            }
          },
          "failure": {
            "optional_fields": [
              "fast_mode_state",
              "terminal_reason",
              "time_to_request_ms",
              "ttft_ms",
              "ttft_stream_ms"
            ],
            "field_contracts": {
              "fast_mode_state": {
                "rule": "constant",
                "value": "off"
              },
              "terminal_reason": {
                "rule": "enum",
                "values": [
                  "completed",
                  "api_error"
                ]
              },
              "time_to_request_ms": {
                "rule": "nonnegative_integer"
              },
              "ttft_ms": {
                "rule": "nonnegative_integer"
              },
              "ttft_stream_ms": {
                "rule": "nonnegative_integer"
              }
            }
          }
        }
      }
    }
  },
