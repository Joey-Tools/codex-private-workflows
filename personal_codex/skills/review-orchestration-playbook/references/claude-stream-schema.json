{
  "claude_code_version": {
    "rule": "strict_release_semver_range",
    "minimum_inclusive": "2.1.211",
    "maximum_exclusive": "3.0.0"
  },
  "process_returncode": {
    "rule": "exact_int",
    "missing_or_invalid": {
      "classification": "inconclusive",
      "reason": "process.returncode.invalid"
    },
    "accepted_requires": 0,
    "nonzero_precedence": {
      "accepted": {
        "classification": "inconclusive",
        "reason": "process.returncode.nonzero"
      },
      "blocked": "preserve",
      "blocked-authentication": "preserve",
      "inconclusive": {
        "classification": "inconclusive",
        "append_reason": "process.returncode.nonzero"
      }
    }
  },
  "launch_profiles": {
    "named-direct": {
      "permission_mode": "dontAsk",
      "runtime_cwd": "host-workspace",
      "tools": [
        "Bash",
        "Glob",
        "Grep",
        "Read"
      ]
    },
    "helper-linux": {
      "permission_mode": "dontAsk",
      "runtime_cwd": "/workspace",
      "tools": [
        "Read"
      ]
    },
    "helper-darwin": {
      "permission_mode": "default",
      "runtime_cwd": "host-workspace",
      "tools": [
        "Glob",
        "Grep",
        "Read"
      ]
    }
  },
  "stream_contract": {
    "encoding": "utf-8",
    "format": "jsonl",
    "blank_lines": "ignored",
    "top_level": "object",
    "duplicate_keys": "reject",
    "nonstandard_constants": "reject",
    "unpaired_surrogates": "reject",
    "max_integer_digits": 128,
    "floating_number_representation": "decimal",
    "max_float_characters": 256,
    "max_float_significand_digits": 128,
    "max_float_explicit_exponent_magnitude": 308,
    "max_bytes": 8388608,
    "max_lines": 10000,
    "max_line_bytes": 1048576,
    "first_nonblank_event": {
      "type": "system",
      "subtype": "init"
    },
    "last_nonblank_event": {
      "type": "result"
    },
    "init_event_count": 1,
    "result_event_count": 1,
    "matching_session_id_when_both_present": true
  },
  "init_event": {
    "required_fields": [
      "type",
      "subtype",
      "cwd",
      "permissionMode",
      "tools",
      "mcp_servers",
      "slash_commands",
      "skills",
      "plugins",
      "model",
      "claude_code_version",
      "apiKeySource"
    ],
    "additional_fields": false,
    "optional_fields": [
      "session_id"
    ],
    "field_contracts": {
      "type": {
        "rule": "constant",
        "value": "system",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "inconclusive"
      },
      "subtype": {
        "rule": "constant",
        "value": "init",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "inconclusive"
      },
      "cwd": {
        "rule": "exact_expected_runtime_cwd",
        "binding_field": "expected_runtime_cwd",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "permissionMode": {
        "rule": "exact_runtime_binding_launch_profile",
        "profile_field": "permission_mode",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "tools": {
        "rule": "duplicate_free_exact_runtime_binding_launch_profile_set",
        "profile_field": "tools",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "mcp_servers": {
        "rule": "empty_array",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "slash_commands": {
        "rule": "empty_array",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "skills": {
        "rule": "empty_array",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "plugins": {
        "rule": "empty_array",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "model": {
        "rule": "exact_cli_argument",
        "argument": "model",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "claude_code_version": {
        "rule": "exact_cli_argument",
        "argument": "claude_code_version",
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      },
      "apiKeySource": {
        "rule": "exact_runtime_binding",
        "binding_field": "api_key_source",
        "accepted_values": [
          "ANTHROPIC_API_KEY",
          "none"
        ],
        "malformed_failure": "inconclusive",
        "mismatch_failure": "blocked"
      }
    },
    "optional_field_contracts": {
      "session_id": {
        "rule": "nonempty_string",
        "failure": "inconclusive"
      }
    },
    "profiles": {
      "selector": "claude_code_version",
      "variants": {
        "legacy-base": {
          "version_range": {
            "minimum_inclusive": "2.1.211",
            "maximum_exclusive": "2.1.216"
          },
          "additional_required_fields": [],
          "field_contracts": {}
        },
        "extended-2x": {
          "version_range": {
            "minimum_inclusive": "2.1.216",
            "maximum_exclusive": "3.0.0"
          },
          "additional_required_fields": [
            "agents",
            "analytics_disabled",
            "capabilities",
            "fast_mode_state",
            "output_style",
            "product_feedback_disabled",
            "uuid"
          ],
          "field_contracts": {
            "output_style": {
              "rule": "constant",
              "value": "default",
              "failure": "inconclusive"
            },
            "agents": {
              "rule": "exact_ordered_array",
              "values": [
                "claude",
                "Explore",
                "general-purpose",
                "Plan"
              ],
              "failure": "inconclusive"
            },
            "capabilities": {
              "rule": "exact_ordered_array",
              "values": [
                "interrupt_receipt_v1",
                "msg_lifecycle_v1"
              ],
              "failure": "inconclusive"
            },
            "analytics_disabled": {
              "rule": "constant",
              "value": true,
              "failure": "inconclusive"
            },
            "product_feedback_disabled": {
              "rule": "boolean",
              "failure": "inconclusive"
            },
            "uuid": {
              "rule": "nonempty_string",
              "failure": "inconclusive"
            },
            "fast_mode_state": {
              "rule": "constant",
              "value": "off",
              "failure": "inconclusive"
            }
          }
        }
      }
    }
  },
  "intermediate_events": {
    "selector": "claude_code_version",
    "session_binding": {
      "field": "session_id",
      "rule": "nonempty_exact_init_session",
      "failure": "inconclusive"
    },
    "event_contracts": {
      "reviewed-2x": {
          "system-thinking-tokens": {
            "match": {
              "type": "system",
              "subtype": "thinking_tokens"
            },
            "required_fields": [
              "estimated_tokens",
              "estimated_tokens_delta",
              "session_id",
              "subtype",
              "type",
              "uuid"
            ],
            "optional_fields": [],
            "additional_fields": false,
            "field_contracts": {
              "estimated_tokens": {
                "rule": "nonnegative_integer"
              },
              "estimated_tokens_delta": {
                "rule": "nonnegative_integer"
              },
              "session_id": {
                "rule": "session_binding"
              },
              "uuid": {
                "rule": "nonempty_string"
              }
            }
          },
          "assistant-message": {
            "match": {
              "type": "assistant"
            },
            "required_fields": [
              "message",
              "parent_tool_use_id",
              "request_id",
              "session_id",
              "timestamp",
              "type",
              "uuid"
            ],
            "optional_fields": [],
            "additional_fields": false,
            "field_contracts": {
              "parent_tool_use_id": {
                "rule": "null"
              },
              "request_id": {
                "rule": "nonempty_string"
              },
              "session_id": {
                "rule": "session_binding"
              },
              "timestamp": {
                "rule": "nonempty_string"
              },
              "uuid": {
                "rule": "nonempty_string"
              },
              "message": {
                "rule": "closed_object",
                "required_fields": [
                  "content",
                  "context_management",
                  "id",
                  "model",
                  "role",
                  "stop_details",
                  "stop_reason",
                  "stop_sequence",
                  "type",
                  "usage"
                ],
                "optional_fields": [],
                "additional_fields": false,
                "fixed_values": {
                  "context_management": null,
                  "role": "assistant",
                  "stop_details": null,
                  "stop_reason": null,
                  "stop_sequence": null,
                  "type": "message"
                },
                "model": "exact_requested_model",
                "id": "nonempty_string",
                "usage": "object",
                "content": {
                  "rule": "single_block",
                  "variants": {
                    "thinking": {
                      "required_fields": [
                        "signature",
                        "thinking",
                        "type"
                      ],
                      "optional_fields": [],
                      "additional_fields": false,
                      "string_fields": [
                        "signature",
                        "thinking"
                      ]
                    },
                    "text": {
                      "required_fields": [
                        "text",
                        "type"
                      ],
                      "optional_fields": [],
                      "additional_fields": false,
                      "string_fields": [
                        "text"
                      ]
                    },
                    "tool_use": {
                      "required_fields": [
                        "caller",
                        "id",
                        "input",
                        "name",
                        "type"
                      ],
                      "optional_fields": [],
                      "additional_fields": false,
                      "caller": "object",
                      "id": "nonempty_string",
                      "input": "object",
                      "name": {
                        "rule": "runtime_binding_launch_profile_set"
                      }
                    }
                  }
                }
              }
            }
          },
          "user-tool-result": {
            "match": {
              "type": "user"
            },
            "required_fields": [
              "message",
              "parent_tool_use_id",
              "session_id",
              "timestamp",
              "tool_use_result",
              "type",
              "uuid"
            ],
            "optional_fields": [],
            "additional_fields": false,
            "field_contracts": {
              "parent_tool_use_id": {
                "rule": "null"
              },
              "session_id": {
                "rule": "session_binding"
              },
              "timestamp": {
                "rule": "nonempty_string"
              },
              "tool_use_result": {
                "rule": "object_or_string"
              },
              "uuid": {
                "rule": "nonempty_string"
              },
              "message": {
                "rule": "closed_object",
                "required_fields": [
                  "content",
                  "role"
                ],
                "optional_fields": [],
                "additional_fields": false,
                "role": "user",
                "content": {
                  "rule": "single_tool_result_block",
                  "required_fields": [
                    "content",
                    "tool_use_id",
                    "type"
                  ],
                  "optional_fields": [
                    "is_error"
                  ],
                  "additional_fields": false,
                  "content": "string",
                  "tool_use_id": "nonempty_string",
                  "is_error": "boolean_when_present"
                }
              }
            }
          },
          "rate-limit-event": {
            "match": {
              "type": "rate_limit_event"
            },
            "required_fields": [
              "rate_limit_info",
              "session_id",
              "type",
              "uuid"
            ],
            "optional_fields": [],
            "additional_fields": false,
            "field_contracts": {
              "session_id": {
                "rule": "session_binding"
              },
              "uuid": {
                "rule": "nonempty_string"
              },
              "rate_limit_info": {
                "rule": "closed_object_variant",
                "selector": "status",
                "variants": {
                  "allowed": {
                    "match": {
                      "status": "allowed"
                    },
                    "required_fields": [
                      "isUsingOverage",
                      "overageInUse",
                      "overageResetsAt",
                      "overageStatus",
                      "rateLimitType",
                      "resetsAt",
                      "status"
                    ],
                    "optional_fields": [],
                    "additional_fields": false,
                    "string_fields": [
                      "status",
                      "rateLimitType",
                      "overageStatus"
                    ],
                    "nonnegative_integer_fields": [
                      "resetsAt",
                      "overageResetsAt"
                    ],
                    "boolean_fields": [
                      "isUsingOverage",
                      "overageInUse"
                    ]
                  },
                  "allowed-warning": {
                    "match": {
                      "status": "allowed_warning"
                    },
                    "required_fields": [
                      "isUsingOverage",
                      "overageInUse",
                      "rateLimitType",
                      "resetsAt",
                      "status",
                      "surpassedThreshold",
                      "utilization"
                    ],
                    "optional_fields": [],
                    "additional_fields": false,
                    "string_fields": [
                      "status",
                      "rateLimitType"
                    ],
                    "nonnegative_integer_fields": [
                      "resetsAt"
                    ],
                    "unit_interval_number_fields": [
                      "utilization",
                      "surpassedThreshold"
                    ],
                    "boolean_fields": [
                      "isUsingOverage",
                      "overageInUse"
                    ]
                  }
                }
              }
            }
          }
      }
    },
    "profiles": {
      "legacy-base": {
        "version_range": {
          "minimum_inclusive": "2.1.211",
          "maximum_exclusive": "2.1.216"
        },
        "event_contract": "reviewed-2x"
      },
      "extended-2x": {
        "version_range": {
          "minimum_inclusive": "2.1.216",
          "maximum_exclusive": "3.0.0"
        },
        "event_contract": "reviewed-2x"
      }
    }
  },
