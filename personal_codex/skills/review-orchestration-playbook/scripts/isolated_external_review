class UserError(RuntimeError):
    pass


def _write_text_atomic(path: pathlib.Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_path_raw = tempfile.mkstemp(
        prefix=f".{path.name}.",
        dir=str(path.parent),
        text=True,
    )
    temp_path = pathlib.Path(temp_path_raw)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(text)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temp_path, path)
    finally:
        try:
            temp_path.unlink()
        except FileNotFoundError:
            pass


def _write_json(path: pathlib.Path, payload: dict[str, object]) -> None:
    _write_text_atomic(
        path,
        json.dumps(payload, indent=2, sort_keys=True) + "\n",
    )


def _read_json(path: pathlib.Path) -> dict[str, object]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as error:
        raise UserError(f"invalid JSON file: {path}") from error


def _read_text_if_present(path: pathlib.Path) -> str | None:
    try:
        return path.read_text(encoding="utf-8")
    except OSError:
        return None


def _normalize_codex_readonly_final_text(text: str) -> str:
    if text.strip().lower() in CODEX_READONLY_FINAL_MESSAGE_ALIASES:
        return CODEX_READONLY_FINAL_MESSAGE_DEFAULT
    return text


def _read_exit_code(path: pathlib.Path) -> int | None:
    contents = _read_text_if_present(path)
    if contents is None:
        return None
    contents = contents.strip()
    if not contents:
        return None
    try:
        return int(contents)
    except ValueError:
        return None


def _state_lock_is_held(lock_path: pathlib.Path) -> bool:
    if not lock_path.exists():
        return False
    with lock_path.open("a+b") as handle:
        try:
            fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return True
        fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
    return False


def _tail_text(path: pathlib.Path, *, line_count: int = STATUS_TAIL_LINE_COUNT) -> str:
    if not path.is_file():
        return ""
    if line_count <= 0:
        return ""

    with path.open("rb") as handle:
        handle.seek(0, os.SEEK_END)
        position = handle.tell()
        buffer = bytearray()
        while position > 0 and len(buffer) < STATUS_TAIL_MAX_BYTES:
            if buffer.count(b"\n") > line_count:
                break
            chunk_size = min(
                STATUS_TAIL_READ_CHUNK_BYTES,
                position,
                STATUS_TAIL_MAX_BYTES - len(buffer),
            )
            position -= chunk_size
            handle.seek(position)
            buffer[:0] = handle.read(chunk_size)

    lines = bytes(buffer).decode("utf-8", errors="replace").splitlines()
    if not lines:
        return ""
    return "\n".join(lines[-line_count:])


def _maybe_stateful_action(argv: list[str]) -> str | None:
    if not argv:
        return None
    if argv[0] == "__run-child":
        return "__run-child"
    if argv[0] != STATEFUL_CONTROL_NAMESPACE:
        return None
    if len(argv) < 2:
        raise UserError(
            f"`{STATEFUL_CONTROL_NAMESPACE}` requires one of: "
            + ", ".join(sorted(STATEFUL_ACTIONS))
        )
    action = argv[1]
    if action not in STATEFUL_ACTIONS:
        raise UserError(
            f"unsupported {STATEFUL_CONTROL_NAMESPACE} action: {action}"
        )
    return action


def _run(
    cmd: list[str],
    *,
    cwd: pathlib.Path | None = None,
    env: dict[str, str] | None = None,
    input_bytes: bytes | None = None,
    capture_output: bool = False,
) -> subprocess.CompletedProcess[bytes]:
    completed = subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        env=env,
        input=input_bytes,
        stdout=subprocess.PIPE if capture_output else None,
        stderr=subprocess.PIPE if capture_output else None,
        check=False,
    )
    if completed.returncode != 0:
        raise UserError(_format_command_error(cmd, completed))
    return completed


def _format_command_error(
    cmd: list[str],
    completed: subprocess.CompletedProcess[bytes],
) -> str:
    message = [f"command failed: {' '.join(cmd)}"]
    if completed.stdout:
        message.append("--- stdout ---")
        message.append(completed.stdout.decode("utf-8", errors="replace").rstrip())
    if completed.stderr:
        message.append("--- stderr ---")
        message.append(completed.stderr.decode("utf-8", errors="replace").rstrip())
    return "\n".join(message)


def _git_stdout(repo_root: pathlib.Path, *args: str) -> str:
    completed = _run([_resolve_real_git(), "-C", str(repo_root), *args], capture_output=True)
    return completed.stdout.decode("utf-8", errors="replace").strip()


def _resolve_commit(repo_root: pathlib.Path, ref: str, *, flag: str) -> str:
    try:
        return _git_stdout(repo_root, "rev-parse", "--verify", f"{ref}^{{commit}}")
    except UserError as error:
        raise UserError(f"{flag} did not resolve to a commit in {repo_root}: {ref}") from error


def _resolve_frozen_range(
    repo_root: pathlib.Path,
    *,
    base_ref: str | None,
    head_ref: str | None,
) -> tuple[str | None, str | None]:
    if (base_ref is None) != (head_ref is None):
        raise UserError("--base-ref and --head-ref must be provided together")
    if base_ref is None:
        return None, None
    resolved_base = _resolve_commit(repo_root, base_ref, flag="--base-ref")
    resolved_head = _resolve_commit(repo_root, head_ref, flag="--head-ref")
    return resolved_base, resolved_head


def _git_is_ancestor(
    repo_root: pathlib.Path,
    ancestor_ref: str,
    descendant_ref: str,
) -> bool:
    cmd = [
        _resolve_real_git(),
        "-C",
        str(repo_root),
        "merge-base",
        "--is-ancestor",
        ancestor_ref,
        descendant_ref,
    ]
    completed = subprocess.run(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode == 0:
        return True
    if completed.returncode == 1:
        return False
    raise UserError(_format_command_error(cmd, completed))


def _git_merge_base(
    repo_root: pathlib.Path,
    left_ref: str,
    right_ref: str,
) -> str | None:
    cmd = [
        _resolve_real_git(),
        "-C",
        str(repo_root),
        "merge-base",
        left_ref,
        right_ref,
    ]
    completed = subprocess.run(
        cmd,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode == 0:
        return completed.stdout.decode("utf-8", errors="replace").strip() or None
    if completed.returncode == 1:
        return None
    raise UserError(_format_command_error(cmd, completed))


def _require_linear_codex_review_range(
    repo_root: pathlib.Path,
    *,
    base_ref: str,
    head_ref: str,
) -> None:
    if _git_is_ancestor(repo_root, base_ref, head_ref):
        return
    merge_base = _git_merge_base(repo_root, base_ref, head_ref) or "<no common ancestor>"
    raise UserError(
        "codex-review frozen range requires `--base-ref` to be an ancestor of "
        f"`--head-ref`; builtin `codex exec review --base` would drift to merge-base "
        f"{merge_base} instead of reviewing the exact tree diff {base_ref}..{head_ref}. "
        "Use a linear range or a diff-fed direct read-only fallback for target-branch "
        "comparisons."
    )


def _resolve_repo_root(repo_arg: str) -> pathlib.Path:
    repo_path = pathlib.Path(repo_arg).resolve()
    try:
        root = _git_stdout(repo_path, "rev-parse", "--show-toplevel")
    except UserError as error:
        raise UserError(f"{repo_path} is not inside a git worktree") from error
    return pathlib.Path(root).resolve()


def _is_git_worktree_root(path: pathlib.Path) -> bool:
    try:
        top_level = _git_stdout(path, "rev-parse", "--show-toplevel")
    except UserError:
        return False
    return pathlib.Path(top_level).resolve() == path.resolve()


def _ensure_no_conflicts(repo_root: pathlib.Path) -> None:
    conflicted = _git_stdout(repo_root, "diff", "--name-only", "--diff-filter=U")
    if conflicted:
        raise UserError(
            f"refusing to snapshot unresolved conflicts in {repo_root}:\n{conflicted}"
        )


def _list_direct_submodules(repo_root: pathlib.Path) -> list[pathlib.Path]:
    gitmodules = repo_root / ".gitmodules"
    if not gitmodules.exists():
        return []
    try:
        output = _git_stdout(
            repo_root,
            "config",
            "-f",
            str(gitmodules),
            "--get-regexp",
            r"^submodule\..*\.path$",
        )
    except UserError:
        return []

    paths = []
    for line in output.splitlines():
        parts = line.split(None, 1)
        if len(parts) != 2:
            continue
        paths.append(pathlib.Path(parts[1]))
    return paths


def _copy_file_or_symlink(source: pathlib.Path, target: pathlib.Path) -> None:
    target.parent.mkdir(parents=True, exist_ok=True)
    if target.exists() or target.is_symlink():
        if target.is_dir() and not target.is_symlink():
            shutil.rmtree(target)
        else:
            target.unlink()
    if source.is_symlink():
        os.symlink(os.readlink(source), target)
    else:
        shutil.copy2(source, target, follow_symlinks=False)


@lru_cache(maxsize=1)
def _gnu_cp_path() -> str | None:
    cp_path = shutil.which("cp")
    if not cp_path:
        return None
    completed = subprocess.run(
        [cp_path, "--version"],
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode != 0:
        return None
    if b"GNU coreutils" not in completed.stdout:
        return None
    return cp_path


def _is_copy_strategy_mismatch(error: UserError) -> bool:
    message = str(error)
    retryable_fragments = (
        "--reflink",
        "illegal option",
        "unknown option",
        "Operation not supported",
        "Not supported",
        "Cross-device link",
        "Invalid argument",
        "failed to clone",
        "clonefile failed",
    )
    return any(fragment in message for fragment in retryable_fragments)


def _copy_dir_contents(source: pathlib.Path, target: pathlib.Path) -> None:
    target.mkdir(parents=True, exist_ok=True)
    source_arg = f"{source}{os.sep}."
    gnu_cp = _gnu_cp_path()
    if gnu_cp is not None:
        try:
            _run([gnu_cp, "-a", "--reflink=always", source_arg, str(target)])
            return
        except UserError as error:
            if not _is_copy_strategy_mismatch(error):
                raise
    if sys.platform == "darwin" and pathlib.Path("/bin/cp").exists():
        try:
            _run(["/bin/cp", "-cRp", source_arg, str(target)])
            return
        except UserError as error:
            if not _is_copy_strategy_mismatch(error):
                raise

    fallback_cp = gnu_cp or shutil.which("cp") or "/bin/cp"
    _run([fallback_cp, "-Rp", source_arg, str(target)])


def _copy_path(source: pathlib.Path, target: pathlib.Path) -> None:
    if source.is_dir() and not source.is_symlink():
        if target.exists() and not target.is_dir():
            target.unlink()
        _copy_dir_contents(source, target)
        return
    _copy_file_or_symlink(source, target)


def _remove_path(path: pathlib.Path) -> None:
    if path.is_dir() and not path.is_symlink():
        shutil.rmtree(path)
        return
    if path.exists() or path.is_symlink():
        path.unlink()


def _is_relative_to(path: pathlib.Path, candidate: pathlib.Path) -> bool:
    try:
        path.relative_to(candidate)
        return True
    except ValueError:
        return False


def _is_safe_path_entry(path: str | pathlib.Path) -> bool:
    return os.pathsep not in os.fspath(path)


def _is_default_nvm_bin_entry(path: pathlib.Path, nvm_root: pathlib.Path) -> bool:
    versions_root = nvm_root / "versions" / "node"
    if not _is_relative_to(path, versions_root):
        return False
    relative = path.relative_to(versions_root)
    return len(relative.parts) == 2 and relative.parts[1] == "bin"


def _default_nvm_root() -> pathlib.Path:
    nvm_dir = os.environ.get("NVM_DIR")
    if nvm_dir and _is_safe_path_entry(nvm_dir):
        candidate = pathlib.Path(nvm_dir).expanduser()
        if candidate.is_absolute():
            return candidate.resolve(strict=False)
    return (pathlib.Path.home() / ".nvm").resolve(strict=False)


def _read_nvm_alias_target(nvm_root: pathlib.Path, alias_name: str) -> str | None:
    alias_root = (nvm_root / "alias").resolve(strict=False)
    alias_path = (alias_root / alias_name).resolve(strict=False)
    if not _is_relative_to(alias_path, alias_root):
        return None
    try:
        alias_text = alias_path.read_text(encoding="utf-8")
    except OSError:
        return None
    for line in alias_text.splitlines():
        target = line.split("#", 1)[0].strip()
        if target:
            return target
    return None


def _nvm_version_bin_for_target(
    nvm_root: pathlib.Path,
    target: str,
) -> pathlib.Path | None:
    if target == "system":
        return None
    versions_root = nvm_root / "versions" / "node"
    candidate_names = [target]
    if target and not target.startswith("v"):
        candidate_names.append(f"v{target}")
    for candidate_name in candidate_names:
        candidate = (versions_root / candidate_name / "bin").resolve(strict=False)
        if _is_default_nvm_bin_entry(candidate, nvm_root) and candidate.is_dir():
            return candidate
    partial_match = re.match(r"\Av?(\d+)(?:\.(\d+))?\Z", target)
    if partial_match:
        raw_parts = partial_match.groups()
        prefix = tuple(int(part) for part in raw_parts if part is not None)
        matching_bins: list[pathlib.Path] = []
        for candidate_bin in _installed_nvm_version_bins(nvm_root):
            version_key = _nvm_version_key(candidate_bin.parent.name)
            if version_key is None:
                continue
            if version_key[: len(prefix)] == prefix:
                matching_bins.append(candidate_bin)
        return _highest_nvm_version_bin(nvm_root, matching_bins)
    return None


def _nvm_version_key(version_name: str) -> tuple[int, int, int, int, str] | None:
    match = re.match(r"\Av?(\d+)\.(\d+)\.(\d+)(.*)\Z", version_name)
    if not match:
        return None
    major, minor, patch, suffix = match.groups()
    release_rank = 1 if not suffix else 0
    return (int(major), int(minor), int(patch), release_rank, suffix)


def _highest_nvm_version_bin(
    nvm_root: pathlib.Path,
    candidate_bins: Iterable[pathlib.Path],
) -> pathlib.Path | None:
    candidates: list[tuple[tuple[int, int, int, int, str], pathlib.Path]] = []
    for candidate_bin in candidate_bins:
        resolved_bin = candidate_bin.resolve(strict=False)
        if not _is_default_nvm_bin_entry(resolved_bin, nvm_root):
            continue
        if not resolved_bin.is_dir():
            continue
        version_key = _nvm_version_key(resolved_bin.parent.name)
        if version_key is None:
            continue
        candidates.append((version_key, resolved_bin))
    if not candidates:
        return None
    return max(candidates, key=lambda item: item[0])[1]


def _installed_nvm_version_bins(nvm_root: pathlib.Path) -> tuple[pathlib.Path, ...]:
    versions_root = nvm_root / "versions" / "node"
    try:
        version_dirs = tuple(versions_root.iterdir())
    except OSError:
        return ()
    return tuple(version_dir / "bin" for version_dir in version_dirs)


def _lts_nvm_alias_bins(nvm_root: pathlib.Path) -> tuple[pathlib.Path, ...]:
    bins: list[pathlib.Path] = []
    literal_target = _read_nvm_alias_target(nvm_root, "lts/*")
    if literal_target:
        literal_bin = _nvm_version_bin_for_target(nvm_root, literal_target)
        if literal_bin:
            bins.append(literal_bin)

    lts_alias_root = (nvm_root / "alias" / "lts").resolve(strict=False)
    try:
        alias_paths = tuple(lts_alias_root.iterdir())
    except OSError:
        return tuple(bins)
    for alias_path in alias_paths:
        alias_name = alias_path.name
        target = _read_nvm_alias_target(nvm_root, f"lts/{alias_name}")
        if not target:
            continue
        version_bin = _nvm_version_bin_for_target(nvm_root, target)
        if version_bin:
            bins.append(version_bin)
    return tuple(bins)


def _builtin_nvm_alias_bin(
    nvm_root: pathlib.Path,
    target: str,
) -> pathlib.Path | None:
    if target in {"node", "stable"}:
        return _highest_nvm_version_bin(nvm_root, _installed_nvm_version_bins(nvm_root))
    if target == "lts/*":
        return _highest_nvm_version_bin(nvm_root, _lts_nvm_alias_bins(nvm_root))
    return None


def _default_nvm_alias_bin(nvm_root: pathlib.Path) -> pathlib.Path | None:
    target = _read_nvm_alias_target(nvm_root, "default")
    if not target:
        return None

    seen: set[str] = {"default"}
    for _ in range(8):
        if target in seen:
            return None
        seen.add(target)
        if target == "system":
            return None
        alias_target = _read_nvm_alias_target(nvm_root, target)
        if alias_target:
            target = alias_target
            continue
        version_bin = _nvm_version_bin_for_target(nvm_root, target)
        if version_bin:
            return version_bin
        builtin_bin = _builtin_nvm_alias_bin(nvm_root, target)
        if builtin_bin:
            return builtin_bin
        return None
    return None


def _trusted_nvm_bin_entries() -> tuple[str, ...]:
    nvm_root = _default_nvm_root()
    entries: list[str] = []
    seen: set[str] = set()

    def add_candidate(raw_path: str | pathlib.Path | None) -> None:
        if not raw_path:
            return
        candidate = pathlib.Path(raw_path).expanduser()
        if not candidate.is_absolute():
            return
        resolved = candidate.resolve(strict=False)
        if not _is_safe_path_entry(candidate) or not _is_safe_path_entry(resolved):
            return
        if not _is_default_nvm_bin_entry(resolved, nvm_root):
            return
        if not candidate.is_dir():
            return
        entry = str(resolved)
        if entry in seen:
            return
        seen.add(entry)
        entries.append(entry)

    default_nvm_bin = _default_nvm_alias_bin(nvm_root)
    add_candidate(default_nvm_bin)

    raw_nvm_bin = os.environ.get("NVM_BIN")
    if default_nvm_bin is not None and raw_nvm_bin:
        nvm_bin = pathlib.Path(raw_nvm_bin).expanduser()
        if nvm_bin.is_absolute() and nvm_bin.resolve(strict=False) == default_nvm_bin:
            add_candidate(nvm_bin)

    return tuple(entries)


def _nvm_bin_for_resolved_path(
    path: str | pathlib.Path,
    nvm_root: pathlib.Path,
) -> pathlib.Path | None:
    if not _is_safe_path_entry(nvm_root):
        return None
    versions_root = nvm_root / "versions" / "node"
    resolved = pathlib.Path(path).expanduser().resolve(strict=False)
    if not _is_relative_to(resolved, versions_root):
        return None
    relative = resolved.relative_to(versions_root)
    if len(relative.parts) < 2:
        return None
    nvm_bin = versions_root / relative.parts[0] / "bin"
    if not nvm_bin.is_dir():
        return None
    return nvm_bin.resolve(strict=False)


def _matching_default_nvm_bin_for_path(path: str | pathlib.Path) -> str | None:
    nvm_root = _default_nvm_root()
    nvm_bin = _nvm_bin_for_resolved_path(path, nvm_root)
    if nvm_bin is None:
        return None
    default_nvm_bin = _default_nvm_alias_bin(nvm_root)
    if default_nvm_bin is None:
        return None
    if nvm_bin != default_nvm_bin.resolve(strict=False):
        return None
    if not _is_safe_path_entry(nvm_bin):
        return None
    return str(nvm_bin)


def _matching_default_nvm_version_root_for_bin_member(
    path: str | pathlib.Path,
) -> pathlib.Path | None:
    nvm_root = _default_nvm_root()
    if not _is_safe_path_entry(nvm_root):
        return None
    versions_root = nvm_root / "versions" / "node"
    candidate = pathlib.Path(path).expanduser()
    if not candidate.is_absolute():
        return None
    canonical_link = candidate.parent.resolve(strict=False) / candidate.name
    if not _is_relative_to(canonical_link, versions_root):
        return None
    relative = canonical_link.relative_to(versions_root)
    if len(relative.parts) < 3 or relative.parts[1] != "bin":
        return None
    nvm_bin = versions_root / relative.parts[0] / "bin"
    default_nvm_bin = _default_nvm_alias_bin(nvm_root)
    if default_nvm_bin is None:
        return None
    if nvm_bin.resolve(strict=False) != default_nvm_bin.resolve(strict=False):
        return None
    if not nvm_bin.is_dir():
        return None
    return (versions_root / relative.parts[0]).resolve(strict=False)


def _is_trusted_default_nvm_codex_candidate(
    path: pathlib.Path,
    resolved_path: pathlib.Path,
) -> bool | None:
    version_root = _matching_default_nvm_version_root_for_bin_member(path)
    if version_root is None:
        return None
    return _is_relative_to(resolved_path, version_root)


def _is_excluded(
    relative_path: pathlib.Path,
    excluded_paths: Iterable[pathlib.Path],
) -> bool:
    if relative_path.parts and relative_path.parts[0] == ".codex-tmp":
        return True
    for excluded in excluded_paths:
        if relative_path == excluded or _is_relative_to(relative_path, excluded):
            return True
    return False


def _has_excluded_descendants(
    relative_path: pathlib.Path,
    excluded_paths: Iterable[pathlib.Path],
) -> bool:
    for excluded in excluded_paths:
        if excluded == relative_path:
            continue
        if _is_relative_to(excluded, relative_path):
            return True
    return False


def _materialize_directory_contents(
    source_dir: pathlib.Path,
    target_dir: pathlib.Path,
    *,
    source_root: pathlib.Path,
    excluded_paths: Iterable[pathlib.Path],
) -> None:
    target_dir.mkdir(parents=True, exist_ok=True)
    source_children: dict[str, pathlib.Path] = {}
    relative_dir = source_dir.relative_to(source_root)
    for source_child in source_dir.iterdir():
        child_relative = source_child.relative_to(source_root)
        if _is_excluded(child_relative, excluded_paths):
            continue
        source_children[source_child.name] = source_child
        _materialize_path(
            source_child,
            target_dir / source_child.name,
            source_root=source_root,
            excluded_paths=excluded_paths,
        )

    for target_child in target_dir.iterdir():
        child_relative = relative_dir / target_child.name
        if _is_excluded(child_relative, excluded_paths):
            continue
        if target_child.name not in source_children:
            _remove_path(target_child)


def _materialize_path(
    source_path: pathlib.Path,
    target_path: pathlib.Path,
    *,
    source_root: pathlib.Path,
    excluded_paths: Iterable[pathlib.Path],
) -> None:
    relative_path = source_path.relative_to(source_root)
    if _is_excluded(relative_path, excluded_paths):
        return

    if source_path.is_dir() and not source_path.is_symlink():
        if target_path.exists() and (not target_path.is_dir() or target_path.is_symlink()):
            _remove_path(target_path)
        if not _has_excluded_descendants(relative_path, excluded_paths):
            if target_path.exists():
                shutil.rmtree(target_path)
            _copy_dir_contents(source_path, target_path)
            return
        _materialize_directory_contents(
            source_path,
            target_path,
            source_root=source_root,
            excluded_paths=excluded_paths,
        )
        return

    _copy_file_or_symlink(source_path, target_path)


def _tracked_codex_tmp_change_paths(repo_root: pathlib.Path) -> list[pathlib.Path]:
    completed = _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "diff",
            "--no-ext-diff",
            "--no-textconv",
            "--name-only",
            "-z",
            "HEAD",
            "--",
            ".codex-tmp",
        ],
        capture_output=True,
    )
    paths: list[pathlib.Path] = []
    for raw_path in completed.stdout.split(b"\0"):
        if not raw_path:
            continue
        relative_path = pathlib.Path(os.fsdecode(raw_path))
        if relative_path.parts and relative_path.parts[0] == ".codex-tmp":
            paths.append(relative_path)
    return paths


def _git_path_is_tracked(repo_root: pathlib.Path, relative_path: pathlib.Path) -> bool:
    command = [
        _resolve_real_git(),
        "-C",
        str(repo_root),
        "ls-files",
        "--error-unmatch",
        "--",
        relative_path.as_posix(),
    ]
    completed = subprocess.run(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode == 0:
        return True
    if completed.returncode == 1:
        return False
    raise UserError(_format_command_error(command, completed))


def _materialize_tracked_codex_tmp_changes(
    source_repo: pathlib.Path,
    target_repo: pathlib.Path,
) -> None:
    for relative_path in _tracked_codex_tmp_change_paths(source_repo):
        source_path = source_repo / relative_path
        target_path = target_repo / relative_path
        if not _git_path_is_tracked(source_repo, relative_path):
            _remove_path(target_path)
            continue
        if source_path.exists() or source_path.is_symlink():
            if source_path.is_dir() and not source_path.is_symlink():
                _remove_path(target_path)
                continue
            _copy_file_or_symlink(source_path, target_path)
            if not _git_path_is_tracked(target_repo, relative_path):
                _run(
                    [
                        _resolve_real_git(),
                        "-C",
                        str(target_repo),
                        "add",
                        "--intent-to-add",
                        "--force",
                        "--",
                        relative_path.as_posix(),
                    ],
                    capture_output=True,
                )
            continue
        _remove_path(target_path)


def _materialize_repo_snapshot(source_repo: pathlib.Path, target_repo: pathlib.Path) -> None:
    _ensure_no_conflicts(source_repo)
    source_head = _git_stdout(source_repo, "rev-parse", "HEAD")
    target_head = _git_stdout(target_repo, "rev-parse", "HEAD")
    if target_head != source_head:
        _run([_resolve_real_git(), "-C", str(target_repo), "checkout", "--detach", source_head])

    direct_submodules = _list_direct_submodules(source_repo)
    excluded_paths = [
        pathlib.Path(".git"),
        pathlib.Path(".codex-tmp"),
        *direct_submodules,
    ]
    _materialize_directory_contents(
        source_repo,
        target_repo,
        source_root=source_repo,
        excluded_paths=excluded_paths,
    )
    _materialize_tracked_codex_tmp_changes(source_repo, target_repo)

    for submodule_path in direct_submodules:
        source_submodule = source_repo / submodule_path
        target_submodule = target_repo / submodule_path
        if not source_submodule.exists() or not _is_git_worktree_root(source_submodule):
            continue
        if not target_submodule.exists() or not _is_git_worktree_root(target_submodule):
            continue
        _materialize_repo_snapshot(source_submodule, target_submodule)


def _checkout_snapshot_worktree(target_repo: pathlib.Path) -> None:
    _run(
        [
            _resolve_real_git(),
            "-C",
            str(target_repo),
            "checkout",
            "--detach",
            "--force",
            "HEAD",
        ],
        capture_output=True,
    )


def _prepare_submodule_worktrees(
    source_repo: pathlib.Path,
    target_repo: pathlib.Path,
) -> None:
    for submodule_path in _list_direct_submodules(source_repo):
        source_submodule = source_repo / submodule_path
        if not source_submodule.exists() or not _is_git_worktree_root(source_submodule):
            continue

        target_submodule = target_repo / submodule_path
        if target_submodule.exists() or target_submodule.is_symlink():
            _remove_path(target_submodule)
        target_submodule.parent.mkdir(parents=True, exist_ok=True)

        _run(
            [
                _resolve_real_git(),
                "-C",
                str(source_submodule),
                "worktree",
                "add",
                "--detach",
                "--no-checkout",
                str(target_submodule),
                "HEAD",
            ],
            capture_output=True,
        )
        _checkout_snapshot_worktree(target_submodule)
        _prepare_submodule_worktrees(source_submodule, target_submodule)


def _checkout_submodules(repo_root: pathlib.Path) -> None:
    if not (repo_root / ".gitmodules").exists():
        return
    _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "-c",
            "protocol.file.allow=always",
            "submodule",
            "update",
            "--init",
            "--checkout",
            "--recursive",
        ],
        capture_output=True,
    )


def _cleanup_submodule_worktrees(
    source_repo: pathlib.Path,
    target_repo: pathlib.Path,
) -> None:
    for submodule_path in _list_direct_submodules(source_repo):
        source_submodule = source_repo / submodule_path
        target_submodule = target_repo / submodule_path
        if not source_submodule.exists() or not _is_git_worktree_root(source_submodule):
            continue
        if not target_submodule.exists() or not _is_git_worktree_root(target_submodule):
            continue
        _cleanup_submodule_worktrees(source_submodule, target_submodule)
        _run(
            [
                _resolve_real_git(),
                "-C",
                str(source_submodule),
                "worktree",
                "remove",
                "--force",
                str(target_submodule),
            ],
            capture_output=True,
        )


def _copy_input_path(
    source_path: pathlib.Path,
    *,
    source_root: pathlib.Path,
    target_root: pathlib.Path,
    bucket: str,
) -> pathlib.Path:
    if _is_relative_to(source_path, source_root):
        relative_path = source_path.relative_to(source_root)
        target_path = target_root / relative_path
    else:
        target_path = (
            target_root
            / ".codex-tmp"
            / "isolated-review-inputs"
            / bucket
            / source_path.name
        )
    _copy_path(source_path, target_path)
    return target_path


def _write_generated_review_diff(
    *,
    target_root: pathlib.Path,
    base_ref: str,
    head_ref: str,
    output_root: pathlib.Path | None = None,
) -> pathlib.Path:
    diff_root = output_root or target_root
    diff_target = (
        diff_root
        / ".codex-tmp"
        / "isolated-review-inputs"
        / "diff"
        / f"{base_ref[:12]}..{head_ref[:12]}.diff"
    )
    diff_target.parent.mkdir(parents=True, exist_ok=True)
    completed = _run(
        [
            _resolve_real_git(),
            "-C",
            str(target_root),
            "diff",
            "--no-ext-diff",
            "--no-textconv",
            "--binary",
            "--submodule=diff",
            base_ref,
            head_ref,
        ],
        capture_output=True,
    )
    diff_target.write_bytes(completed.stdout)
    return diff_target


def _count_tracked_repo_files(repo_root: pathlib.Path) -> int:
    completed = _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "ls-files",
            "-z",
        ],
        capture_output=True,
    )
    tracked_files = sum(1 for raw_path in completed.stdout.split(b"\0") if raw_path)
    for submodule_path in _list_direct_submodules(repo_root):
        submodule_root = repo_root / submodule_path
        if not submodule_root.exists() or not _is_git_worktree_root(submodule_root):
            continue
        tracked_files -= 1
        tracked_files += _count_tracked_repo_files(submodule_root)
    return tracked_files


def _parse_diff_numstat(stdout: bytes) -> tuple[int, int]:
    changed_files = 0
    changed_lines = 0
    for line in stdout.decode("utf-8", errors="replace").splitlines():
        parts = line.split("\t", 2)
        if len(parts) < 3:
            continue
        changed_files += 1
        added, deleted = parts[0], parts[1]
        if added.isdigit():
            changed_lines += int(added)
        if deleted.isdigit():
            changed_lines += int(deleted)
    return changed_files, changed_lines


def _review_diff_budget_metrics_from_lines(
    lines: Iterable[bytes],
) -> tuple[int, int, int, int]:
    changed_files = 0
    changed_lines = 0
    diff_bytes = 0
    max_changed_line_bytes = 0
    in_hunk = False
    for raw_line in lines:
        diff_bytes += len(raw_line)
        if raw_line.startswith(b"diff --git "):
            changed_files += 1
            in_hunk = False
            continue
        if raw_line.startswith(b"@@"):
            in_hunk = True
            continue
        if not in_hunk:
            continue
        if raw_line.startswith((b"+", b"-")):
            changed_lines += 1
            line_bytes = max(0, len(raw_line.rstrip(b"\r\n")) - 1)
            max_changed_line_bytes = max(max_changed_line_bytes, line_bytes)
    return changed_files, changed_lines, diff_bytes, max_changed_line_bytes


def _review_diff_metrics_from_lines(lines: Iterable[bytes]) -> tuple[int, int]:
    changed_files, changed_lines, _, _ = _review_diff_budget_metrics_from_lines(lines)
    return changed_files, changed_lines


def _review_diff_metrics_from_bytes(diff_bytes: bytes) -> tuple[int, int]:
    return _review_diff_metrics_from_lines(diff_bytes.splitlines())


def _review_diff_budget_metrics_from_bytes(
    diff_bytes: bytes,
) -> tuple[int, int, int, int]:
    changed_files, changed_lines, _, max_changed_line_bytes = (
        _review_diff_budget_metrics_from_lines(diff_bytes.splitlines())
    )
    return changed_files, changed_lines, len(diff_bytes), max_changed_line_bytes


def _review_diff_file_metrics(diff_file: pathlib.Path) -> tuple[int, int]:
    with diff_file.open("rb") as handle:
        return _review_diff_metrics_from_lines(handle)


def _review_diff_file_budget_metrics(
    diff_file: pathlib.Path,
) -> tuple[int, int, int, int]:
    with diff_file.open("rb") as handle:
        return _review_diff_budget_metrics_from_lines(handle)


def _codex_review_builtin_budget_exceeded(metrics: tuple[int, int, int, int]) -> bool:
    changed_files, changed_lines, diff_bytes, max_changed_line_bytes = metrics
    return (
        changed_files >= CODEX_REVIEW_BUILTIN_MAX_CHANGED_FILES
        or changed_lines >= CODEX_REVIEW_BUILTIN_MAX_CHANGED_LINES
        or diff_bytes >= CODEX_REVIEW_BUILTIN_MAX_DIFF_BYTES
        or max_changed_line_bytes >= CODEX_REVIEW_BUILTIN_MAX_CHANGED_LINE_BYTES
    )


def _streaming_review_diff_budget_metrics(
    command: list[str],
    *,
    stop_when_oversized: bool = False,
) -> tuple[int, int, int, int]:
    process = subprocess.Popen(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    assert process.stdout is not None
    changed_files = 0
    changed_lines = 0
    diff_bytes = 0
    max_changed_line_bytes = 0
    in_hunk = False
    continuation_kind: str | None = None
    current_changed_line_bytes = 0
    stopped_for_budget = False
    read_limit = CODEX_REVIEW_BUILTIN_MAX_CHANGED_LINE_BYTES + 2
    while True:
        raw_line = process.stdout.readline(read_limit)
        if not raw_line:
            break
        diff_bytes += len(raw_line)
        ends_line = raw_line.endswith(b"\n")
        segment = raw_line.rstrip(b"\r\n") if ends_line else raw_line

        if continuation_kind == "changed":
            current_changed_line_bytes += len(segment)
            max_changed_line_bytes = max(
                max_changed_line_bytes,
                current_changed_line_bytes,
            )
            if ends_line:
                continuation_kind = None
                current_changed_line_bytes = 0
        elif continuation_kind == "other":
            if ends_line:
                continuation_kind = None
        elif raw_line.startswith(b"diff --git "):
            changed_files += 1
            in_hunk = False
            if not ends_line:
                continuation_kind = "other"
        elif raw_line.startswith(b"@@"):
            in_hunk = True
            if not ends_line:
                continuation_kind = "other"
        elif in_hunk and raw_line.startswith((b"+", b"-")):
            changed_lines += 1
            current_changed_line_bytes = max(0, len(segment) - 1)
            max_changed_line_bytes = max(
                max_changed_line_bytes,
                current_changed_line_bytes,
            )
            if not ends_line:
                continuation_kind = "changed"
        elif not ends_line:
            continuation_kind = "other"

        metrics = (
            changed_files,
            changed_lines,
            diff_bytes,
            max_changed_line_bytes,
        )
        if stop_when_oversized and _codex_review_builtin_budget_exceeded(metrics):
            stopped_for_budget = True
            process.terminate()
            break

    try:
        _stdout, stderr = process.communicate(timeout=5)
    except subprocess.TimeoutExpired:
        process.kill()
        _stdout, stderr = process.communicate()
    if process.returncode != 0 and not stopped_for_budget:
        completed = subprocess.CompletedProcess(
            command,
            process.returncode,
            stdout=b"",
            stderr=stderr,
        )
        raise UserError(_format_command_error(command, completed))
    return changed_files, changed_lines, diff_bytes, max_changed_line_bytes


def _streaming_diff_numstat_metrics(
    command: list[str],
    *,
    stop_when_oversized: bool = False,
) -> tuple[int, int]:
    process = subprocess.Popen(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    assert process.stdout is not None
    changed_files = 0
    changed_lines = 0
    stopped_for_budget = False
    while True:
        raw_line = process.stdout.readline()
        if not raw_line:
            break
        parsed_files, parsed_lines = _parse_diff_numstat(raw_line)
        changed_files += parsed_files
        changed_lines += parsed_lines
        if stop_when_oversized and _codex_review_builtin_budget_exceeded(
            (changed_files, changed_lines, 0, 0)
        ):
            stopped_for_budget = True
            process.terminate()
            break

    try:
        _stdout, stderr = process.communicate(timeout=5)
    except subprocess.TimeoutExpired:
        process.kill()
        _stdout, stderr = process.communicate()
    if process.returncode != 0 and not stopped_for_budget:
        completed = subprocess.CompletedProcess(
            command,
            process.returncode,
            stdout=b"",
            stderr=stderr,
        )
        raise UserError(_format_command_error(command, completed))
    return changed_files, changed_lines


def _review_scope_numstat_metrics(
    repo_root: pathlib.Path,
    *,
    base_ref: str | None,
    head_ref: str | None,
    stop_when_oversized: bool = False,
) -> tuple[int, int]:
    command = [
        _resolve_real_git(),
        "-C",
        str(repo_root),
        "diff",
        "--numstat",
        "--no-ext-diff",
        "--no-textconv",
    ]
    if base_ref is not None and head_ref is not None:
        command.extend([base_ref, head_ref])
    else:
        command.append("HEAD")
    return _streaming_diff_numstat_metrics(
        command,
        stop_when_oversized=stop_when_oversized,
    )


def _review_scope_diff_budget_metrics(
    repo_root: pathlib.Path,
    *,
    base_ref: str,
    head_ref: str,
    stop_when_oversized: bool = False,
) -> tuple[int, int, int, int]:
    return _streaming_review_diff_budget_metrics(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "diff",
            "--no-ext-diff",
            "--no-textconv",
            "--binary",
            "--submodule=diff",
            base_ref,
            head_ref,
        ],
        stop_when_oversized=stop_when_oversized,
    )


def _uncommitted_tracked_diff_budget_metrics(
    repo_root: pathlib.Path,
    *,
    stop_when_oversized: bool = False,
) -> tuple[int, int, int, int]:
    return _streaming_review_diff_budget_metrics(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "diff",
            "--no-ext-diff",
            "--no-textconv",
            "--binary",
            "--submodule=diff",
            "HEAD",
        ],
        stop_when_oversized=stop_when_oversized,
    )


def _review_scope_change_metrics(
    repo_root: pathlib.Path,
    *,
    base_ref: str | None,
    head_ref: str | None,
) -> tuple[int, int]:
    changed_files, changed_lines = _review_scope_numstat_metrics(
        repo_root,
        base_ref=base_ref,
        head_ref=head_ref,
    )
    if base_ref is not None and head_ref is not None:
        diff_changed_files, diff_changed_lines, _, _ = _review_scope_diff_budget_metrics(
            repo_root,
            base_ref=base_ref,
            head_ref=head_ref,
        )
    else:
        expanded_diff = _uncommitted_diff_section(repo_root, scope_label=None)
        diff_changed_files, diff_changed_lines = _review_diff_metrics_from_bytes(expanded_diff)
    changed_files = max(changed_files, diff_changed_files)
    changed_lines = max(changed_lines, diff_changed_lines)
    return changed_files, changed_lines


def _review_scope_change_budget_metrics(
    repo_root: pathlib.Path,
    *,
    base_ref: str | None,
    head_ref: str | None,
) -> tuple[int, int, int, int]:
    if base_ref is None or head_ref is None:
        return _uncommitted_scope_change_budget_metrics(repo_root)

    changed_files, changed_lines = _review_scope_numstat_metrics(
        repo_root,
        base_ref=base_ref,
        head_ref=head_ref,
        stop_when_oversized=True,
    )
    if _codex_review_builtin_budget_exceeded((changed_files, changed_lines, 0, 0)):
        return changed_files, changed_lines, 0, 0
    diff_changed_files, diff_changed_lines, total_bytes, max_changed_line_bytes = (
        _review_scope_diff_budget_metrics(
            repo_root,
            base_ref=base_ref,
            head_ref=head_ref,
            stop_when_oversized=True,
        )
    )
    return (
        max(changed_files, diff_changed_files),
        max(changed_lines, diff_changed_lines),
        total_bytes,
        max_changed_line_bytes,
    )


def _untracked_text_patch_budget_metrics(
    *,
    path_label: str,
    file_mode: str,
    contents: str,
) -> tuple[int, int, int, int]:
    patch_text = "".join(
        difflib.unified_diff(
            [],
            contents.splitlines(keepends=True),
            fromfile="/dev/null",
            tofile=f"b/{path_label}",
            n=0,
        )
    )
    patch_bytes = (
        f"diff --git a/{path_label} b/{path_label}\n"
        f"new file mode {file_mode}\n"
        f"{patch_text}"
    ).encode("utf-8", errors="surrogateescape")
    return _review_diff_budget_metrics_from_bytes(patch_bytes)


def _untracked_binary_patch_budget_metrics(
    *,
    path_label: str,
    file_mode: str,
    file_size: int,
) -> tuple[int, int, int, int]:
    patch_bytes = (
        f"diff --git a/{path_label} b/{path_label}\n"
        f"new file mode {file_mode}\n"
        f"Binary file added: {path_label} ({file_size} bytes)\n"
    ).encode("utf-8", errors="surrogateescape")
    return _review_diff_budget_metrics_from_bytes(patch_bytes)


def _untracked_path_budget_metrics(
    repo_root: pathlib.Path,
    relative_path: pathlib.Path,
) -> tuple[int, int, int, int]:
    file_path = repo_root / relative_path
    path_label = relative_path.as_posix()
    header_bytes = len(
        (
            f"diff --git a/{path_label} b/{path_label}\n"
            f"new file mode {'120000' if file_path.is_symlink() else '100644'}\n"
        ).encode("utf-8", errors="surrogateescape")
    )
    if file_path.is_symlink():
        return _untracked_text_patch_budget_metrics(
            path_label=path_label,
            file_mode="120000",
            contents=os.readlink(file_path),
        )
    if not file_path.is_file():
        return 0, 0, 0, 0

    file_size = file_path.stat().st_size
    if file_size > CODEX_REVIEW_BUILTIN_MAX_DIFF_BYTES:
        return (
            1,
            1,
            header_bytes + file_size,
            min(file_size, CODEX_REVIEW_BUILTIN_MAX_CHANGED_LINE_BYTES + 1),
        )

    file_mode = "100755" if os.access(file_path, os.X_OK) else "100644"
    data = file_path.read_bytes()
    if b"\0" in data:
        return _untracked_binary_patch_budget_metrics(
            path_label=path_label,
            file_mode=file_mode,
            file_size=len(data),
        )
    return _untracked_text_patch_budget_metrics(
        path_label=path_label,
        file_mode=file_mode,
        contents=data.decode("utf-8", errors="surrogateescape"),
    )


def _combine_budget_metrics(
    left: tuple[int, int, int, int],
    right: tuple[int, int, int, int],
) -> tuple[int, int, int, int]:
    return (
        left[0] + right[0],
        left[1] + right[1],
        left[2] + right[2],
        max(left[3], right[3]),
    )


def _uncommitted_scope_change_budget_metrics(
    repo_root: pathlib.Path,
) -> tuple[int, int, int, int]:
    metrics = _uncommitted_tracked_diff_budget_metrics(
        repo_root,
        stop_when_oversized=True,
    )
    if _codex_review_builtin_budget_exceeded(metrics):
        return metrics
    metrics = _untracked_repo_budget_metrics(repo_root, initial_metrics=metrics)
    if _codex_review_builtin_budget_exceeded(metrics):
        return metrics
    for submodule_path in _list_direct_submodules(repo_root):
        submodule_root = repo_root / submodule_path
        if not submodule_root.exists() or not _is_git_worktree_root(submodule_root):
            continue
        metrics = _combine_budget_metrics(
            metrics,
            _uncommitted_scope_change_budget_metrics(submodule_root),
        )
        if _codex_review_builtin_budget_exceeded(metrics):
            return metrics
    return metrics


def _parallel_agentic_review_policy(
    repo_root: pathlib.Path,
    *,
    base_ref: str | None,
    head_ref: str | None,
    diff_file: pathlib.Path | None = None,
) -> dict[str, object]:
    tracked_files = _count_tracked_repo_files(repo_root)
    if diff_file is not None and diff_file.is_file():
        changed_files, changed_lines = _review_diff_file_metrics(diff_file)
    else:
        changed_files, changed_lines = _review_scope_change_metrics(
            repo_root,
            base_ref=base_ref,
            head_ref=head_ref,
        )

    tier = 0
    if tracked_files >= 25000 or changed_files >= 200 or changed_lines >= 15000:
        tier = 3
    elif tracked_files >= 12000 or changed_files >= 75 or changed_lines >= 5000:
        tier = 2
    elif tracked_files >= 4000 or changed_files >= 25 or changed_lines >= 1500:
        tier = 1

    timeout_budget_seconds = (
        CODEX_PARALLEL_AGENTIC_TIMEOUT_SECONDS,
        30.0 * 60.0,
        45.0 * 60.0,
        CODEX_PARALLEL_AGENTIC_MAX_TIMEOUT_SECONDS,
    )[tier]
    initial_quiet_seconds = (
        CODEX_PARALLEL_AGENTIC_INITIAL_QUIET_SECONDS,
        5.0 * 60.0,
        8.0 * 60.0,
        CODEX_PARALLEL_AGENTIC_MAX_INITIAL_QUIET_SECONDS,
    )[tier]
    progress_lease_seconds = (
        CODEX_PARALLEL_AGENTIC_PROGRESS_LEASE_SECONDS,
        8.0 * 60.0,
        10.0 * 60.0,
        CODEX_PARALLEL_AGENTIC_MAX_PROGRESS_LEASE_SECONDS,
    )[tier]
    return {
        "tracked_files": tracked_files,
        "changed_files": changed_files,
        "changed_lines": changed_lines,
        "tier": tier,
        "agentic_timeout_budget_seconds": timeout_budget_seconds,
        "agentic_initial_quiet_seconds": initial_quiet_seconds,
        "agentic_progress_lease_seconds": progress_lease_seconds,
    }


def _stateful_codex_timeout_keys(entrypoint: str) -> dict[str, str]:
    prefix = entrypoint.replace("-", "_")
    return {
        "budget": f"{prefix}_timeout_budget_seconds",
        "initial_quiet": f"{prefix}_initial_quiet_seconds",
        "progress_lease": f"{prefix}_progress_lease_seconds",
        "policy_error": f"{prefix}_policy_error",
        "output_snapshot": f"{prefix}_output_snapshot",
        "last_output_at": f"{prefix}_last_output_at",
        "timed_out": f"{prefix}_timed_out",
        "term_sent_at": f"{prefix}_term_sent_at",
        "kill_sent_at": f"{prefix}_kill_sent_at",
    }


def _maybe_populate_stateful_codex_timeout_policy(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    entrypoint: str,
    repo_root: pathlib.Path | None = None,
) -> None:
    keys = _stateful_codex_timeout_keys(entrypoint)
    if all(
        key in state
        for key in (
            keys["budget"],
            keys["initial_quiet"],
            keys["progress_lease"],
        )
    ):
        return

    resolved_repo_root = repo_root
    if resolved_repo_root is None:
        workspace_root_raw = state.get("workspace_root")
        if isinstance(workspace_root_raw, str) and workspace_root_raw:
            resolved_repo_root = pathlib.Path(workspace_root_raw)
        else:
            source_root_raw = state.get("source_root")
            if isinstance(source_root_raw, str) and source_root_raw:
                resolved_repo_root = pathlib.Path(source_root_raw)
    if resolved_repo_root is None:
        return

    diff_file_raw = state.get("diff_file")
    diff_file = (
        pathlib.Path(str(diff_file_raw))
        if isinstance(diff_file_raw, str) and diff_file_raw
        else None
    )
    try:
        policy = _parallel_agentic_review_policy(
            resolved_repo_root,
            base_ref=str(state.get("base_ref")) if state.get("base_ref") else None,
            head_ref=str(state.get("head_ref")) if state.get("head_ref") else None,
            diff_file=diff_file,
        )
    except (UserError, OSError) as error:
        state[keys["policy_error"]] = str(error)
        _save_state(state_dir, state)
        return

    state[keys["budget"]] = policy["agentic_timeout_budget_seconds"]
    state[keys["initial_quiet"]] = policy["agentic_initial_quiet_seconds"]
    state[keys["progress_lease"]] = policy["agentic_progress_lease_seconds"]
    _save_state(state_dir, state)


def _maybe_populate_codex_review_timeout_policy(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    repo_root: pathlib.Path | None = None,
) -> None:
    _maybe_populate_stateful_codex_timeout_policy(
        state_dir,
        state,
        entrypoint="codex-review",
        repo_root=repo_root,
    )


def _maybe_populate_codex_readonly_timeout_policy(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    repo_root: pathlib.Path | None = None,
) -> None:
    _maybe_populate_stateful_codex_timeout_policy(
        state_dir,
        state,
        entrypoint="codex-readonly",
        repo_root=repo_root,
    )


def _untracked_repo_paths(repo_root: pathlib.Path) -> list[pathlib.Path]:
    completed = _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "ls-files",
            "--others",
            "--exclude-standard",
            "-z",
        ],
        capture_output=True,
    )
    paths: list[pathlib.Path] = []
    for raw_path in completed.stdout.split(b"\0"):
        if not raw_path:
            continue
        relative_path = pathlib.Path(os.fsdecode(raw_path))
        if relative_path.parts and relative_path.parts[0] == ".codex-tmp":
            continue
        paths.append(relative_path)
    return paths


def _untracked_paths_command(repo_root: pathlib.Path) -> list[str]:
    return [
        _resolve_real_git(),
        "-C",
        str(repo_root),
        "ls-files",
        "--others",
        "--exclude-standard",
        "-z",
    ]


def _iter_nul_records(stream: BinaryIO) -> Iterable[bytes]:
    buffer = bytearray()
    while True:
        chunk = stream.read(8192)
        if not chunk:
            break
        buffer.extend(chunk)
        while True:
            try:
                separator_index = buffer.index(0)
            except ValueError:
                break
            record = bytes(buffer[:separator_index])
            del buffer[: separator_index + 1]
            if record:
                yield record
    if buffer:
        yield bytes(buffer)


def _untracked_repo_budget_metrics(
    repo_root: pathlib.Path,
    *,
    initial_metrics: tuple[int, int, int, int] = (0, 0, 0, 0),
) -> tuple[int, int, int, int]:
    command = _untracked_paths_command(repo_root)
    process = subprocess.Popen(
        command,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    assert process.stdout is not None
    metrics = initial_metrics
    stopped_for_budget = False
    try:
        for raw_path in _iter_nul_records(process.stdout):
            relative_path = pathlib.Path(os.fsdecode(raw_path))
            if relative_path.parts and relative_path.parts[0] == ".codex-tmp":
                continue
            metrics = _combine_budget_metrics(
                metrics,
                _untracked_path_budget_metrics(repo_root, relative_path),
            )
            if _codex_review_builtin_budget_exceeded(metrics):
                stopped_for_budget = True
                process.terminate()
                break
    finally:
        try:
            _stdout, stderr = process.communicate(timeout=5)
        except subprocess.TimeoutExpired:
            process.kill()
            _stdout, stderr = process.communicate()
    if process.returncode != 0 and not stopped_for_budget:
        completed = subprocess.CompletedProcess(
            command,
            process.returncode,
            stdout=b"",
            stderr=stderr,
        )
        raise UserError(_format_command_error(command, completed))
    return metrics


def _repo_dirty_paths(repo_root: pathlib.Path) -> list[pathlib.PurePath]:
    completed = _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "status",
            "--porcelain=v1",
            "-z",
            "--untracked-files=all",
        ],
        capture_output=True,
    )
    paths: list[pathlib.PurePath] = []
    records = completed.stdout.split(b"\0")
    index = 0
    while index < len(records):
        record = records[index]
        index += 1
        if not record:
            continue
        status = record[:2].decode("ascii", errors="replace")
        path_bytes = record[3:] if record[2:3] == b" " else record[2:].lstrip()
        if path_bytes:
            relative_path = pathlib.PurePath(os.fsdecode(path_bytes))
            helper_untracked = (
                status == "??"
                and relative_path.parts
                and relative_path.parts[0] == ".codex-tmp"
            )
            if not helper_untracked:
                paths.append(relative_path)
        if status[:1] in {"R", "C"} or status[1:2] in {"R", "C"}:
            index += 1
    return paths


def _untracked_repo_patch(repo_root: pathlib.Path, relative_path: pathlib.Path) -> bytes:
    file_path = repo_root / relative_path
    path_label = relative_path.as_posix()
    if file_path.is_symlink():
        file_mode = "120000"
        contents = os.readlink(file_path)
        lines = contents.splitlines(keepends=True)
    else:
        data = file_path.read_bytes()
        file_mode = "100755" if os.access(file_path, os.X_OK) else "100644"
        if b"\0" in data:
            return (
                f"diff --git a/{path_label} b/{path_label}\n"
                f"new file mode {file_mode}\n"
                f"Binary file added: {path_label} ({len(data)} bytes)\n"
            ).encode("utf-8", errors="surrogateescape")
        contents = data.decode("utf-8", errors="surrogateescape")
        lines = contents.splitlines(keepends=True)

    patch_lines = difflib.unified_diff(
        [],
        lines,
        fromfile="/dev/null",
        tofile=f"b/{path_label}",
        n=0,
    )
    patch_text = "".join(patch_lines)
    return (
        f"diff --git a/{path_label} b/{path_label}\n"
        f"new file mode {file_mode}\n"
        f"{patch_text}"
    ).encode("utf-8", errors="surrogateescape")


def _uncommitted_diff_section(
    repo_root: pathlib.Path,
    *,
    scope_label: str | None,
) -> bytes:
    status = _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "status",
            "--short",
            "--untracked-files=all",
        ],
        capture_output=True,
    )
    tracked_diff = _run(
        [
            _resolve_real_git(),
            "-C",
            str(repo_root),
            "diff",
            "--no-ext-diff",
            "--no-textconv",
            "--binary",
            "--submodule=diff",
            "HEAD",
        ],
        capture_output=True,
    )
    untracked_diff = bytearray()
    has_untracked_diff = False
    for relative_path in _untracked_repo_paths(repo_root):
        untracked_diff.extend(_untracked_repo_patch(repo_root, relative_path))
        has_untracked_diff = True

    suffix = "" if scope_label is None else f" ({scope_label})"
    sections: list[bytes] = []
    if status.stdout or tracked_diff.stdout or has_untracked_diff:
        repo_section = (
            f"# Working tree status vs HEAD{suffix}\n".encode("utf-8")
            + status.stdout
            + f"\n# Tracked diff vs HEAD{suffix}\n".encode("utf-8")
            + tracked_diff.stdout
        )
        if has_untracked_diff:
            repo_section += (
                f"\n# Untracked content vs /dev/null{suffix}\n".encode("utf-8")
                + bytes(untracked_diff)
            )
        sections.append(repo_section.rstrip(b"\n"))

    for submodule_path in _list_direct_submodules(repo_root):
        submodule_root = repo_root / submodule_path
        if not submodule_root.exists() or not _is_git_worktree_root(submodule_root):
            continue
        nested_scope = (
            submodule_path.as_posix()
            if scope_label is None
            else f"{scope_label}/{submodule_path.as_posix()}"
        )
        nested_section = _uncommitted_diff_section(
            submodule_root,
            scope_label=nested_scope,
        )
        if nested_section:
            sections.append(nested_section.rstrip(b"\n"))

    if not sections:
        return b""
    return b"\n\n".join(sections) + b"\n"


def _write_generated_uncommitted_review_diff(
    *,
    target_root: pathlib.Path,
    output_root: pathlib.Path | None = None,
) -> pathlib.Path:
    diff_root = output_root or target_root
    diff_target = (
        diff_root
        / ".codex-tmp"
        / "isolated-review-inputs"
        / "diff"
        / "working-tree.diff"
    )
    diff_target.parent.mkdir(parents=True, exist_ok=True)
    diff_target.write_bytes(_uncommitted_diff_section(target_root, scope_label=None))
    return diff_target


def _substitute_placeholders(
    value: str,
    placeholders: dict[str, str | None],
) -> str:
    rendered = value
    for placeholder in PLACEHOLDERS:
        if placeholder not in rendered:
            continue
        replacement = placeholders.get(placeholder)
        if replacement is None:
            raise UserError(f"missing value for placeholder {placeholder}")
        rendered = rendered.replace(placeholder, replacement)
    return rendered


def _validate_workspace_relative_path(value: str, *, flag: str) -> pathlib.Path:
    candidate = pathlib.Path(value)
    if candidate.is_absolute():
        raise UserError(f"{flag} must be relative to the isolated workspace: {value}")
    if any(part == ".." for part in candidate.parts):
        raise UserError(f"{flag} must not escape the isolated workspace: {value}")
    return candidate


def _resolve_codex_review_final_path(
    *,
    output_path: str,
    workspace_root: pathlib.Path,
    state_dir: pathlib.Path,
    caller_supplied: bool,
) -> pathlib.Path:
    if caller_supplied:
        relative_output_path = _validate_workspace_relative_path(
            output_path,
            flag="codex-review --output-last-message",
        )
        resolved_output_path = (workspace_root / relative_output_path).resolve(strict=False)
        workspace_root_resolved = workspace_root.resolve(strict=False)
        if _is_relative_to(resolved_output_path, workspace_root_resolved):
            return resolved_output_path
        raise UserError(
            "codex-review --output-last-message must stay inside the isolated workspace after symlink resolution: "
            f"{output_path}"
        )

    resolved_final_path = pathlib.Path(output_path)
    if not resolved_final_path.is_absolute():
        resolved_final_path = workspace_root / resolved_final_path
    resolved_final_path = resolved_final_path.resolve(strict=False)
    if _is_relative_to(resolved_final_path, workspace_root.resolve(strict=False)):
        return resolved_final_path
    if _is_relative_to(resolved_final_path, state_dir.resolve(strict=False)):
        return resolved_final_path
    raise UserError(
        "codex-review final output path must stay inside the isolated workspace or state dir"
    )


def _resolve_codex_review_cwd(
    *,
    cwd_value: str,
    workspace_root: pathlib.Path,
) -> pathlib.Path:
    candidate = pathlib.Path(cwd_value)
    if not candidate.is_absolute():
        candidate = workspace_root / candidate
    resolved_cwd = candidate.resolve(strict=False)
    if _is_relative_to(resolved_cwd, workspace_root.resolve(strict=False)):
        return resolved_cwd
    raise UserError(
        f"codex-review -C/--cd must stay inside the isolated workspace: {cwd_value}"
    )


def _normalize_codex_review_path_options(
    *,
    rendered_args: list[str],
    workspace_root: pathlib.Path,
    final_path: pathlib.Path,
) -> tuple[list[str], pathlib.Path]:
    normalized: list[str] = []
    resolved_final_path: pathlib.Path | None = None
    index = 0
    while index < len(rendered_args):
        arg = rendered_args[index]
        if arg in {"-o", "--output-last-message"}:
            if index + 1 >= len(rendered_args):
                raise UserError(f"missing value for codex-review child arg `{arg}`")
            resolved_final_path = _resolve_codex_review_final_path(
                output_path=rendered_args[index + 1],
                workspace_root=workspace_root,
                state_dir=final_path.parent,
                caller_supplied=True,
            )
            normalized.extend([arg, str(resolved_final_path)])
            index += 2
            continue
        if arg.startswith("-o=") or arg.startswith("--output-last-message="):
            option = "-o" if arg.startswith("-o=") else "--output-last-message"
            resolved_final_path = _resolve_codex_review_final_path(
                output_path=arg.split("=", 1)[1],
                workspace_root=workspace_root,
                state_dir=final_path.parent,
                caller_supplied=True,
            )
            normalized.extend([option, str(resolved_final_path)])
            index += 1
            continue
        if arg in {"-C", "--cd"}:
            if index + 1 >= len(rendered_args):
                raise UserError(f"missing value for codex-review child arg `{arg}`")
            normalized.extend(
                [
                    arg,
                    str(
                        _resolve_codex_review_cwd(
                            cwd_value=rendered_args[index + 1],
                            workspace_root=workspace_root,
                        )
                    ),
                ]
            )
            index += 2
            continue
        if arg.startswith("-C=") or arg.startswith("--cd="):
            option = "-C" if arg.startswith("-C=") else "--cd"
            normalized.extend(
                [
                    option,
                    str(
                        _resolve_codex_review_cwd(
                            cwd_value=arg.split("=", 1)[1],
                            workspace_root=workspace_root,
                        )
                    ),
                ]
            )
            index += 1
            continue
        normalized.append(arg)
        index += 1

    if resolved_final_path is None:
        resolved_final_path = _resolve_codex_review_final_path(
            output_path=str(final_path),
            workspace_root=workspace_root,
            state_dir=final_path.parent,
            caller_supplied=False,
        )
        normalized = ["-o", str(resolved_final_path), *normalized]

    return normalized, resolved_final_path


def _has_option(args: list[str], *options: str) -> bool:
    option_args = args
    if "--" in args:
        option_args = args[: args.index("--")]
    for option in options:
        option_prefix = f"{option}="
        if any(arg == option or arg.startswith(option_prefix) for arg in option_args):
            return True
    return False


def _option_value(args: list[str], *options: str) -> str | None:
    values = _option_values(args, *options)
    return values[0] if values else None


def _option_values(args: list[str], *options: str) -> list[str]:
    option_args = args
    if "--" in args:
        option_args = args[: args.index("--")]

    values: list[str] = []
    index = 0
    while index < len(option_args):
        arg = option_args[index]
        for option in options:
            option_prefix = f"{option}="
            if arg == option:
                if index + 1 < len(option_args):
                    values.append(option_args[index + 1])
                    index += 1
                break
            if arg.startswith(option_prefix):
                values.append(arg[len(option_prefix) :])
                break
        index += 1
    return values


def _is_gpt_model(model: str) -> bool:
    model_id = model.rsplit("/", 1)[-1].lower()
    return model_id.startswith("gpt")


def _external_gpt_model_reason(entrypoint_label: str, model: str) -> str:
    return (
        f"`{entrypoint_label}` must not use GPT model `{model}`; "
        "use a Codex CLI entrypoint for GPT models"
    )


def _ensure_no_external_gpt_model(
    *,
    entrypoint_label: str,
    rendered_args: list[str],
) -> None:
    if entrypoint_label not in EXTERNAL_GPT_MODEL_ENTRYPOINTS:
        return

    for model in _option_values(rendered_args, "-m", "--model"):
        if _is_gpt_model(model):
            raise UserError(_external_gpt_model_reason(entrypoint_label, model))


def _strip_options(args: list[str], *options: str) -> list[str]:
    option_args = args
    passthrough_args: list[str] = []
    if "--" in args:
        boundary = args.index("--")
        option_args = args[:boundary]
        passthrough_args = args[boundary:]

    stripped: list[str] = []
    skip_next = False
    for index, arg in enumerate(option_args):
        if skip_next:
            skip_next = False
            continue

        matched = False
        for option in options:
            option_prefix = f"{option}="
            if arg == option:
                matched = True
                if index + 1 < len(option_args):
                    skip_next = True
                break
            if arg.startswith(option_prefix):
                matched = True
                break
        if not matched:
            stripped.append(arg)

    return [*stripped, *passthrough_args]


def _strip_flags(args: list[str], *flags: str) -> list[str]:
    option_args = args
    passthrough_args: list[str] = []
    if "--" in args:
        boundary = args.index("--")
        option_args = args[:boundary]
        passthrough_args = args[boundary:]

    return [arg for arg in option_args if arg not in flags] + passthrough_args


def _sanitize_auto_fallback_args(
    *,
    mode: str,
    entrypoint_label: str,
    rendered_args: list[str],
) -> list[str]:
    if mode != "auto":
        return rendered_args

    sanitized_args = rendered_args
    if entrypoint_label != "agent":
        sanitized_args = _strip_options(
            sanitized_args,
            *AGENT_ONLY_OPTIONS_WITH_VALUES,
        )
        sanitized_args = _strip_flags(sanitized_args, *AGENT_ONLY_FLAGS)

    if any(
        _is_gpt_model(model)
        for model in _option_values(sanitized_args, "-m", "--model")
    ):
        return _strip_options(sanitized_args, "-m", "--model")

    if entrypoint_label == "opencode":
        return sanitized_args

    if entrypoint_label in {"copilot", "gh-copilot"}:
        return _strip_options(sanitized_args, "-m", "--model")

    model = _option_value(sanitized_args, "-m", "--model")
    if model and "/" in model:
        return _strip_options(sanitized_args, "-m", "--model")
    return sanitized_args


def _render_report_placeholders(
    args: argparse.Namespace,
    *,
    target_root: pathlib.Path,
    placeholders: dict[str, str | None],
) -> None:
    report_target: pathlib.Path | None = None
    default_final_reply: str | None = None
    if args.report_path:
        report_relative = _validate_workspace_relative_path(
            args.report_path,
            flag="--report-path",
        )
        report_target = target_root / report_relative
        report_target.parent.mkdir(parents=True, exist_ok=True)
        placeholders["{report_file}"] = str(report_target)
        default_final_reply = f"WROTE {args.report_path}"
        placeholders["{final_reply}"] = default_final_reply

    if args.final_reply:
        placeholders["{final_reply}"] = _substitute_placeholders(
            args.final_reply,
            placeholders,
        )
        return

    if default_final_reply is not None:
        placeholders["{final_reply}"] = default_final_reply


def _resolve_named_entrypoint(
    label: str,
) -> tuple[list[str], str] | None:
    if label == "codex-review":
        return [_resolve_real_codex()], "codex-review"
    if label == "codex-readonly":
        return [_resolve_real_codex()], "codex-readonly"

    if label == "opencode":
        opencode_path = shutil.which("opencode")
        if not opencode_path:
            return None
        return [opencode_path], "opencode"

    if label == "agent":
        agent_path = shutil.which("agent")
        if not agent_path:
            return None
        return [agent_path], "agent"

    if label == "copilot":
        copilot_path = shutil.which("copilot")
        if not copilot_path:
            return None
        return [copilot_path], "copilot"

    gh_path = shutil.which("gh")
    if not gh_path:
        return None
    if _resolve_gh_copilot_companion() is None:
        return None
    return [gh_path, "copilot"], "gh-copilot"


def _resolve_gh_copilot_companion() -> str | None:
    override = os.environ.get("CODEX_GH_COPILOT_COMPANION_PATH")
    if override:
        candidate = pathlib.Path(override).expanduser().resolve()
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
        return None

    for candidate in PREFERRED_GH_COPILOT_COMPANION_PATHS:
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None


def _resolve_opencode_model(args: list[str]) -> str:
    return _option_value(args, "-m", "--model") or OPENCODE_MODEL_DEFAULT


def _resolve_agent_model(args: list[str]) -> str:
    return _option_value(args, "-m", "--model") or AGENT_MODEL_DEFAULT


def _opencode_model_catalog(
    opencode_path: str,
    *,
    provider: str | None = None,
) -> tuple[set[str] | None, str | None]:
    commands: list[list[str]] = []
    if provider:
        commands.append([opencode_path, "models", provider])
    commands.append([opencode_path, "models"])

    failures: list[str] = []
    seen_commands: set[tuple[str, ...]] = set()
    for cmd in commands:
        key = tuple(cmd)
        if key in seen_commands:
            continue
        seen_commands.add(key)
        try:
            completed = subprocess.run(
                cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
                timeout=10,
            )
        except (OSError, subprocess.TimeoutExpired) as error:
            failures.append(f"{' '.join(cmd)}: {error}")
            continue

        stdout = completed.stdout.decode("utf-8", errors="replace")
        stderr = completed.stderr.decode("utf-8", errors="replace").strip()
        if completed.returncode != 0:
            failures.append(f"{' '.join(cmd)}: {stderr or 'unknown error'}")
            continue

        models: set[str] = set()
        for line in stdout.splitlines():
            stripped = line.strip()
            if not stripped:
                continue
            if provider and cmd[1:] == ["models", provider] and "/" not in stripped:
                models.add(f"{provider}/{stripped}")
            else:
                models.add(stripped)

        if models:
            return models, None

    return None, "; ".join(failures) or "`opencode models` returned no models"


def _resolve_opencode_default_model(
    *,
    models: set[str] | None = None,
    opencode_path: str | None = None,
) -> str | None:
    if models is None:
        if opencode_path is None:
            return None
        models, _ = _opencode_model_catalog(opencode_path, provider="github-copilot")
        if models is None:
            return None

    for candidate in (OPENCODE_MODEL_DEFAULT, *OPENCODE_MODEL_COMPAT_DEFAULTS):
        if candidate in models:
            return candidate
    return None


def _agent_catalog_failure_is_inconclusive(reason: str) -> bool:
    return any(
        fragment in reason
        for fragment in AGENT_MODEL_INCONCLUSIVE_FAILURE_FRAGMENTS
    )


def _agent_model_catalog(agent_path: str) -> tuple[set[str] | None, str | None, bool]:
    try:
        completed = subprocess.run(
            [agent_path, "models"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=10,
        )
    except (OSError, subprocess.TimeoutExpired) as error:
        return None, str(error), False

    stdout = completed.stdout.decode("utf-8", errors="replace")
    stderr = completed.stderr.decode("utf-8", errors="replace").strip()
    if completed.returncode != 0:
        reason = stderr or "unknown error"
        return None, reason, _agent_catalog_failure_is_inconclusive(reason)

    models: set[str] = set()
    for line in stdout.splitlines():
        stripped = line.strip()
        if not stripped:
            continue
        if stripped == "Available models" or stripped.startswith("Tip:"):
            continue
        model_id = stripped.split(" - ", 1)[0].strip()
        if model_id:
            models.add(model_id)

    return models, None, False


def _resolve_agent_default_model(
    *,
    models: set[str] | None = None,
    agent_path: str | None = None,
) -> str | None:
    if models is None:
        if agent_path is None:
            return None
        models, _, _ = _agent_model_catalog(agent_path)
        if models is None:
            return None

    for candidate in (AGENT_MODEL_DEFAULT, *AGENT_MODEL_COMPAT_DEFAULTS):
        if candidate in models:
            return candidate
    return None


def _opencode_preflight(opencode_path: str, model: str) -> tuple[bool, str | None]:
    provider = None
    if "/" in model:
        provider = model.split("/", 1)[0]

    commands: list[list[str]] = []
    if provider:
        commands.append([opencode_path, "models", provider])
    commands.append([opencode_path, "models"])

    failures: list[str] = []
    seen_commands: set[tuple[str, ...]] = set()
    want_suffix = None if "/" in model else f"/{model}"

    for cmd in commands:
        key = tuple(cmd)
        if key in seen_commands:
            continue
        seen_commands.add(key)
        try:
            completed = subprocess.run(
                cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
                timeout=10,
            )
        except (OSError, subprocess.TimeoutExpired) as error:
            failures.append(f"{' '.join(cmd)}: {error}")
            continue

        stdout = completed.stdout.decode("utf-8", errors="replace")
        stderr = completed.stderr.decode("utf-8", errors="replace").strip()
        if completed.returncode != 0:
            failures.append(f"{' '.join(cmd)}: {stderr or 'unknown error'}")
            continue

        models = [line.strip() for line in stdout.splitlines() if line.strip()]
        if any(line == model or (want_suffix and line.endswith(want_suffix)) for line in models):
            return True, None

        failures.append(f"{' '.join(cmd)} did not list `{model}`")

    return False, "; ".join(failures) or f"`{model}` not found"


def _opencode_preflight_for_args(
    *,
    opencode_path: str,
    rendered_args: list[str],
    placeholders: dict[str, str | None],
) -> tuple[bool, str | None, str | None]:
    for explicit_model in _option_values(rendered_args, "-m", "--model"):
        if not _is_gpt_model(explicit_model):
            continue
        return (
            False,
            _external_gpt_model_reason("opencode", explicit_model),
            None,
        )

    opencode_default_model: str | None = None
    if not _has_option(rendered_args, "-m", "--model"):
        models, reason = _opencode_model_catalog(
            opencode_path,
            provider="github-copilot",
        )
        if models is None:
            return False, reason, None
        opencode_default_model = _resolve_opencode_default_model(models=models)
        if opencode_default_model is None:
            return (
                False,
                "`opencode models` did not list any supported helper default model",
                None,
            )

    effective_args = _apply_opencode_defaults(
        rendered_args=rendered_args,
        placeholders=placeholders,
        opencode_default_model=opencode_default_model,
    )
    model = _resolve_opencode_model(effective_args)
    usable, reason = _opencode_preflight(opencode_path, model)
    return usable, reason, opencode_default_model


def _agent_preflight_for_args(
    *,
    agent_path: str,
    rendered_args: list[str],
) -> tuple[bool | None, str | None, str | None]:
    for explicit_model in _option_values(rendered_args, "-m", "--model"):
        if not _is_gpt_model(explicit_model):
            continue
        return (
            False,
            _external_gpt_model_reason("agent", explicit_model),
            None,
        )

    models, reason, inconclusive = _agent_model_catalog(agent_path)
    if models is None:
        return (None if inconclusive else False), reason, None

    default_model = _resolve_agent_default_model(models=models)
    effective_args = _apply_agent_defaults(
        "agent",
        rendered_args,
        agent_default_model=default_model,
    )
    model = _resolve_agent_model(effective_args)
    if model in models:
        return True, None, default_model
    if default_model is None and not _has_option(rendered_args, "-m", "--model"):
        return False, "`agent models` did not list any supported helper default model", None
    return False, f"`agent models` did not list `{model}`", default_model


def _prepare_inputs(
    args: argparse.Namespace,
    *,
    source_root: pathlib.Path,
    target_root: pathlib.Path,
    base_ref: str | None,
    head_ref: str | None,
) -> dict[str, str | None]:
    generated_input_root = target_root
    if args.entrypoint == "codex-readonly" and args.state_dir:
        generated_input_root = pathlib.Path(args.state_dir).resolve()
    placeholders: dict[str, str | None] = {
        "{workspace}": str(target_root),
        "{repo}": str(target_root),
        "{source_repo}": str(source_root),
        "{prompt_file}": None,
        "{diff_file}": None,
        "{prompt_text}": None,
        "{report_file}": None,
        "{final_reply}": None,
        "{base_ref}": base_ref,
        "{head_ref}": head_ref,
        "{review_range}": (
            f"{base_ref}..{head_ref}" if base_ref is not None and head_ref is not None else None
        ),
    }

    if args.diff_file:
        diff_source = pathlib.Path(args.diff_file).resolve()
        if not diff_source.is_file():
            raise UserError(f"diff file not found: {diff_source}")
        diff_target = _copy_input_path(
            diff_source,
            source_root=source_root,
            target_root=target_root,
            bucket="diff",
        )
        placeholders["{diff_file}"] = str(diff_target)
    elif base_ref is not None and head_ref is not None:
        diff_target = _write_generated_review_diff(
            target_root=target_root,
            base_ref=base_ref,
            head_ref=head_ref,
            output_root=generated_input_root,
        )
        placeholders["{diff_file}"] = str(diff_target)
    elif args.entrypoint == "codex-readonly":
        diff_target = _write_generated_uncommitted_review_diff(
            target_root=target_root,
            output_root=generated_input_root,
        )
        placeholders["{diff_file}"] = str(diff_target)

    _render_report_placeholders(
        args,
        target_root=target_root,
        placeholders=placeholders,
    )

    if args.prompt_file:
        prompt_source = pathlib.Path(args.prompt_file).resolve()
        if not prompt_source.is_file():
            raise UserError(f"prompt file not found: {prompt_source}")
        prompt_text = prompt_source.read_text(encoding="utf-8")
        rendered_prompt = _substitute_placeholders(prompt_text, placeholders)
        if _is_relative_to(prompt_source, source_root):
            prompt_target = target_root / prompt_source.relative_to(source_root)
        else:
            prompt_target = (
                target_root
                / ".codex-tmp"
                / "isolated-review-inputs"
                / "prompt"
                / prompt_source.name
            )
        prompt_target.parent.mkdir(parents=True, exist_ok=True)
        prompt_target.write_text(rendered_prompt, encoding="utf-8")
        placeholders["{prompt_file}"] = str(prompt_target)
        placeholders["{prompt_text}"] = rendered_prompt

    for extra_path in args.copy_path:
        source_path = pathlib.Path(extra_path).resolve()
        if not source_path.exists() and not source_path.is_symlink():
            raise UserError(f"copy path not found: {source_path}")
        _copy_input_path(
            source_path,
            source_root=source_root,
            target_root=target_root,
            bucket="extra",
        )

    return placeholders


def _resolve_entrypoint(
    mode: str,
    lane: str,
    *,
    rendered_args: list[str],
    placeholders: dict[str, str | None],
    excluded_entrypoints: set[str] | None = None,
) -> tuple[list[str], str, str | None]:
    excluded = excluded_entrypoints or set()
    if mode == "auto":
        for candidate in LANE_AUTO_PRIORITIES[lane]:
            if candidate in excluded:
                continue
            resolved = _resolve_named_entrypoint(candidate)
            if resolved is not None:
                candidate_default_model: str | None = None
                candidate_args = _sanitize_auto_fallback_args(
                    mode=mode,
                    entrypoint_label=resolved[1],
                    rendered_args=rendered_args,
                )
                if resolved[1] == "opencode":
                    usable, _, candidate_default_model = _opencode_preflight_for_args(
                        opencode_path=resolved[0][0],
                        rendered_args=candidate_args,
                        placeholders=placeholders,
                    )
                    if usable is False:
                        continue
                elif resolved[1] == "agent":
                    usable, _, candidate_default_model = _agent_preflight_for_args(
                        agent_path=resolved[0][0],
                        rendered_args=candidate_args,
                    )
                    if usable is False:
                        continue
                return resolved[0], resolved[1], candidate_default_model
        raise UserError(
            "none of the configured review entrypoints "
            f"{LANE_AUTO_PRIORITIES[lane]} is available in PATH"
        )

    resolved = _resolve_named_entrypoint(mode)
    if resolved is None:
        raise UserError(f"`{mode}` is not available in PATH")
    if resolved[1] == "opencode":
        usable, reason, default_model = _opencode_preflight_for_args(
            opencode_path=resolved[0][0],
            rendered_args=rendered_args,
            placeholders=placeholders,
        )
        if usable is False:
            raise UserError(f"`opencode` failed usability preflight: {reason}")
        return resolved[0], resolved[1], default_model
    elif resolved[1] == "agent":
        usable, reason, default_model = _agent_preflight_for_args(
            agent_path=resolved[0][0],
            rendered_args=rendered_args,
        )
        if usable is False:
            raise UserError(f"`agent` failed usability preflight: {reason}")
        return resolved[0], resolved[1], default_model
    return resolved[0], resolved[1], None


def _render_command_args(
    raw_args: list[str],
    placeholders: dict[str, str | None],
) -> list[str]:
    if raw_args and raw_args[0] == "--":
        raw_args = raw_args[1:]
    return [_substitute_placeholders(arg, placeholders) for arg in raw_args]


def _build_prompt_bootstrap(placeholders: dict[str, str | None]) -> str:
    prompt_file = placeholders["{prompt_file}"]
    if prompt_file is None:
        raise UserError("bootstrap prompt delivery requires {prompt_file}")

    lines = [
        f"Read the review instructions in {prompt_file} first.",
        "Follow them exactly.",
    ]
    if placeholders["{diff_file}"] is not None:
        lines.append(f"Use {placeholders['{diff_file}']} as the primary review surface.")
    if placeholders["{report_file}"] is not None:
        lines.append(f"Write the report to {placeholders['{report_file}']}.")
    if placeholders["{final_reply}"] is not None:
        lines.append(f"End with the exact final reply: {placeholders['{final_reply}']}")
    return "\n".join(lines)


def _review_evidence_budget_lines(
    *,
    prefix: str,
    start_line: str,
    narrow_after_large_result_to: str | None,
) -> list[str]:
    large_result_target = (
        f" to {narrow_after_large_result_to}"
        if narrow_after_large_result_to is not None
        else ""
    )
    return [
        start_line,
        f"{prefix}Budget first-stage summaries too: before printing changed-file lists, git diff --stat/--numstat, helper diff-file headers, or diff-header samples such as rg -m 80 '^diff --git ' <diff> for a large/generated diff, run count-only probes first, then cap any sample with head -n 80. If the count is high, choose one directory, file, hunk, or exact symbol window instead of dumping the full summary.",
        f"{prefix}Treat line-producing rg -n, including rg -n -C context searches, as a second-stage read: after rg -l / rg --count, run it only against one exact file, one hunk, or one exact symbol window, not across several directories/files or broad alternations.",
        f"{prefix}Do not default to wide selected-file diffs such as git diff --unified=30/40/50/60/80 or git diff --function-context / git diff -W, whole-file nl -ba, path-wide / multi-file / large-alternation raw rg -n searches, or full untracked inventories such as git status --short --untracked-files=all / git ls-files --others.",
        f"{prefix}Do not run bare whole-file reads such as cat <file>, nl -ba <file>, sed -n '1,$p' <file>, or git show <rev>:<path>. When you need file context, combine git show or nl -ba with a narrow sed -n '<start>,<end>p' window, use rg -n for one exact symbol, or inspect the relevant hunk from the supplied diff.",
        f"{prefix}Before every tool call, self-check the command against this budget. Rewrite bare nl -ba <file>, cat <file>, git show <rev>:<path>, path-wide or multi-file rg -n, and wide selected-file diffs into count probes, exact symbol lookups, single-hunk reads, or narrow sed -n '<start>,<end>p' windows before executing.",
        f"{prefix}If untracked files are in scope, start with git status --short --untracked-files=no, then use counts or capped path samples with recursive generated/dependency excludes before inspecting selected paths.",
        f"{prefix}After any 800+ line or 10k+ original-token result, narrow the next read{large_result_target} instead of widening it.",
    ]


def _review_validation_output_budget_line(*, prefix: str) -> str:
    return (
        f"{prefix}Validation-output budget: In read-only or approval-gated lanes, "
        "do not start full tests/builds with huge visible output caps such as "
        "`max_output_tokens=60000` or `max_output_tokens=100000`; use a small "
        "syntax/targeted probe or a low visible cap first. If sandbox tempdir, "
        "pyenv shim, or repeated `unittest` `E` output appears, summarize that "
        "failure shape before rerunning with escalation or a task-scoped log file."
    )


def _build_default_external_review_prompt(
    placeholders: dict[str, str | None],
) -> str | None:
    diff_file = placeholders["{diff_file}"]
    if diff_file is None:
        return None

    lines = [
        "Review the provided diff for correctness, security, data-loss, and regression risks.",
        f"Primary diff: {diff_file}",
    ]
    lines.extend(
        _review_evidence_budget_lines(
            prefix="",
            start_line="Evidence budget: start with the supplied diff, changed-file list, --stat/--numstat, rg -l, rg --count, or exact symbol windows.",
            narrow_after_large_result_to=None,
        )
    )
    lines.append(_review_validation_output_budget_line(prefix=""))
    if placeholders["{review_range}"] is not None:
        lines.append(f"Review range: {placeholders['{review_range}']}")
    lines.extend(
        [
            "Return findings only, ordered by severity.",
            "Use file/line references when possible.",
            "If there are no findings, reply exactly: No findings.",
        ]
    )
    if placeholders["{report_file}"] is not None:
        lines.append(f"Write the same findings to {placeholders['{report_file}']}.")
    if placeholders["{final_reply}"] is not None:
        lines.append(f"End with the exact final reply: {placeholders['{final_reply}']}")
    return "\n".join(lines) + "\n"


def _maybe_apply_default_external_prompt(
    *,
    entrypoint_label: str,
    rendered_args: list[str],
    placeholders: dict[str, str | None],
) -> list[str]:
    if entrypoint_label not in DEFAULT_PROMPT_ENTRYPOINTS:
        return rendered_args
    if rendered_args or placeholders["{prompt_text}"] is not None:
        return rendered_args

    prompt_text = _build_default_external_review_prompt(placeholders)
    if prompt_text is None:
        return rendered_args

    placeholders["{prompt_text}"] = prompt_text
    return [prompt_text]


def _replace_prompt_arg(
    *,
    rendered_args: list[str],
    current_prompt: str,
    replacement_prompt: str,
) -> tuple[list[str], bool]:
    result: list[str] = []
    replaced = False
    for arg in rendered_args:
        if arg == current_prompt:
            result.append(replacement_prompt)
            replaced = True
            continue
        if arg.startswith("--prompt=") and arg[len("--prompt=") :] == current_prompt:
            result.append(f"--prompt={replacement_prompt}")
            replaced = True
            continue
        result.append(arg)
    return result, replaced


def _apply_prompt_delivery(
    *,
    requested_mode: str,
    entrypoint_label: str,
    rendered_args: list[str],
    placeholders: dict[str, str | None],
    inline_max_bytes: int,
) -> tuple[list[str], str]:
    prompt_text = placeholders["{prompt_text}"]
    prompt_file = placeholders["{prompt_file}"]
    if prompt_text is None:
        return rendered_args, "none"

    if requested_mode == "inline":
        return rendered_args, "inline"

    if prompt_file is None:
        if requested_mode == "bootstrap":
            raise UserError("--prompt-delivery=bootstrap requires --prompt-file")
        return rendered_args, "inline"

    if entrypoint_label not in PROMPT_FILE_ENTRYPOINTS:
        if requested_mode == "bootstrap":
            raise UserError(
                "--prompt-delivery=bootstrap is only supported for agentic entrypoints "
                "(`agent` and `opencode`)"
            )
        return rendered_args, "inline"

    wants_bootstrap = requested_mode == "bootstrap"
    if requested_mode == "auto":
        wants_bootstrap = len(prompt_text.encode("utf-8")) > inline_max_bytes
    if not wants_bootstrap:
        return rendered_args, "inline"

    bootstrap_prompt = _build_prompt_bootstrap(placeholders)
    replaced_args, replaced = _replace_prompt_arg(
        rendered_args=rendered_args,
        current_prompt=prompt_text,
        replacement_prompt=bootstrap_prompt,
    )
    if requested_mode == "bootstrap" and not replaced:
        raise UserError(
            "--prompt-delivery=bootstrap requires a review arg that resolves to {prompt_text}"
        )
    if not replaced:
        return rendered_args, "inline"
    return replaced_args, "bootstrap"


def _apply_agent_defaults(
    entrypoint_label: str,
    rendered_args: list[str],
    *,
    agent_default_model: str | None = None,
    agent_path: str | None = None,
) -> list[str]:
    if entrypoint_label != "agent":
        return rendered_args

    default_args: list[str] = []
    if not _has_option(rendered_args, "--mode"):
        default_args.extend(["--mode", "ask"])
    if not _has_option(rendered_args, "-m", "--model"):
        default_model = agent_default_model
        if default_model is None and agent_path is not None:
            default_model = _resolve_agent_default_model(agent_path=agent_path)
        if default_model is not None:
            default_args.extend(["--model", default_model])
    if "--print" not in rendered_args:
        default_args.append("--print")
    if "--trust" not in rendered_args:
        default_args.append("--trust")
    return [*default_args, *rendered_args]


@lru_cache(maxsize=1)
def _resolve_trusted_true_path() -> str:
    for entry in TRUSTED_CHILD_PATH_ENTRIES:
        candidate = pathlib.Path(entry) / "true"
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
    raise UserError("`true` is not available in a trusted executable path")


def _probe_codex_linux_sandbox(
    *,
    codex_path: str,
    extra_args: tuple[str, ...] = (),
) -> subprocess.CompletedProcess[bytes]:
    command = [
        codex_path,
        "sandbox",
        "linux",
        *extra_args,
        _resolve_trusted_true_path(),
    ]
    probe_env = dict(os.environ)
    probe_env["PATH"] = _trusted_child_path(codex_path=codex_path)
    try:
        return subprocess.run(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=CODEX_REVIEW_LINUX_SANDBOX_PROBE_TIMEOUT_SECONDS,
            env=probe_env,
        )
    except subprocess.TimeoutExpired as error:
        probe_args_fragment = (
            f" with extra args `{' '.join(extra_args)}`" if extra_args else ""
        )
        raise UserError(
            "timed out after "
            f"{CODEX_REVIEW_LINUX_SANDBOX_PROBE_TIMEOUT_SECONDS}s while probing "
            f"Linux Codex sandbox with `{codex_path}`{probe_args_fragment}"
        ) from error
    except OSError as error:
        probe_args_fragment = (
            f" with extra args `{' '.join(extra_args)}`" if extra_args else ""
        )
        raise UserError(
            "failed to probe Linux Codex sandbox with "
            f"`{codex_path}`{probe_args_fragment}: {error}"
        ) from error


def _probe_stderr_text(completed: subprocess.CompletedProcess[bytes]) -> str:
    return completed.stderr.decode("utf-8", errors="replace").strip()


@lru_cache(maxsize=None)
def _resolve_codex_linux_sandbox_flags(
    *,
    codex_path: str,
    lane_label: str,
) -> tuple[str, ...]:
    if not sys.platform.startswith("linux"):
        return ()

    default_probe = _probe_codex_linux_sandbox(codex_path=codex_path)
    if default_probe.returncode == 0:
        return ()

    default_stderr = _probe_stderr_text(default_probe)
    if CODEX_REVIEW_LINUX_LOOPBACK_FAILURE_FRAGMENT not in default_stderr:
        return ()

    legacy_probe = _probe_codex_linux_sandbox(
        codex_path=codex_path,
        extra_args=CODEX_REVIEW_LINUX_LEGACY_LANDLOCK_FLAGS,
    )
    if legacy_probe.returncode == 0:
        return CODEX_REVIEW_LINUX_LEGACY_LANDLOCK_FLAGS

    legacy_stderr = _probe_stderr_text(legacy_probe)
    raise UserError(
        f"{lane_label} Linux sandbox probe hit the known bubblewrap loopback failure, "
        "and the helper-managed legacy landlock retry also failed.\n"
        f"default probe stderr: {default_stderr or '<empty>'}\n"
        f"legacy landlock probe stderr: {legacy_stderr or '<empty>'}"
    )


@lru_cache(maxsize=None)
def _resolve_codex_review_linux_sandbox_flags(codex_path: str) -> tuple[str, ...]:
    return _resolve_codex_linux_sandbox_flags(
        codex_path=codex_path,
        lane_label="codex-review",
    )


def _apply_codex_review_defaults(
    *,
    codex_path: str,
    rendered_args: list[str],
    workspace_root: pathlib.Path,
    final_path: pathlib.Path,
    runtime_temp_dir: pathlib.Path,
    base_ref: str | None,
    prompt_text: str | None,
    model: str,
    reasoning_effort: str,
) -> tuple[list[str], str, bytes | None, pathlib.Path]:
    result = list(rendered_args)
    stdin_bytes: bytes | None = None
    prompt_delivery = "none"
    runtime_temp_dir.mkdir(parents=True, exist_ok=True)

    result, resolved_final_path = _normalize_codex_review_path_options(
        rendered_args=result,
        workspace_root=workspace_root,
        final_path=final_path,
    )
    exec_args, review_args, has_prompt_arg = _split_codex_review_child_args(result)
    exec_args = [
        "-c",
        f'model_reasoning_effort="{reasoning_effort}"',
        *exec_args,
    ]
    if not _has_option(review_args, "-m", "--model"):
        review_args = ["-m", model, *review_args]
    if "--json" not in review_args:
        review_args = ["--json", *review_args]
    if base_ref is not None:
        if has_prompt_arg:
            raise UserError(
                "codex-review cannot combine an explicit prompt with helper-managed `--base`; use codex-readonly when a helper-managed prompt contract is required"
            )
        review_args = ["--base", base_ref, *review_args]
        prompt_delivery = "builtin-review"
    else:
        if has_prompt_arg:
            raise UserError(
                "codex-review cannot combine an explicit prompt with `--uncommitted`; use codex-readonly when a helper-managed prompt contract is required"
            )
        review_args = ["--uncommitted", *review_args]
        if prompt_text is not None:
            raise UserError(
                "codex-review cannot honor helper-managed prompt contracts with `--uncommitted`; use codex-readonly when a helper-managed prompt contract is required"
            )
        prompt_delivery = "builtin-review"

    linux_sandbox_flags = _resolve_codex_review_linux_sandbox_flags(codex_path)
    return (
        [
            *linux_sandbox_flags,
            "-s",
            "read-only",
            "--add-dir",
            str(runtime_temp_dir),
            "exec",
            *exec_args,
            "review",
            *review_args,
        ],
        prompt_delivery,
        stdin_bytes,
        resolved_final_path,
    )


def _build_codex_readonly_prompt(
    *,
    placeholders: dict[str, str | None],
) -> str:
    lines = [
        "Persistent internal Codex readonly review contract:",
        f"- Workspace: {placeholders['{workspace}']}",
        f"- Source repo: {placeholders['{source_repo}']}",
    ]
    if placeholders["{diff_file}"] is not None:
        lines.append(f"- Primary diff file: {placeholders['{diff_file}']}")
    if placeholders["{review_range}"] is not None:
        lines.append(f"- Frozen review range: {placeholders['{review_range}']}")
    else:
        lines.append("- Review scope: working tree snapshot relative to HEAD.")

    lines.extend(
        [
            "",
            "Review discipline:",
            "- Use the supplied diff file as the primary review surface and read additional repo files only when needed to verify a concern.",
            *_review_evidence_budget_lines(
                prefix="- ",
                start_line="- Start with changed-file lists, --stat/--numstat, helper diff-file headers, rg -l, rg --count, or exact symbol windows before reading large hunks.",
                narrow_after_large_result_to="one file, one hunk, or one exact symbol window",
            ),
            "- Focus on correctness, regressions, performance or resource risks, and missing tests.",
            "- Skip style-only, naming-only, formatting-only, and documentation-only comments.",
            "- Do not run tests, builds, linters, benchmarks, package-manager commands, or repo-wide validation commands.",
            "- If a command is blocked by the readonly git shim or sandbox, treat that as lane context rather than a finding.",
            "",
            "Output contract:",
            "- Return findings only.",
            "- If there are no credible findings, reply with exactly `LGTM`.",
        ]
    )
    return "\n".join(lines) + "\n"


def _apply_codex_readonly_defaults(
    *,
    codex_path: str,
    rendered_args: list[str],
    workspace_root: pathlib.Path,
    runtime_temp_dir: pathlib.Path,
    final_path: pathlib.Path,
    placeholders: dict[str, str | None],
    model: str,
    reasoning_effort: str,
) -> tuple[list[str], str, bytes, pathlib.Path]:
    if rendered_args:
        raise UserError(
            "codex-readonly is fully helper-managed; remove custom child args and let the helper build the readonly prompt and command shape"
        )
    runtime_temp_dir.mkdir(parents=True, exist_ok=True)
    prompt_text = _build_codex_readonly_prompt(placeholders=placeholders)
    linux_sandbox_flags = _resolve_codex_linux_sandbox_flags(
        codex_path=codex_path,
        lane_label="codex-readonly",
    )
    workspace_root_resolved = workspace_root.resolve(strict=False)
    add_dirs: list[pathlib.Path] = []

    def register_add_dir(candidate_dir: pathlib.Path) -> None:
        resolved_candidate_dir = candidate_dir.resolve(strict=False)
        if any(existing == resolved_candidate_dir for existing in add_dirs):
            return
        add_dirs.append(resolved_candidate_dir)

    register_add_dir(runtime_temp_dir)
    register_add_dir(final_path.parent)
    for helper_path in (
        placeholders.get("{diff_file}"),
        placeholders.get("{prompt_file}"),
    ):
        if not helper_path:
            continue
        helper_parent = pathlib.Path(helper_path).resolve(strict=False).parent
        if _is_relative_to(helper_parent, workspace_root_resolved):
            continue
        register_add_dir(helper_parent)

    add_dir_args: list[str] = []
    for add_dir in add_dirs:
        add_dir_args.extend(["--add-dir", str(add_dir)])
    return (
        [
            *linux_sandbox_flags,
            "-s",
            "read-only",
            *add_dir_args,
            "exec",
            "-m",
            model,
            "-c",
            f'model_reasoning_effort="{reasoning_effort}"',
            "-o",
            str(final_path),
            "-",
        ],
        "stdin",
        prompt_text.encode("utf-8"),
        final_path,
    )


def _reject_frozen_codex_review_prompt_contracts(args: argparse.Namespace) -> None:
    rejected_flags: list[str] = []
    if args.prompt_file:
        rejected_flags.append("--prompt-file")
    if args.diff_file:
        rejected_flags.append("--diff-file")
    if args.copy_path:
        rejected_flags.append("--copy-path")
    if args.final_reply:
        rejected_flags.append("--final-reply")
    if args.prompt_delivery != "auto":
        rejected_flags.append("--prompt-delivery")
    if args.prompt_inline_max_bytes != PROMPT_INLINE_MAX_BYTES_DEFAULT:
        rejected_flags.append("--prompt-inline-max-bytes")
    if not rejected_flags:
        return
    raise UserError(
        "frozen codex-review cannot honor helper-managed prompt contracts with "
        "`--base-ref/--head-ref`; remove: " + ", ".join(rejected_flags)
    )


def _reject_uncommitted_codex_review_prompt_contracts(args: argparse.Namespace) -> None:
    rejected_flags: list[str] = []
    if args.prompt_file:
        rejected_flags.append("--prompt-file")
    if args.diff_file:
        rejected_flags.append("--diff-file")
    if args.copy_path:
        rejected_flags.append("--copy-path")
    if args.final_reply:
        rejected_flags.append("--final-reply")
    if args.prompt_delivery != "auto":
        rejected_flags.append("--prompt-delivery")
    if args.prompt_inline_max_bytes != PROMPT_INLINE_MAX_BYTES_DEFAULT:
        rejected_flags.append("--prompt-inline-max-bytes")
    if not rejected_flags:
        return
    raise UserError(
        "uncommitted codex-review cannot honor helper-managed prompt contracts; "
        "remove: " + ", ".join(rejected_flags)
    )


def _reject_codex_review_report_path(args: argparse.Namespace) -> None:
    if not args.report_path:
        return
    raise UserError(
        "codex-review cannot honor helper-managed `--report-path`; "
        "this lane only persists the helper-managed final assistant message"
    )


def _reject_oversized_codex_review_builtin_scope(
    *,
    source_root: pathlib.Path,
    base_ref: str | None,
    head_ref: str | None,
    diff_file: pathlib.Path | None,
) -> None:
    if diff_file is not None and diff_file.is_file():
        (
            changed_files,
            changed_lines,
            diff_bytes,
            max_changed_line_bytes,
        ) = _review_diff_file_budget_metrics(diff_file)
    else:
        (
            changed_files,
            changed_lines,
            diff_bytes,
            max_changed_line_bytes,
        ) = _review_scope_change_budget_metrics(
            source_root,
            base_ref=base_ref,
            head_ref=head_ref,
        )
    if (
        changed_files < CODEX_REVIEW_BUILTIN_MAX_CHANGED_FILES
        and changed_lines < CODEX_REVIEW_BUILTIN_MAX_CHANGED_LINES
        and diff_bytes < CODEX_REVIEW_BUILTIN_MAX_DIFF_BYTES
        and max_changed_line_bytes < CODEX_REVIEW_BUILTIN_MAX_CHANGED_LINE_BYTES
    ):
        return
    raise UserError(
        "codex-review builtin prompt cannot honor the helper-managed evidence budget "
        f"for this scope ({changed_files} changed files, {changed_lines} changed lines, "
        f"{diff_bytes} diff bytes, {max_changed_line_bytes} max changed-line bytes). "
        "Use `--entrypoint codex-readonly`, which receives the generated diff file and "
        "bounded-read prompt contract."
    )


def _reject_codex_readonly_customizations(args: argparse.Namespace) -> None:
    rejected_flags: list[str] = []
    if args.prompt_file:
        rejected_flags.append("--prompt-file")
    if args.diff_file:
        rejected_flags.append("--diff-file")
    if args.copy_path:
        rejected_flags.append("--copy-path")
    if args.report_path:
        rejected_flags.append("--report-path")
    if args.final_reply:
        rejected_flags.append("--final-reply")
    if args.prompt_delivery != "auto":
        rejected_flags.append("--prompt-delivery")
    if args.prompt_inline_max_bytes != PROMPT_INLINE_MAX_BYTES_DEFAULT:
        rejected_flags.append("--prompt-inline-max-bytes")
    if args.review_args:
        rejected_flags.append("review args after `--`")
    if not rejected_flags:
        return
    raise UserError(
        "codex-readonly is fully helper-managed; remove: "
        + ", ".join(rejected_flags)
    )


def _reject_codex_parallel_customizations(args: argparse.Namespace) -> None:
    rejected_flags: list[str] = []
    if args.reuse_workspace:
        rejected_flags.append("--reuse-workspace")
    if args.prompt_file:
        rejected_flags.append("--prompt-file")
    if args.diff_file:
        rejected_flags.append("--diff-file")
    if args.copy_path:
        rejected_flags.append("--copy-path")
    if args.report_path:
        rejected_flags.append("--report-path")
    if args.final_reply:
        rejected_flags.append("--final-reply")
    if args.prompt_delivery != "auto":
        rejected_flags.append("--prompt-delivery")
    if args.prompt_inline_max_bytes != PROMPT_INLINE_MAX_BYTES_DEFAULT:
        rejected_flags.append("--prompt-inline-max-bytes")
    if args.review_args:
        rejected_flags.append("review args after `--`")
    if not rejected_flags:
        return
    raise UserError(
        "codex-parallel is fully helper-managed; remove: "
        + ", ".join(rejected_flags)
    )


def _reject_codex_review_explicit_prompt(
    args: argparse.Namespace,
    *,
    frozen_range: bool,
) -> None:
    raw_review_args = list(args.review_args)
    if raw_review_args and raw_review_args[0] == "--":
        raw_review_args = raw_review_args[1:]
    _, _, has_prompt_arg = _split_codex_review_child_args(raw_review_args)
    if not has_prompt_arg:
        return
    if frozen_range:
        raise UserError(
            "codex-review cannot combine an explicit prompt with helper-managed `--base`; use codex-readonly when a helper-managed prompt contract is required"
        )
    raise UserError(
        "codex-review cannot combine an explicit prompt with `--uncommitted`; use codex-readonly when a helper-managed prompt contract is required"
    )


def _reject_codex_review_output_override(args: argparse.Namespace) -> None:
    raw_review_args = list(args.review_args)
    if raw_review_args and raw_review_args[0] == "--":
        raw_review_args = raw_review_args[1:]
    if not _has_option(raw_review_args, "-o", "--output-last-message"):
        return
    raise UserError(
        "codex-review does not allow caller-supplied `-o/--output-last-message`; "
        "the helper owns the final output path so cleanup cannot mutate the review scope"
    )


def _split_codex_review_child_args(
    args: list[str],
) -> tuple[list[str], list[str], bool]:
    exec_args: list[str] = []
    review_args: list[str] = []
    has_prompt = False
    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--":
            raise UserError("codex-review child args must not include a nested `--` delimiter")
        if arg in CODEX_REVIEW_MANAGED_OPTIONS_WITH_VALUES:
            raise UserError(
                f"codex-review manages `{arg}` itself; remove it from child args"
            )
        if any(arg.startswith(f"{option}=") for option in CODEX_REVIEW_MANAGED_OPTIONS_WITH_VALUES):
            option = next(
                option
                for option in CODEX_REVIEW_MANAGED_OPTIONS_WITH_VALUES
                if arg.startswith(f"{option}=")
            )
            raise UserError(
                f"codex-review manages `{option}` itself; remove it from child args"
            )
        if arg in CODEX_REVIEW_MANAGED_FLAGS:
            raise UserError(
                f"codex-review manages `{arg}` itself; remove it from child args"
            )
        if arg in CODEX_REVIEW_DISALLOWED_FLAGS:
            raise UserError(
                f"codex-review does not allow `{arg}` because this lane must stay helper-managed read-only"
            )
        if arg in CODEX_REVIEW_EXEC_OPTIONS_WITH_VALUES:
            if index + 1 >= len(args):
                raise UserError(f"missing value for codex-review child arg `{arg}`")
            exec_args.extend(args[index : index + 2])
            index += 2
            continue
        if any(arg.startswith(f"{option}=") for option in CODEX_REVIEW_EXEC_OPTIONS_WITH_VALUES):
            exec_args.append(arg)
            index += 1
            continue
        if arg in CODEX_REVIEW_EXEC_FLAGS:
            exec_args.append(arg)
            index += 1
            continue
        if arg in CODEX_REVIEW_REVIEW_OPTIONS_WITH_VALUES:
            if index + 1 >= len(args):
                raise UserError(f"missing value for codex-review child arg `{arg}`")
            review_args.extend(args[index : index + 2])
            index += 2
            continue
        if any(arg.startswith(f"{option}=") for option in CODEX_REVIEW_REVIEW_OPTIONS_WITH_VALUES):
            review_args.append(arg)
            index += 1
            continue
        if arg in CODEX_REVIEW_REVIEW_FLAGS:
            review_args.append(arg)
            index += 1
            continue
        if arg == "-":
            raise UserError(
                "codex-review child args must not provide stdin prompt directly; let the helper inject stdin or pass explicit prompt text"
            )
        if arg.startswith("-"):
            raise UserError(
                f"unsupported codex-review child arg `{arg}`; pass only safe `codex exec` / `codex exec review` options plus an optional explicit prompt"
            )
        if arg in CODEX_REVIEW_RESERVED_SUBCOMMANDS:
            raise UserError(
                "codex-review already enters `codex exec review`; do not pass nested subcommands"
            )
        if has_prompt:
            raise UserError(
                "codex-review only supports one explicit prompt positional after its safe exec options"
            )
        has_prompt = True
        review_args.append(arg)
        index += 1
    return exec_args, review_args, has_prompt
def _resolve_opencode_compaction_mode(
    *,
    lane: str,
    requested_mode: str,
) -> str:
    if requested_mode != "default":
        return requested_mode
    if lane == "bounded-semantic":
        return "no-auto"
    if lane == "super-large":
        return "auto-hardened"
    return "auto"


def _build_opencode_instruction_text(
    *,
    lane: str,
    placeholders: dict[str, str | None],
) -> str:
    lines = [
        "Persistent external review contract for this session:",
        f"- Workspace: {placeholders['{workspace}']}",
        f"- Source repo: {placeholders['{source_repo}']}",
    ]
    if placeholders["{diff_file}"] is not None:
        lines.append(f"- Primary diff: {placeholders['{diff_file}']}")
    if placeholders["{review_range}"] is not None:
        lines.append(f"- Frozen review range: {placeholders['{review_range}']}")
    if placeholders["{report_file}"] is not None:
        lines.append(f"- Final report file: {placeholders['{report_file}']}")
    if placeholders["{final_reply}"] is not None:
        lines.append(f"- Final reply must be exactly: {placeholders['{final_reply}']}")

    lines.extend(
        [
            "",
            "Review discipline:",
            "- Preserve this contract across the whole session, including after compaction.",
            "- Keep the review focused on correctness, regressions, performance/resource risks, and test coverage reasoning.",
            *_review_evidence_budget_lines(
                prefix="- ",
                start_line="- Start with the supplied diff, changed-file lists, --stat/--numstat, rg -l, rg --count, or exact symbol windows before reading large hunks.",
                narrow_after_large_result_to="one file, one hunk, or one exact symbol window",
            ),
            "- Skip style, formatting, naming, documentation-only, and hypothetical findings.",
            "- Verify concerns in code before flagging them.",
            "- Assume the caller already ran the relevant tests and gates; do not run tests, builds, linters, benchmarks, package-manager commands, or similar tool-driven validation.",
        ]
    )

    if lane == "super-large":
        lines.extend(
            [
                "- This is a super-large review lane. Preserve breadth when needed, but treat comment/header-only noise as non-findings unless it affects tooling, parsing, build behavior, or executable semantics.",
            ]
        )
    else:
        lines.extend(
            [
                "- Prefer a bounded semantic review centered on the supplied diff and directly related files.",
            ]
        )

    if placeholders["{report_file}"] is not None:
        lines.extend(
            [
                "- Write the final report to the configured report file instead of only returning findings in chat.",
                "- If there are no credible findings, write LGTM in the Findings section.",
            ]
        )

    return "\n".join(lines) + "\n"


def _build_opencode_permission_config(
    *,
    report_relative_path: str | None,
    report_file_path: str | None,
) -> dict[str, object]:
    edit_rules: dict[str, str] = {"*": "deny"}
    if report_relative_path is not None:
        edit_rules[report_relative_path] = "allow"
        report_parent = str(pathlib.Path(report_relative_path).parent)
        if report_parent not in (".", ""):
            edit_rules[f"{report_parent}/*"] = "allow"

    bash_rules: dict[str, str] = {"*": "deny"}
    for pattern in OPENCODE_BASH_ALLOW_PATTERNS:
        bash_rules[pattern] = "allow"
    if report_file_path is not None:
        report_parent = str(pathlib.Path(report_file_path).parent)
        if report_parent not in (".", ""):
            bash_rules[f"mkdir -p {report_parent}"] = "allow"
            bash_rules[f"mkdir -p '{report_parent}'"] = "allow"
            bash_rules[f'mkdir -p "{report_parent}"'] = "allow"

    return {
        "*": "deny",
        "read": {
            "*": "allow",
            "*.env": "ask",
            "*.env.*": "ask",
            "*.env.example": "allow",
        },
        "edit": edit_rules,
        "bash": bash_rules,
        "task": "deny",
        "skill": "deny",
        "question": "deny",
        "plan_enter": "deny",
        "plan_exit": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "codesearch": "deny",
        "todoread": "deny",
        "todowrite": "deny",
    }


def _prepare_opencode_runtime(
    *,
    workspace_root: pathlib.Path,
    placeholders: dict[str, str | None],
    lane: str,
    compaction_mode: str,
    opencode_reserved: int,
) -> dict[str, str]:
    runtime_root = workspace_root / ".codex-tmp" / "opencode-runtime"
    config_dir = runtime_root / ".opencode"
    instruction_path = config_dir / "instructions" / "review-contract.md"
    instruction_path.parent.mkdir(parents=True, exist_ok=True)

    instruction_path.write_text(
        _build_opencode_instruction_text(
            lane=lane,
            placeholders=placeholders,
        ),
        encoding="utf-8",
    )

    report_relative_path: str | None = None
    if placeholders["{report_file}"] is not None:
        report_relative_path = str(
            pathlib.Path(placeholders["{report_file}"]).resolve().relative_to(
                workspace_root.resolve()
            )
        )

    config: dict[str, object] = {
        "$schema": "https://opencode.ai/config.json",
        "autoupdate": False,
        "snapshot": False,
        "instructions": [str(instruction_path)],
        "permission": _build_opencode_permission_config(
            report_relative_path=report_relative_path,
            report_file_path=placeholders["{report_file}"],
        ),
    }

    if compaction_mode == "no-auto":
        config["compaction"] = {"auto": False}
    elif compaction_mode == "auto-hardened":
        config["compaction"] = {
            "auto": True,
            "prune": False,
            "reserved": opencode_reserved,
        }
    else:
        config["compaction"] = {"auto": True}

    config_path = runtime_root / "opencode.json"
    config_path.parent.mkdir(parents=True, exist_ok=True)
    config_path.write_text(
        json.dumps(config, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )

    env = {
        "OPENCODE_CONFIG": str(config_path),
    }
    if lane == "super-large" or compaction_mode == "auto-hardened":
        xdg_data_root = runtime_root / "xdg-data"
        xdg_data_root.mkdir(parents=True, exist_ok=True)
        env["XDG_DATA_HOME"] = str(xdg_data_root)
    return env


def _apply_opencode_defaults(
    *,
    rendered_args: list[str],
    placeholders: dict[str, str | None],
    opencode_default_model: str | None = None,
) -> list[str]:
    result = list(rendered_args)
    if not result or result[0] != "run":
        result = ["run", *result]

    injected_args: list[str] = []
    if not _has_option(result, "-m", "--model"):
        injected_args.extend(["-m", opencode_default_model or OPENCODE_MODEL_DEFAULT])
    if not _has_option(result, "--format"):
        injected_args.extend(["--format", OPENCODE_DEFAULT_FORMAT])
    if placeholders["{diff_file}"] is not None and not _has_option(result, "-f", "--file"):
        injected_args.extend(["--file", placeholders["{diff_file}"]])
    if len(result) > 1 and "--" not in result[1:]:
        return [result[0], *injected_args, "--", *result[1:]]
    return [result[0], *injected_args, *result[1:]]


def _apply_copilot_prompt_defaults(
    *,
    rendered_args: list[str],
    placeholders: dict[str, str | None],
) -> list[str]:
    if _has_option(rendered_args, "-p", "--prompt", "-i", "--interactive"):
        return rendered_args

    prompt_text = placeholders["{prompt_text}"]
    result = list(rendered_args)
    if prompt_text is not None:
        for index, arg in enumerate(result):
            if arg == prompt_text:
                return [*result[:index], "--prompt", arg, *result[index + 1 :]]

    index = 0
    while index < len(result):
        arg = result[index]
        if arg == "--":
            if index + 1 < len(result):
                return [*result[: index + 1], "--prompt", result[index + 1], *result[index + 2 :]]
            return rendered_args
        if arg in COPILOT_OPTIONS_REQUIRING_VALUES:
            index += 2
            continue
        if any(arg.startswith(f"{option}=") for option in COPILOT_OPTIONS_REQUIRING_VALUES):
            index += 1
            continue
        if arg.startswith("-"):
            index += 1
            continue
        return [*result[:index], "--prompt", arg, *result[index + 1 :]]

    return rendered_args


def _resolve_real_git() -> str:
    candidates: list[str] = []
    seen: set[str] = set()

    def add_candidate(path: str | None) -> None:
        if not path:
            return
        resolved = str(pathlib.Path(path).resolve())
        if resolved in seen:
            return
        seen.add(resolved)
        candidates.append(resolved)

    for candidate in PREFERRED_GIT_PATHS:
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            add_candidate(candidate)

    add_candidate(shutil.which("git", path=os.defpath))
    add_candidate(shutil.which("git"))

    for candidate in candidates:
        try:
            completed = subprocess.run(
                [candidate, "--version"],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
            )
        except OSError:
            continue
        if completed.returncode == 0:
            return candidate

    raise UserError("`git` is not available in a trusted executable path")


def _resolve_real_codex() -> str:
    candidates: list[str] = []
    seen: set[str] = set()

    def add_candidate(path: str | None) -> None:
        if not path:
            return
        candidate_path = pathlib.Path(path).expanduser()
        if candidate_path.stem != "codex":
            return
        resolved_path = candidate_path.resolve()
        nvm_trust = _is_trusted_default_nvm_codex_candidate(
            candidate_path,
            resolved_path,
        )
        if nvm_trust is False:
            return
        nvm_root = _default_nvm_root()
        if (
            _nvm_bin_for_resolved_path(resolved_path, nvm_root) is not None
            and _matching_default_nvm_bin_for_path(resolved_path) is None
        ):
            return
        if not resolved_path.name.startswith("codex"):
            return
        resolved = str(resolved_path)
        if resolved in seen:
            return
        seen.add(resolved)
        candidates.append(resolved)

    base_trusted_path_entries: list[str] = []
    trusted_path_entries: list[str] = []
    seen_entries: set[str] = set()

    def add_trusted_path_entry(candidate: str, *, nvm_only: bool = False) -> None:
        if not candidate:
            return
        if not _is_safe_path_entry(candidate):
            return
        resolved_candidate = str(pathlib.Path(candidate).resolve(strict=False))
        if not _is_safe_path_entry(resolved_candidate):
            return
        if resolved_candidate in seen_entries:
            return
        seen_entries.add(resolved_candidate)
        if not nvm_only:
            base_trusted_path_entries.append(resolved_candidate)
        trusted_path_entries.append(resolved_candidate)

    for candidate in [
        *(str(pathlib.Path(path).parent) for path in PREFERRED_CODEX_PATHS),
        *TRUSTED_CHILD_PATH_ENTRIES,
        *os.defpath.split(os.pathsep),
    ]:
        add_trusted_path_entry(candidate)
    for candidate in _trusted_nvm_bin_entries():
        add_trusted_path_entry(candidate, nvm_only=True)

    if os.environ.get(FAKE_CODEX_TEST_ENV) == "1":
        test_override = os.environ.get("FAKE_CODEX_PATH")
        add_candidate(test_override)

    override = os.environ.get("CODEX_REAL_CODEX")
    if override:
        override_path = pathlib.Path(override).expanduser()
        canonical_override_link = override_path.parent.resolve(strict=False) / override_path.name
        resolved_override = override_path.resolve(strict=False)
        nvm_trust = _is_trusted_default_nvm_codex_candidate(
            override_path,
            resolved_override,
        )
        if nvm_trust is True or any(
            _is_relative_to(path, pathlib.Path(candidate).resolve(strict=False))
            for path in (canonical_override_link, resolved_override)
            for candidate in base_trusted_path_entries
        ):
            add_candidate(override)

    for candidate in PREFERRED_CODEX_PATHS:
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            add_candidate(candidate)

    for trusted_path_entry in trusted_path_entries:
        add_candidate(shutil.which("codex", path=trusted_path_entry))

    for candidate in candidates:
        validation_path_entries: list[str] = []
        seen_validation_entries: set[str] = set()
        for entry in [
            _matching_default_nvm_bin_for_path(candidate),
            *base_trusted_path_entries,
        ]:
            if not entry or not _is_safe_path_entry(entry) or entry in seen_validation_entries:
                continue
            seen_validation_entries.add(entry)
            validation_path_entries.append(entry)
        validation_env = dict(os.environ)
        validation_env["PATH"] = os.pathsep.join(validation_path_entries)
        try:
            completed = subprocess.run(
                [candidate, "--version"],
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                check=False,
                env=validation_env,
            )
        except OSError:
            continue
        if completed.returncode == 0:
            return candidate

    raise UserError("`codex` is not available in a trusted executable path")


def _install_readonly_git_shim(
    container_dir: pathlib.Path,
) -> pathlib.Path:
    if not READONLY_GIT_SHIM_SOURCE.is_file():
        raise UserError(f"readonly git shim source missing: {READONLY_GIT_SHIM_SOURCE}")
    shim_dir = container_dir / "tool-shims"
    shim_dir.mkdir(parents=True, exist_ok=True)
    shim_path = shim_dir / "git"
    shim_text = READONLY_GIT_SHIM_SOURCE.read_text(encoding="utf-8")
    shim_python = _resolve_python_for_readonly_git_shim()
    shim_text = re.sub(
        r"\A#![^\n]*python3[^\n]*\n",
        f"#!{shim_python}\n",
        shim_text,
        count=1,
    )
    if shim_path.exists() or shim_path.is_symlink():
        if shim_path.is_dir() and not shim_path.is_symlink():
            shutil.rmtree(shim_path)
        else:
            shim_path.unlink()
    shim_path.write_text(shim_text, encoding="utf-8")
    shim_path.chmod(0o755)
    return shim_dir


def _resolve_python_for_readonly_git_shim() -> pathlib.Path:
    candidates: list[pathlib.Path] = []
    seen: set[str] = set()

    def add_candidate(candidate: str | os.PathLike[str] | None) -> None:
        if not candidate:
            return
        resolved = pathlib.Path(candidate).resolve(strict=False)
        key = str(resolved)
        if key in seen:
            return
        seen.add(key)
        if resolved.is_file() and os.access(resolved, os.X_OK):
            candidates.append(resolved)

    for candidate in PREFERRED_PYTHON_PATHS:
        add_candidate(candidate)
    add_candidate(shutil.which("python3"))
    add_candidate(sys.executable)

    for candidate in candidates:
        if not _is_apple_python(candidate):
            return candidate
    if candidates:
        return candidates[0]
    raise UserError("failed to resolve an executable Python for readonly git shim")


def _is_apple_python(path: pathlib.Path) -> bool:
    text = str(path.resolve(strict=False))
    return any(
        text == prefix or text.startswith(prefix)
        for prefix in APPLE_PYTHON_PREFIXES
    )


def _verify_readonly_git_shim(
    *,
    workspace_root: pathlib.Path,
    child_env: dict[str, str],
    expected_shim_path: pathlib.Path,
) -> None:
    resolved_git = shutil.which("git", path=child_env.get("PATH"))
    if resolved_git is None:
        raise UserError("failed to resolve `git` in child PATH")

    resolved_path = pathlib.Path(resolved_git).resolve()
    expected_path = expected_shim_path.resolve()
    if resolved_path != expected_path:
        raise UserError(
            "readonly git shim is not first on child PATH: "
            f"resolved {resolved_path}, expected {expected_path}"
        )

    completed = subprocess.run(
        ["git", "--version"],
        cwd=str(workspace_root),
        env=child_env,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if completed.returncode != 0:
        raise UserError(
            "readonly git shim probe failed before launching reviewer:\n"
            + _format_command_error(["git", "--version"], completed)
        )


def _cleanup_worktree(
    source_root: pathlib.Path,
    workspace_root: pathlib.Path,
    *,
    cleanup_submodule_worktrees: bool,
    preserve_container_dir: bool = False,
) -> None:
    if cleanup_submodule_worktrees:
        _cleanup_submodule_worktrees(source_root, workspace_root)
    _run(
        [
            _resolve_real_git(),
            "-C",
            str(source_root),
            "worktree",
            "remove",
            "--force",
            str(workspace_root),
        ],
        capture_output=True,
    )
    container_dir = workspace_root.parent
    if not preserve_container_dir and container_dir.exists():
        shutil.rmtree(container_dir, ignore_errors=True)


def _source_root_recognizes_workspace(
    source_root: pathlib.Path,
    workspace_root: pathlib.Path,
) -> bool:
    try:
        worktree_list = subprocess.run(
            [_resolve_real_git(), "-C", str(source_root), "worktree", "list", "--porcelain"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=False,
        )
    except OSError as error:
        raise UserError(f"failed to validate stateful source_root: {error}") from error
    if worktree_list.returncode != 0:
        return False
    resolved_workspace_root = workspace_root.resolve(strict=False)
    for line in worktree_list.stdout.splitlines():
        if not line.startswith("worktree "):
            continue
        candidate = pathlib.Path(line.split(" ", 1)[1]).resolve(strict=False)
        if candidate == resolved_workspace_root:
            return True
    return False


def _prune_missing_workspace_registration(
    source_root: pathlib.Path,
    workspace_root: pathlib.Path,
    *,
    require_known: bool,
) -> None:
    if require_known and not _source_root_recognizes_workspace(source_root, workspace_root):
        raise UserError(
            "stateful source_root does not recognize missing workspace_root; refusing cleanup: "
            f"{source_root} -> {workspace_root}"
        )
    _run([_resolve_real_git(), "-C", str(source_root), "worktree", "prune"])
    if _source_root_recognizes_workspace(source_root, workspace_root):
        raise UserError(
            "stateful source_root still recognizes missing workspace_root after prune: "
            f"{source_root} -> {workspace_root}"
        )


def _prune_missing_submodule_workspace_registrations(
    source_root: pathlib.Path,
    workspace_root: pathlib.Path,
) -> None:
    for submodule_path in _list_direct_submodules(source_root):
        source_submodule = source_root / submodule_path
        if not source_submodule.exists() or not _is_git_worktree_root(source_submodule):
            continue
        target_submodule = workspace_root / submodule_path
        _prune_missing_workspace_registration(
            source_submodule,
            target_submodule,
            require_known=False,
        )
        _prune_missing_submodule_workspace_registrations(
            source_submodule,
            target_submodule,
        )


def _cleanup_failed_workspace_setup(
    source_root: pathlib.Path,
    workspace_root: pathlib.Path,
    *,
    container_dir: pathlib.Path,
    created_workspace: bool,
    cleanup_submodule_worktrees: bool,
) -> UserError | None:
    if not created_workspace:
        return None
    try:
        if workspace_root.exists() and _is_git_worktree_root(workspace_root):
            _cleanup_worktree(
                source_root,
                workspace_root,
                cleanup_submodule_worktrees=cleanup_submodule_worktrees,
            )
        elif container_dir.exists():
            shutil.rmtree(container_dir, ignore_errors=True)
    except UserError as error:
        return error
    return None


def _validate_reused_workspace(
    workspace_root: pathlib.Path,
    *,
    source_root: pathlib.Path,
    expected_head: str | None,
    require_clean: bool = False,
) -> pathlib.Path:
    resolved_workspace = workspace_root.resolve()
    resolved_source_root = source_root.resolve(strict=False)
    if not resolved_workspace.is_dir():
        raise UserError(f"reused workspace not found: {resolved_workspace}")
    if not _is_git_worktree_root(resolved_workspace):
        raise UserError(
            f"reused workspace is not a git worktree root: {resolved_workspace}"
        )
    if not _is_relative_to(resolved_workspace, resolved_source_root / ".codex-tmp"):
        raise UserError(
            "reused workspace must live under the source repo's .codex-tmp directory"
        )
    if expected_head is not None:
        workspace_head = _git_stdout(resolved_workspace, "rev-parse", "HEAD")
        if workspace_head != expected_head:
            raise UserError(
                "reused workspace HEAD does not match the requested frozen head: "
                f"{workspace_head} != {expected_head}"
            )
    if require_clean:
        dirty_paths = _repo_dirty_paths(resolved_workspace)
        if dirty_paths:
            sample_paths = ", ".join(path.as_posix() for path in dirty_paths[:5])
            more_count = len(dirty_paths) - 5
            more_suffix = f", and {more_count} more" if more_count > 0 else ""
            raise UserError(
                "reused frozen codex-review workspace must be clean so the builtin "
                "`--base` scope matches the helper evidence-budget check; dirty paths: "
                f"{sample_paths}{more_suffix}"
            )
    return resolved_workspace


def _state_file_path(state_dir: pathlib.Path) -> pathlib.Path:
    return state_dir / "state.json"


def _resolve_state_guarded_path(
    *,
    path_value: object,
    field_name: str,
    state_dir: pathlib.Path,
    workspace_root: pathlib.Path | None = None,
) -> pathlib.Path:
    candidate = pathlib.Path(str(path_value))
    lexical_roots = [state_dir]
    if workspace_root is not None:
        lexical_roots.insert(0, workspace_root)
    resolved_candidate = candidate.resolve(strict=False)
    for lexical_root in lexical_roots:
        resolved_root = lexical_root.resolve(strict=False)
        if not _is_relative_to(resolved_candidate, resolved_root):
            continue
        return resolved_candidate
    raise UserError(
        f"{field_name} must stay inside {state_dir}"
        + (f" or {workspace_root}" if workspace_root is not None else "")
        + f": {candidate}"
    )


def _require_state_field(
    state: dict[str, object],
    field_name: str,
) -> object:
    if field_name not in state:
        raise UserError(f"review state missing required field: {field_name}")
    return state[field_name]


def _load_state(state_dir: pathlib.Path) -> dict[str, object]:
    state_path = _state_file_path(state_dir)
    if not state_path.is_file():
        raise UserError(f"review state not found: {state_path}")
    state = _read_json(state_path)
    if not isinstance(state, dict):
        raise UserError(f"invalid review state format: {state_path}")
    expected_head_raw = state.get("head_ref")
    expected_head = str(expected_head_raw) if expected_head_raw else None
    source_root_raw = state.get("source_root")
    if (
        state.get("state_kind") == "parallel" or state.get("reuse_workspace")
    ) and source_root_raw is not None:
        workspace_candidate = pathlib.Path(
            str(_require_state_field(state, "workspace_root"))
        ).resolve(strict=False)
        source_root = pathlib.Path(str(source_root_raw))
        resolved_source_root = source_root.resolve(strict=False)
        if workspace_candidate.exists():
            workspace_root = _validate_reused_workspace(
                workspace_candidate,
                source_root=source_root,
                expected_head=expected_head,
            )
        elif _is_relative_to(workspace_candidate, resolved_source_root / ".codex-tmp"):
            workspace_root = workspace_candidate
        else:
            raise UserError(
                "reused workspace must live under the source repo's .codex-tmp directory"
            )
    else:
        workspace_root = _resolve_state_guarded_path(
            path_value=_require_state_field(state, "workspace_root"),
            field_name="workspace_root",
            state_dir=state_dir,
        )
    state["workspace_root"] = str(workspace_root)
    for field_name in (
        "pid_path",
        "exit_code_path",
        "stdout_path",
        "stderr_path",
        "lock_path",
        "runner_spec_path",
    ):
        if field_name not in state:
            continue
        state[field_name] = str(
            _resolve_state_guarded_path(
                path_value=state[field_name],
                field_name=field_name,
                state_dir=state_dir,
            )
        )
    for field_name in ("diff_file",):
        if field_name not in state or state[field_name] is None:
            continue
        state[field_name] = str(
            _resolve_state_guarded_path(
                path_value=state[field_name],
                field_name=field_name,
                state_dir=state_dir,
                workspace_root=workspace_root,
            )
        )
    return state


def _save_state(state_dir: pathlib.Path, state: dict[str, object]) -> None:
    _write_json(_state_file_path(state_dir), state)


def _read_pid(path: pathlib.Path) -> int | None:
    contents = _read_text_if_present(path)
    if contents is None:
        return None
    contents = contents.strip()
    if not contents:
        return None
    try:
        return int(contents)
    except ValueError:
        return None


def _unlink_allowed_file_if_present(
    path: pathlib.Path | None,
    *,
    workspace_root: pathlib.Path,
    state_dir: pathlib.Path | None = None,
) -> None:
    if path is None:
        return
    resolved_path = path.resolve(strict=False)
    lexical_roots = [workspace_root]
    if state_dir is not None:
        lexical_roots.append(state_dir)
    for lexical_root in lexical_roots:
        try:
            path.relative_to(lexical_root)
        except ValueError:
            continue
        if not _is_relative_to(resolved_path, lexical_root.resolve(strict=False)):
            return
        break
    else:
        return
    if path.is_dir() and not path.is_symlink():
        return
    if path.exists() or path.is_symlink():
        path.unlink()


def _state_launch_pending(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    pid: int | None,
    exit_code: int | None,
) -> bool:
    if exit_code is not None or pid is not None:
        return False

    runner_spec_path = pathlib.Path(
        str(state.get("runner_spec_path", state_dir / "runner-spec.json"))
    )
    if not runner_spec_path.is_file():
        return False

    started_at_raw = state.get("started_at")
    try:
        started_at = float(started_at_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        return False
    return (time.time() - started_at) < STATEFUL_LAUNCH_GRACE_SECONDS


def _reset_stateful_artifacts(
    state_dir: pathlib.Path,
    *,
    workspace_root: pathlib.Path,
    current_final_path: pathlib.Path | None,
    current_report_path: pathlib.Path | None,
) -> None:
    prior_state_path = _state_file_path(state_dir)
    prior_state = _load_state(state_dir) if prior_state_path.is_file() else None
    if isinstance(prior_state, dict):
        if pathlib.Path(
            str(_require_state_field(prior_state, "workspace_root"))
        ) != workspace_root.resolve(strict=False):
            raise UserError(
                "reused workspace state does not match the requested workspace_root: "
                f"{_require_state_field(prior_state, 'workspace_root')} != {workspace_root}"
            )
        prior_pid_path = pathlib.Path(str(prior_state.get("pid_path", state_dir / "pid")))
        prior_exit_code_path = pathlib.Path(
            str(prior_state.get("exit_code_path", state_dir / "exit_code"))
        )
        prior_report_path_raw = prior_state.get("report_file")
        prior_report_path = (
            pathlib.Path(str(prior_report_path_raw))
            if prior_report_path_raw
            else None
        )
        prior_final_path_raw = prior_state.get("final_path")
        prior_final_path = (
            pathlib.Path(str(prior_final_path_raw))
            if prior_final_path_raw
            else None
        )
    else:
        prior_pid_path = state_dir / "pid"
        prior_exit_code_path = state_dir / "exit_code"
        prior_report_path = None
        prior_final_path = None

    prior_exit_code = _read_exit_code(prior_exit_code_path)
    prior_pid = _read_pid(prior_pid_path)
    prior_lock_path = (
        pathlib.Path(str(prior_state.get("lock_path", state_dir / "runner.lock")))
        if isinstance(prior_state, dict)
        else state_dir / "runner.lock"
    )
    prior_launch_pending = False
    if isinstance(prior_state, dict):
        prior_launch_pending = _state_launch_pending(
            state_dir,
            prior_state,
            pid=prior_pid,
            exit_code=prior_exit_code,
        )
    if prior_exit_code is None and (
        _state_lock_is_held(prior_lock_path)
        or prior_launch_pending
    ):
        raise UserError(f"review is still running in reused workspace: {state_dir}")

    artifact_paths = {
        state_dir / "stdout.log",
        state_dir / "stderr.log",
        state_dir / "exit_code",
        state_dir / "pid",
        state_dir / "runner-spec.json",
        state_dir / "runner.lock",
        state_dir / "launcher.log",
        state_dir / "stdin.txt",
        state_dir / "model-fallback.json",
        prior_state_path,
    }
    for artifact_path in artifact_paths:
        if artifact_path.is_file():
            artifact_path.unlink()

    _unlink_allowed_file_if_present(
        prior_final_path,
        workspace_root=workspace_root,
        state_dir=state_dir,
    )
    _unlink_allowed_file_if_present(
        current_final_path,
        workspace_root=workspace_root,
        state_dir=state_dir,
    )
    _unlink_allowed_file_if_present(
        prior_report_path,
        workspace_root=workspace_root,
        state_dir=state_dir,
    )
    _unlink_allowed_file_if_present(
        current_report_path,
        workspace_root=workspace_root,
        state_dir=state_dir,
    )


def _build_state_parser(action: str) -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=f"Manage a background isolated review process ({action})."
    )
    parser.add_argument(
        "--state-dir",
        required=True,
        help="State directory returned by `start`.",
    )
    if action == "wait":
        parser.add_argument(
            "--timeout-seconds",
            type=float,
            help="Optional wait timeout before returning a timeout error.",
        )
    return parser


def _state_summary(state_dir: pathlib.Path, state: dict[str, object]) -> dict[str, object]:
    if _state_kind(state) == "parallel":
        return _parallel_state_summary(state_dir, state)

    entrypoint = str(_require_state_field(state, "entrypoint"))
    pid_path = pathlib.Path(str(_require_state_field(state, "pid_path")))
    exit_code_path = pathlib.Path(str(_require_state_field(state, "exit_code_path")))
    stdout_path = pathlib.Path(str(_require_state_field(state, "stdout_path")))
    stderr_path = pathlib.Path(str(_require_state_field(state, "stderr_path")))
    lock_path = pathlib.Path(str(state.get("lock_path", state_dir / "runner.lock")))
    pid = _read_pid(pid_path)
    exit_code = _read_exit_code(exit_code_path)
    pid_running = _state_lock_is_held(lock_path)
    launch_pending = _state_launch_pending(
        state_dir,
        state,
        pid=pid,
        exit_code=exit_code,
    )
    final_path = state.get("final_path")
    final_available = False
    if final_path:
        final_available = (
            _resolve_stateful_output_source(
                state_dir=state_dir,
                state=state,
                source_path=pathlib.Path(str(final_path)),
            )
            is not None
        )
    stderr_tail = _tail_text(stderr_path)
    if exit_code is not None:
        running = False
        if exit_code == 0 and entrypoint == "codex-readonly" and not final_available:
            exit_code = 1
            status = "failed"
            note = "codex-readonly exited successfully without a final artifact"
            stderr_tail = (
                f"{stderr_tail.rstrip()}\n{note}\n"
                if stderr_tail.strip()
                else f"{note}\n"
            )
        else:
            status = "passed" if exit_code == 0 else "failed"
    else:
        running = pid_running or launch_pending
        if pid_running:
            status = "running"
        elif launch_pending:
            status = "launching"
        else:
            status = "unknown"
    report_file = state.get("report_file")
    report_available = False
    if report_file:
        report_available = (
            _resolve_stateful_output_source(
                state_dir=state_dir,
                state=state,
                source_path=pathlib.Path(str(report_file)),
            )
            is not None
        )
    model_fallback = None
    model_fallback_path_raw = state.get("model_fallback_path")
    if model_fallback_path_raw:
        model_fallback_path = pathlib.Path(str(model_fallback_path_raw))
        if model_fallback_path.is_file():
            try:
                model_fallback = _read_json(model_fallback_path)
            except (OSError, UserError):
                model_fallback = None
    codex_model = None
    if entrypoint in {"codex-review", "codex-readonly"}:
        primary_model = state.get("codex_primary_model")
        if isinstance(primary_model, str) and primary_model:
            codex_model = primary_model
        if isinstance(model_fallback, dict):
            fallback_model = model_fallback.get("fallback_model")
            if isinstance(fallback_model, str) and fallback_model:
                codex_model = fallback_model
    return {
        "state_dir": str(state_dir),
        "workspace_root": _require_state_field(state, "workspace_root"),
        "entrypoint": entrypoint,
        "review_range": state.get("review_range"),
        "pid": pid,
        "running": running,
        "exit_code": exit_code,
        "status": status,
        "final_available": final_available,
        "report_available": report_available,
        "workspace_cleaned": bool(state.get("workspace_cleaned")),
        "codex_model": codex_model,
        "model_fallback": model_fallback,
        "stdout_tail": _tail_text(stdout_path),
        "stderr_tail": stderr_tail,
    }


def _preserve_stateful_workspace_file(
    state_dir: pathlib.Path,
) -> pathlib.Path:
    return state_dir / "report-artifacts"


def _resolve_stateful_output_source(
    *,
    state_dir: pathlib.Path,
    state: dict[str, object],
    source_path: pathlib.Path,
) -> tuple[pathlib.Path, pathlib.Path] | None:
    try:
        resolved_source_path = source_path.resolve(strict=True)
    except OSError:
        return None
    if not resolved_source_path.is_file():
        return None

    workspace_root = pathlib.Path(str(_require_state_field(state, "workspace_root")))
    for lexical_root in (workspace_root, state_dir):
        try:
            relative_source_path = source_path.relative_to(lexical_root)
        except ValueError:
            continue
        try:
            resolved_source_path.relative_to(lexical_root.resolve())
        except ValueError:
            return None
        return relative_source_path, resolved_source_path
    return None


def _preserve_stateful_output(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    state_key: str,
    preserved_path: pathlib.Path | None = None,
) -> None:
    source_path = state.get(state_key)
    if not source_path:
        return
    source_details = _resolve_stateful_output_source(
        state_dir=state_dir,
        state=state,
        source_path=pathlib.Path(str(source_path)),
    )
    if source_details is None:
        return

    relative_source_path, source_file = source_details

    resolved_preserved_path = preserved_path
    if resolved_preserved_path is None:
        resolved_preserved_path = (
            _preserve_stateful_workspace_file(state_dir) / relative_source_path
        )
    resolved_preserved_path.parent.mkdir(parents=True, exist_ok=True)
    if source_file == resolved_preserved_path:
        return
    resolved_preserved_path.write_bytes(source_file.read_bytes())
    state[state_key] = str(resolved_preserved_path)
    _save_state(state_dir, state)


def _maybe_cleanup_stateful_workspace(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    exit_code: int,
) -> None:
    if bool(state.get("workspace_cleaned")):
        return
    workspace_root = pathlib.Path(str(_require_state_field(state, "workspace_root")))
    _unlink_allowed_file_if_present(
        state_dir / "stdin.txt",
        workspace_root=workspace_root,
        state_dir=state_dir,
    )
    if state.get("reuse_workspace") or state.get("keep_workspace"):
        return
    if exit_code != 0 and state.get("keep_on_failure"):
        return

    _preserve_stateful_output(
        state_dir,
        state,
        state_key="final_path",
        preserved_path=state_dir / "final.txt",
    )
    _preserve_stateful_output(state_dir, state, state_key="report_file")
    source_root = pathlib.Path(str(_require_state_field(state, "source_root")))
    if not workspace_root.exists():
        _prune_missing_workspace_registration(
            source_root,
            workspace_root,
            require_known=True,
        )
        if bool(state.get("cleanup_submodule_worktrees")):
            _prune_missing_submodule_workspace_registrations(
                source_root,
                workspace_root,
            )
        state["workspace_cleaned"] = True
        _save_state(state_dir, state)
        return

    if not _source_root_recognizes_workspace(source_root, workspace_root):
        raise UserError(
            "stateful source_root does not recognize workspace_root; refusing cleanup: "
            f"{source_root} -> {workspace_root}"
        )

    _cleanup_worktree(
        source_root,
        workspace_root,
        cleanup_submodule_worktrees=bool(state.get("cleanup_submodule_worktrees")),
        preserve_container_dir=True,
    )
    state["workspace_cleaned"] = True
    _save_state(state_dir, state)


def _extract_codex_review_stdout_message(stdout_path: pathlib.Path) -> str | None:
    for line in reversed(_tail_text(stdout_path, line_count=80).splitlines()):
        stripped = line.strip()
        if not stripped.startswith("{"):
            continue
        try:
            payload = json.loads(stripped)
        except json.JSONDecodeError:
            continue
        if not isinstance(payload, dict):
            continue
        item = payload.get("item")
        if not isinstance(item, dict):
            continue
        if item.get("type") != "agent_message":
            continue
        text = item.get("text")
        if not isinstance(text, str) or not text.strip():
            continue
        return text if text.endswith("\n") else f"{text}\n"
    return None


def _build_stateful_runner_env(child_env: dict[str, str]) -> dict[str, str]:
    runner_env: dict[str, str] = {}
    for key, value in child_env.items():
        if (
            key in STATEFUL_RUNNER_SAFE_ENV_KEYS
            or key in STATEFUL_RUNNER_REVIEW_ENV_KEYS
            or key.startswith(STATEFUL_RUNNER_SAFE_ENV_PREFIXES)
            or key.startswith(STATEFUL_RUNNER_REVIEW_ENV_PREFIXES)
        ):
            runner_env[key] = value
    return runner_env


def _trusted_child_path(*extra_entries: str, codex_path: str | None = None) -> str:
    entries: list[str] = []
    seen: set[str] = set()
    for candidate in [
        *extra_entries,
        _matching_default_nvm_bin_for_path(codex_path) if codex_path else None,
        *TRUSTED_CHILD_PATH_ENTRIES,
    ]:
        if not candidate or candidate in seen:
            continue
        if not _is_safe_path_entry(candidate):
            continue
        seen.add(candidate)
        entries.append(candidate)
    return os.pathsep.join(entries)


def _prepare_workspace(
    args: argparse.Namespace,
) -> tuple[
    pathlib.Path,
    str | None,
    str | None,
    pathlib.Path,
    pathlib.Path,
    bool,
    bool,
]:
    source_root = _resolve_repo_root(args.repo)
    base_ref, head_ref = _resolve_frozen_range(
        source_root,
        base_ref=args.base_ref,
        head_ref=args.head_ref,
    )
    if args.entrypoint == "codex-review" and base_ref is not None and head_ref is not None:
        _require_linear_codex_review_range(
            source_root,
            base_ref=base_ref,
            head_ref=head_ref,
        )
    temp_parent = source_root / ".codex-tmp"
    temp_parent.mkdir(parents=True, exist_ok=True)
    created_workspace = False
    if args.reuse_workspace:
        workspace_root = _validate_reused_workspace(
            pathlib.Path(args.reuse_workspace),
            source_root=source_root,
            expected_head=head_ref,
            require_clean=(
                args.entrypoint == "codex-review"
                and base_ref is not None
                and head_ref is not None
            ),
        )
        if args.state_dir:
            container_dir = pathlib.Path(args.state_dir).resolve()
            if not _is_relative_to(container_dir, source_root / ".codex-tmp"):
                raise UserError(
                    "state_dir must live under the source repo's .codex-tmp directory"
                )
            container_dir.mkdir(parents=True, exist_ok=True)
        else:
            container_dir = workspace_root.parent
    else:
        container_dir = pathlib.Path(
            tempfile.mkdtemp(prefix="isolated-review-", dir=temp_parent)
        )
        workspace_root = container_dir / "workspace"
        created_workspace = True

    cleanup_submodule_worktrees = False
    try:
        if created_workspace:
            if head_ref is not None:
                _run(
                    [
                        _resolve_real_git(),
                        "-C",
                        str(source_root),
                        "worktree",
                        "add",
                        "--detach",
                        str(workspace_root),
                        head_ref,
                    ],
                    capture_output=True,
                )
                _checkout_submodules(workspace_root)
            else:
                _run(
                    [
                        _resolve_real_git(),
                        "-C",
                        str(source_root),
                        "worktree",
                        "add",
                        "--detach",
                        "--no-checkout",
                        str(workspace_root),
                        "HEAD",
                    ],
                    capture_output=True,
                )
                _checkout_snapshot_worktree(workspace_root)
                _prepare_submodule_worktrees(source_root, workspace_root)
                cleanup_submodule_worktrees = True
                _materialize_repo_snapshot(source_root, workspace_root)
    except UserError as error:
        cleanup_error = _cleanup_failed_workspace_setup(
            source_root,
            workspace_root,
            container_dir=container_dir,
            created_workspace=created_workspace,
            cleanup_submodule_worktrees=cleanup_submodule_worktrees,
        )
        if cleanup_error is not None:
            raise UserError(f"{error}\n{cleanup_error}") from error
        raise

    return (
        source_root,
        base_ref,
        head_ref,
        container_dir,
        workspace_root,
        created_workspace,
        cleanup_submodule_worktrees,
    )


def _build_child_process(
    args: argparse.Namespace,
    *,
    source_root: pathlib.Path,
    base_ref: str | None,
    head_ref: str | None,
    container_dir: pathlib.Path,
    workspace_root: pathlib.Path,
    placeholders: dict[str, str | None],
) -> tuple[list[str], dict[str, str], str, pathlib.Path | None, bytes | None, str]:
    rendered_args = _render_command_args(args.review_args, placeholders)
    base_rendered_args = list(rendered_args)
    entrypoint_cmd, entrypoint_label, entrypoint_default_model = _resolve_entrypoint(
        args.entrypoint,
        args.lane,
        rendered_args=base_rendered_args,
        placeholders=placeholders,
    )
    rendered_args = _sanitize_auto_fallback_args(
        mode=args.entrypoint,
        entrypoint_label=entrypoint_label,
        rendered_args=base_rendered_args,
    )
    late_agent_path: str | None = None
    if entrypoint_label == "agent":
        late_agent_path = entrypoint_cmd[0]
        if not _has_option(rendered_args, "-m", "--model") and entrypoint_default_model is None:
            late_usable, late_reason, late_default_model = _agent_preflight_for_args(
                agent_path=entrypoint_cmd[0],
                rendered_args=rendered_args,
            )
            late_agent_path = None
            if late_usable is False:
                if args.entrypoint == "auto":
                    entrypoint_cmd, entrypoint_label, entrypoint_default_model = _resolve_entrypoint(
                        args.entrypoint,
                        args.lane,
                        rendered_args=base_rendered_args,
                        placeholders=placeholders,
                        excluded_entrypoints={"agent"},
                    )
                    rendered_args = _sanitize_auto_fallback_args(
                        mode=args.entrypoint,
                        entrypoint_label=entrypoint_label,
                        rendered_args=base_rendered_args,
                    )
                else:
                    raise UserError(f"`agent` failed usability preflight: {late_reason}")
            elif late_usable is None:
                reason = (
                    late_reason
                    or "trusted `agent models` catalog remained inconclusive"
                )
                if args.entrypoint == "auto":
                    entrypoint_cmd, entrypoint_label, entrypoint_default_model = _resolve_entrypoint(
                        args.entrypoint,
                        args.lane,
                        rendered_args=base_rendered_args,
                        placeholders=placeholders,
                        excluded_entrypoints={"agent"},
                    )
                    rendered_args = _sanitize_auto_fallback_args(
                        mode=args.entrypoint,
                        entrypoint_label=entrypoint_label,
                        rendered_args=base_rendered_args,
                    )
                else:
                    raise UserError(
                        "`agent` failed usability preflight: "
                        "unable to verify the helper default model after repeated "
                        f"inconclusive catalog probes ({reason}); pass an explicit "
                        "`-m/--model` or use another lane"
                    )
            else:
                entrypoint_default_model = late_default_model

    stdin_bytes: bytes | None = None
    prompt_delivery = "none"
    final_path: pathlib.Path | None = None
    if entrypoint_label == "codex-review":
        final_path = container_dir / "final.txt"
        runtime_temp_dir = container_dir / "codex-review-tmp"
        (
            rendered_args,
            prompt_delivery,
            stdin_bytes,
            final_path,
        ) = _apply_codex_review_defaults(
            codex_path=entrypoint_cmd[0],
            rendered_args=rendered_args,
            workspace_root=workspace_root,
            final_path=final_path,
            runtime_temp_dir=runtime_temp_dir,
            base_ref=base_ref,
            prompt_text=placeholders["{prompt_text}"],
            model=args.codex_model,
            reasoning_effort=args.codex_reasoning_effort,
        )
    elif entrypoint_label == "codex-readonly":
        final_path = container_dir / "final.txt"
        runtime_temp_dir = container_dir / "codex-readonly-tmp"
        (
            rendered_args,
            prompt_delivery,
            stdin_bytes,
            final_path,
        ) = _apply_codex_readonly_defaults(
            codex_path=entrypoint_cmd[0],
            rendered_args=rendered_args,
            workspace_root=workspace_root,
            runtime_temp_dir=runtime_temp_dir,
            final_path=final_path,
            placeholders=placeholders,
            model=args.codex_model,
            reasoning_effort=args.codex_reasoning_effort,
        )
    else:
        rendered_args = _maybe_apply_default_external_prompt(
            entrypoint_label=entrypoint_label,
            rendered_args=rendered_args,
            placeholders=placeholders,
        )
        rendered_args, prompt_delivery = _apply_prompt_delivery(
            requested_mode=args.prompt_delivery,
            entrypoint_label=entrypoint_label,
            rendered_args=rendered_args,
            placeholders=placeholders,
            inline_max_bytes=args.prompt_inline_max_bytes,
        )
        if entrypoint_label == "agent":
            rendered_args = _apply_agent_defaults(
                entrypoint_label,
                rendered_args,
                agent_default_model=entrypoint_default_model,
                agent_path=late_agent_path,
            )
        elif entrypoint_label == "opencode":
            rendered_args = _apply_opencode_defaults(
                rendered_args=rendered_args,
                placeholders=placeholders,
                opencode_default_model=entrypoint_default_model,
            )
        elif entrypoint_label in {"copilot", "gh-copilot"}:
            rendered_args = _apply_copilot_prompt_defaults(
                rendered_args=rendered_args,
                placeholders=placeholders,
            )
        _ensure_no_external_gpt_model(
            entrypoint_label=entrypoint_label,
            rendered_args=rendered_args,
        )

    if entrypoint_label == "gh-copilot":
        command = [*entrypoint_cmd, *(["--"] if rendered_args else []), *rendered_args]
    else:
        command = [*entrypoint_cmd, *rendered_args]

    base_env = os.environ.copy()
    child_env = dict(base_env)
    child_env["CODEX_ISOLATED_REVIEW_ROOT"] = str(workspace_root)
    child_env["CODEX_ISOLATED_SOURCE_REPO"] = str(source_root)
    child_env["CODEX_ISOLATED_REVIEW_ENTRYPOINT"] = entrypoint_label
    if base_ref is not None:
        child_env["CODEX_ISOLATED_REVIEW_BASE_REF"] = base_ref
    if head_ref is not None:
        child_env["CODEX_ISOLATED_REVIEW_HEAD_REF"] = head_ref
        child_env["CODEX_ISOLATED_REVIEW_RANGE"] = placeholders["{review_range}"] or ""
    if placeholders["{report_file}"] is not None:
        child_env["CODEX_ISOLATED_REVIEW_REPORT_FILE"] = placeholders["{report_file}"]
    if placeholders["{final_reply}"] is not None:
        child_env["CODEX_ISOLATED_REVIEW_FINAL_REPLY"] = placeholders["{final_reply}"]
    if final_path is not None:
        child_env["CODEX_ISOLATED_REVIEW_FINAL_FILE"] = str(final_path)
    if entrypoint_label in {"codex-review", "codex-readonly"}:
        runtime_temp_dir = container_dir / (
            "codex-review-tmp"
            if entrypoint_label == "codex-review"
            else "codex-readonly-tmp"
        )
        child_env["TMPDIR"] = str(runtime_temp_dir)
        child_env["TMP"] = str(runtime_temp_dir)
        child_env["TEMP"] = str(runtime_temp_dir)
        child_env["TMPPREFIX"] = str(runtime_temp_dir / "zsh")
    real_git = _resolve_real_git()
    readonly_git_shim_dir = _install_readonly_git_shim(container_dir)
    child_env["PATH"] = (
        f"{readonly_git_shim_dir}{os.pathsep}"
        f"{child_env.get('PATH', '')}"
    )
    child_env["CODEX_REAL_GIT"] = real_git
    child_env["CODEX_ISOLATED_REVIEW_GIT_POLICY"] = "readonly-shim"
    child_env["CODEX_ISOLATED_REVIEW_GIT_SHIM"] = str(
        readonly_git_shim_dir / "git"
    )
    child_env["CODEX_ISOLATED_REVIEW_PROMPT_DELIVERY"] = prompt_delivery
    if placeholders["{prompt_file}"] is not None:
        child_env["CODEX_ISOLATED_REVIEW_PROMPT_FILE"] = placeholders["{prompt_file}"]
    if placeholders["{diff_file}"] is not None:
        child_env["CODEX_ISOLATED_REVIEW_DIFF_FILE"] = placeholders["{diff_file}"]
    if placeholders["{prompt_text}"] is not None and prompt_delivery not in {"bootstrap", "stdin", "builtin-review"}:
        child_env["CODEX_ISOLATED_REVIEW_PROMPT_TEXT"] = placeholders["{prompt_text}"]

    if entrypoint_label == "opencode":
        child_env.update(
            _prepare_opencode_runtime(
                workspace_root=workspace_root,
                placeholders=placeholders,
                lane=args.lane,
                compaction_mode=_resolve_opencode_compaction_mode(
                    lane=args.lane,
                    requested_mode=args.opencode_compaction,
                ),
                opencode_reserved=args.opencode_reserved,
            )
        )
    elif entrypoint_label in {"codex-review", "codex-readonly"}:
        child_env["PATH"] = _trusted_child_path(
            str(readonly_git_shim_dir),
            codex_path=entrypoint_cmd[0],
        )
    elif entrypoint_label == "gh-copilot":
        companion_path = _resolve_gh_copilot_companion()
        if companion_path:
            companion_dir = str(pathlib.Path(companion_path).parent)
            current_path = child_env.get("PATH", "")
            path_entries = [entry for entry in current_path.split(os.pathsep) if entry]
            if companion_dir not in path_entries:
                path_entries.insert(1 if path_entries else 0, companion_dir)
            child_env["PATH"] = os.pathsep.join(path_entries)

    _verify_readonly_git_shim(
        workspace_root=workspace_root,
        child_env=child_env,
        expected_shim_path=readonly_git_shim_dir / "git",
    )
    return (
        command,
        child_env,
        entrypoint_label,
        final_path,
        stdin_bytes,
        prompt_delivery,
    )


def _validate_codex_model_policy(args: argparse.Namespace) -> None:
    if args.entrypoint not in {"codex-review", "codex-readonly", "codex-parallel"}:
        return
    for flag, value in (
        ("--codex-model", args.codex_model),
        ("--codex-fallback-model", args.codex_fallback_model),
        ("--codex-reasoning-effort", args.codex_reasoning_effort),
    ):
        if not isinstance(value, str) or not value.strip():
            raise UserError(f"{flag} must be a non-empty string")
    if (
        not args.no_codex_model_fallback
        and args.codex_model == args.codex_fallback_model
    ):
        raise UserError(
            "--codex-fallback-model must differ from --codex-model, or pass "
            "--no-codex-model-fallback"
        )


def _codex_model_fallback_enabled(
    args: argparse.Namespace,
    *,
    entrypoint_label: str,
) -> bool:
    if entrypoint_label not in {"codex-review", "codex-readonly"}:
        return False
    if args.no_codex_model_fallback:
        return False
    if entrypoint_label == "codex-review":
        raw_review_args = list(args.review_args)
        if raw_review_args and raw_review_args[0] == "--":
            raw_review_args = raw_review_args[1:]
        if _has_option(raw_review_args, "-m", "--model"):
            return False
    return True


def _prepare_review_execution(args: argparse.Namespace) -> dict[str, object]:
    source_root: pathlib.Path | None = None
    workspace_root: pathlib.Path | None = None
    created_workspace = False
    cleanup_submodule_worktrees = False
    try:
        _validate_codex_model_policy(args)
        if args.entrypoint == "codex-review":
            frozen_range = args.base_ref is not None or args.head_ref is not None
            _reject_codex_review_report_path(args)
            _reject_codex_review_explicit_prompt(
                args,
                frozen_range=frozen_range,
            )
            _reject_codex_review_output_override(args)
            if frozen_range:
                _reject_frozen_codex_review_prompt_contracts(args)
            else:
                _reject_uncommitted_codex_review_prompt_contracts(args)
        elif args.entrypoint == "codex-readonly":
            _reject_codex_readonly_customizations(args)
        elif args.entrypoint == "codex-parallel":
            _reject_codex_parallel_customizations(args)
        (
            source_root,
            base_ref,
            head_ref,
            container_dir,
            workspace_root,
            created_workspace,
            cleanup_submodule_worktrees,
        ) = _prepare_workspace(args)

        if args.entrypoint == "codex-review" and not args.prepare_only:
            _reject_oversized_codex_review_builtin_scope(
                source_root=workspace_root,
                base_ref=base_ref,
                head_ref=head_ref,
                diff_file=None,
            )

        placeholders = _prepare_inputs(
            args,
            source_root=source_root,
            target_root=workspace_root,
            base_ref=base_ref,
            head_ref=head_ref,
        )
        prepared = {
            "args": args,
            "source_root": source_root,
            "base_ref": base_ref,
            "head_ref": head_ref,
            "container_dir": container_dir,
            "workspace_root": workspace_root,
            "created_workspace": created_workspace,
            "cleanup_submodule_worktrees": cleanup_submodule_worktrees,
            "placeholders": placeholders,
        }
        if args.prepare_only:
            prepared.update(
                {
                    "command": [],
                    "child_env": {},
                    "entrypoint_label": "prepare-only",
                    "final_path": None,
                    "stdin_bytes": None,
                    "prompt_delivery": "none",
                }
            )
            return prepared

        command, child_env, entrypoint_label, final_path, stdin_bytes, prompt_delivery = _build_child_process(
            args,
            source_root=source_root,
            base_ref=base_ref,
            head_ref=head_ref,
            container_dir=container_dir,
            workspace_root=workspace_root,
            placeholders=placeholders,
        )
        prepared.update(
            {
                "command": command,
                "child_env": child_env,
                "entrypoint_label": entrypoint_label,
                "final_path": final_path,
                "stdin_bytes": stdin_bytes,
                "prompt_delivery": prompt_delivery,
                "codex_model_fallback_enabled": _codex_model_fallback_enabled(
                    args,
                    entrypoint_label=entrypoint_label,
                ),
                "codex_primary_model": (
                    _option_value(command, "-m", "--model")
                    or args.codex_model
                ),
                "codex_fallback_model": args.codex_fallback_model,
                "codex_reasoning_effort": args.codex_reasoning_effort,
            }
        )
        return prepared
    except UserError as error:
        if source_root is None or workspace_root is None:
            raise
        cleanup_error = _cleanup_prepared_workspace(
            {
                "args": args,
                "source_root": source_root,
                "workspace_root": workspace_root,
                "created_workspace": created_workspace,
                "cleanup_submodule_worktrees": cleanup_submodule_worktrees,
            },
            child_returncode=1,
            cleanup_error=None,
            keep_prepare_only_workspace=False,
        )
        if cleanup_error is not None:
            raise UserError(f"{error}\n{cleanup_error}") from error
        raise


def _cleanup_prepared_workspace(
    prepared: dict[str, object],
    *,
    child_returncode: int,
    cleanup_error: UserError | None,
    preserve_container_dir: bool = False,
    keep_prepare_only_workspace: bool = True,
) -> UserError | None:
    args: argparse.Namespace = prepared["args"]  # type: ignore[assignment]
    keep_workspace = (
        (args.prepare_only and keep_prepare_only_workspace)
        or args.reuse_workspace is not None
        or args.keep_workspace
        or (child_returncode != 0 and args.keep_on_failure)
    )
    workspace_root = prepared["workspace_root"]
    if keep_workspace:
        print(f"kept isolated workspace at {workspace_root}", file=sys.stderr)
        return cleanup_error
    try:
        if prepared["created_workspace"] and pathlib.Path(str(workspace_root)).exists():
            _cleanup_worktree(
                pathlib.Path(str(prepared["source_root"])),
                pathlib.Path(str(workspace_root)),
                cleanup_submodule_worktrees=bool(prepared["cleanup_submodule_worktrees"]),
                preserve_container_dir=preserve_container_dir,
            )
    except UserError as error:
        return error
    return cleanup_error


def _read_binary_tail(path: pathlib.Path, *, max_bytes: int) -> bytes:
    with path.open("rb") as handle:
        handle.seek(0, os.SEEK_END)
        size = handle.tell()
        handle.seek(max(0, size - max_bytes), os.SEEK_SET)
        return handle.read(max_bytes)


def _codex_model_fallback_error(
    *,
    stdout_path: pathlib.Path,
    stderr_path: pathlib.Path,
    primary_model: str,
    fallback_model: str = CODEX_FALLBACK_MODEL_DEFAULT,
) -> bool:
    return _codex_model_fallback_error_output(
        stdout_tail=_read_binary_tail(
            stdout_path,
            max_bytes=CODEX_MODEL_FALLBACK_SCAN_BYTES,
        ),
        stderr_tail=_read_binary_tail(
            stderr_path,
            max_bytes=CODEX_MODEL_FALLBACK_SCAN_BYTES,
        ),
        primary_model=primary_model,
        fallback_model=fallback_model,
    )


def _codex_model_fallback_error_output(
    *,
    stdout_tail: bytes,
    stderr_tail: bytes,
    primary_model: str,
    fallback_model: str = CODEX_FALLBACK_MODEL_DEFAULT,
) -> bool:
    if _codex_model_fallback_error_text(
        stderr_tail=stderr_tail,
        primary_model=primary_model,
        fallback_model=fallback_model,
    ):
        return True
    for raw_line in stdout_tail.splitlines():
        try:
            event = json.loads(raw_line.decode("utf-8"))
        except (UnicodeDecodeError, json.JSONDecodeError):
            continue
        if not isinstance(event, dict):
            continue
        event_type = str(event.get("type") or "").lower()
        if event_type != "error" and not event_type.endswith(".failed"):
            continue
        event_text = json.dumps(
            event,
            ensure_ascii=False,
            sort_keys=True,
        ).encode("utf-8")
        if _codex_model_fallback_error_text(
            stderr_tail=event_text,
            primary_model=primary_model,
            fallback_model=fallback_model,
            require_error_prefix=False,
        ):
            return True
    return False


def _codex_model_fallback_error_text(
    *,
    stderr_tail: bytes,
    primary_model: str,
    fallback_model: str,
    require_error_prefix: bool = True,
) -> bool:
    text = stderr_tail.decode("utf-8", errors="replace").lower()
    primary_model_lower = primary_model.lower()
    fallback_model_lower = fallback_model.lower()
    primary_model_aliases = {
        primary_model_lower,
        primary_model_lower.rsplit("/", 1)[-1],
    }
    configured_model_aliases = {
        *primary_model_aliases,
        fallback_model_lower,
        fallback_model_lower.rsplit("/", 1)[-1],
    }
    for line in text.splitlines():
        if require_error_prefix and not CODEX_MODEL_FALLBACK_STDERR_PREFIX_PATTERN.match(
            line.lstrip()
        ):
            continue
        mentioned_models = {
            model_reference
            for pattern in CODEX_EXPLICIT_MODEL_REFERENCE_PATTERNS
            for match in pattern.finditer(line)
            for model_reference in (match.group("model").rstrip(".,;:!?"),)
            if model_reference in configured_model_aliases
            or (
                any(character.isalpha() for character in model_reference)
                and any(character.isdigit() for character in model_reference)
            )
            or any(character in "-./_" for character in model_reference)
        }
        if mentioned_models and mentioned_models.isdisjoint(primary_model_aliases):
            continue
        if any(
            fragment in line
            for fragment in CODEX_MODEL_FALLBACK_ERROR_FRAGMENTS
        ):
            return True
        if any(pattern.search(line) for pattern in CODEX_MODEL_FALLBACK_ERROR_PATTERNS):
            return True
    return False


def _replace_codex_model(
    command: list[str],
    *,
    primary_model: str,
    fallback_model: str,
) -> list[str]:
    result = list(command)
    for index, arg in enumerate(result):
        if arg in {"-m", "--model"} and index + 1 < len(result):
            if result[index + 1] == primary_model:
                result[index + 1] = fallback_model
                return result
        for option in ("-m", "--model"):
            prefix = f"{option}="
            if arg == f"{prefix}{primary_model}":
                result[index] = f"{prefix}{fallback_model}"
                return result
    raise UserError(
        "helper-managed Codex fallback could not locate the primary model in the child command"
    )


def _emit_binary_file(path: pathlib.Path, stream: object) -> None:
    binary_stream = getattr(stream, "buffer", None)
    if binary_stream is not None:
        with path.open("rb") as source:
            shutil.copyfileobj(source, binary_stream)
        binary_stream.flush()
        return
    text_stream = stream
    text_stream.write(path.read_text(encoding="utf-8", errors="replace"))
    text_stream.flush()


def _emit_binary_bytes(payload: bytes, stream: object) -> None:
    binary_stream = getattr(stream, "buffer", None)
    if binary_stream is not None:
        binary_stream.write(payload)
        binary_stream.flush()
        return
    text_stream = stream
    text_stream.write(payload.decode("utf-8", errors="replace"))
    text_stream.flush()


def _append_bounded_tail(buffer: bytearray, payload: bytes) -> None:
    buffer.extend(payload)
    overflow = len(buffer) - CODEX_MODEL_FALLBACK_SCAN_BYTES
    if overflow > 0:
        del buffer[:overflow]


def _run_streaming_codex_attempt(
    *,
    command: list[str],
    workspace_root: pathlib.Path,
    child_env: dict[str, str],
    stdin_bytes: bytes | None,
) -> tuple[int, bytes, bytes]:
    stdout_tail = bytearray()
    stderr_tail = bytearray()
    stop_pumps = threading.Event()

    def pump(
        source: BinaryIO,
        stream: object,
        tail: bytearray,
        eof_reached: threading.Event,
    ) -> None:
        stream_failed = False
        post_exit_bytes = 0

        def consume(payload: bytes) -> None:
            nonlocal stream_failed
            _append_bounded_tail(tail, payload)
            if stream_failed:
                return
            try:
                _emit_binary_bytes(payload, stream)
            except (BrokenPipeError, OSError, ValueError):
                stream_failed = True

        try:
            source_fd = source.fileno()
        except (AttributeError, OSError, ValueError):
            while True:
                payload = source.read(8192)
                if not payload:
                    eof_reached.set()
                    return
                consume(payload)

        while True:
            timeout = 0.0 if stop_pumps.is_set() else CODEX_STREAMING_PUMP_POLL_SECONDS
            try:
                readable, _, _ = select.select([source_fd], [], [], timeout)
            except (OSError, ValueError):
                return
            if not readable:
                if stop_pumps.is_set():
                    return
                continue
            try:
                payload = os.read(source_fd, 8192)
            except OSError:
                return
            if not payload:
                eof_reached.set()
                return
            consume(payload)
            if stop_pumps.is_set():
                post_exit_bytes += len(payload)
                if post_exit_bytes >= CODEX_STREAMING_POST_EXIT_DRAIN_BYTES:
                    return

    process: subprocess.Popen[bytes]

    def signal_process_group(sig: signal.Signals) -> None:
        process_pid = getattr(process, "pid", None)
        if os.name == "posix" and isinstance(process_pid, int):
            try:
                os.killpg(process_pid, sig)
                return
            except ProcessLookupError:
                return
        try:
            if sig == signal.SIGTERM:
                process.terminate()
            else:
                process.kill()
        except ProcessLookupError:
            pass

    class ForwardedSignal(BaseException):
        def __init__(self, signum: signal.Signals) -> None:
            super().__init__(int(signum))
            self.signum = signum

    def forward_signal(signum: int, _frame: object) -> None:
        forwarded = signal.Signals(signum)
        signal_process_group(forwarded)
        raise ForwardedSignal(forwarded)

    process = subprocess.Popen(
        command,
        cwd=str(workspace_root),
        env=child_env,
        stdin=subprocess.PIPE if stdin_bytes is not None else subprocess.DEVNULL,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        start_new_session=os.name == "posix",
    )
    previous_signal_handlers: dict[signal.Signals, object] = {}
    if os.name == "posix" and threading.current_thread() is threading.main_thread():
        forwarded_signals = [signal.SIGTERM]
        if hasattr(signal, "SIGHUP"):
            forwarded_signals.append(signal.SIGHUP)
        for forwarded in forwarded_signals:
            previous_signal_handlers[forwarded] = signal.getsignal(forwarded)
            signal.signal(forwarded, forward_signal)

    assert process.stdout is not None
    assert process.stderr is not None
    stdout_eof = threading.Event()
    stderr_eof = threading.Event()
    stdout_thread = threading.Thread(
        target=pump,
        args=(process.stdout, sys.stdout, stdout_tail, stdout_eof),
        daemon=True,
    )
    stderr_thread = threading.Thread(
        target=pump,
        args=(process.stderr, sys.stderr, stderr_tail, stderr_eof),
        daemon=True,
    )
    interrupted_by_signal: signal.Signals | None = None
    stdout_thread_started = False
    stderr_thread_started = False
    try:
        try:
            stdout_thread.start()
            stdout_thread_started = True
            stderr_thread.start()
            stderr_thread_started = True
            if process.stdin is not None:
                try:
                    process.stdin.write(stdin_bytes or b"")
                except BrokenPipeError:
                    pass
                finally:
                    try:
                        process.stdin.close()
                    except (BrokenPipeError, OSError, ValueError):
                        pass
            returncode = process.wait()
        except BaseException:
            if process.poll() is None:
                signal_process_group(signal.SIGTERM)
                try:
                    process.wait(timeout=CODEX_STREAMING_TERM_GRACE_SECONDS)
                except subprocess.TimeoutExpired:
                    signal_process_group(signal.SIGKILL)
                    process.wait()
            raise
        finally:
            stop_pumps.set()
            if stdout_thread_started:
                stdout_thread.join(timeout=CODEX_STREAMING_PUMP_JOIN_SECONDS)
            if stderr_thread_started:
                stderr_thread.join(timeout=CODEX_STREAMING_PUMP_JOIN_SECONDS)
            if not stdout_eof.is_set() or not stderr_eof.is_set():
                signal_process_group(signal.SIGTERM)
            for source in (process.stdout, process.stderr):
                try:
                    source.close()
                except (OSError, ValueError):
                    pass
            if stdout_thread_started:
                stdout_thread.join(timeout=CODEX_STREAMING_PUMP_JOIN_SECONDS)
            if stderr_thread_started:
                stderr_thread.join(timeout=CODEX_STREAMING_PUMP_JOIN_SECONDS)
    except ForwardedSignal as exc:
        interrupted_by_signal = exc.signum
    finally:
        for forwarded, previous_handler in previous_signal_handlers.items():
            signal.signal(forwarded, previous_handler)
    if interrupted_by_signal is not None:
        raise SystemExit(128 + int(interrupted_by_signal))
    if (
        (stdout_thread_started and stdout_thread.is_alive())
        or (stderr_thread_started and stderr_thread.is_alive())
    ):
        raise UserError("streaming Codex output pump did not stop within the bounded timeout")
    return returncode, bytes(stdout_tail), bytes(stderr_tail)


def _run_captured_codex_attempt(
    *,
    command: list[str],
    workspace_root: pathlib.Path,
    child_env: dict[str, str],
    stdin_bytes: bytes | None,
    container_dir: pathlib.Path,
    attempt: str,
) -> tuple[subprocess.CompletedProcess[bytes], pathlib.Path, pathlib.Path]:
    stdout_path = container_dir / f"codex-{attempt}.stdout"
    stderr_path = container_dir / f"codex-{attempt}.stderr"
    with stdout_path.open("wb") as stdout_handle, stderr_path.open("wb") as stderr_handle:
        completed = subprocess.run(
            command,
            cwd=str(workspace_root),
            env=child_env,
            input=stdin_bytes,
            stdout=stdout_handle,
            stderr=stderr_handle,
            check=False,
        )
    return completed, stdout_path, stderr_path


def _run_prepared_review(prepared: dict[str, object]) -> int:
    args: argparse.Namespace = prepared["args"]  # type: ignore[assignment]
    placeholders = prepared["placeholders"]
    command = prepared["command"]
    workspace_root = prepared["workspace_root"]
    child_env = prepared["child_env"]
    entrypoint_label = str(prepared.get("entrypoint_label") or "")
    child_returncode = 1
    cleanup_error: UserError | None = None
    try:
        if args.prepare_only:
            print(workspace_root)
            return 0

        if args.verbose:
            print(f"workspace={workspace_root}", file=sys.stderr)
            print(f"entrypoint={prepared['entrypoint_label']}", file=sys.stderr)
            if placeholders["{review_range}"] is not None:
                print(f"review_range={placeholders['{review_range}']}", file=sys.stderr)
            print(f"command={' '.join(command)}", file=sys.stderr)

        fallback_enabled = bool(prepared.get("codex_model_fallback_enabled"))
        if fallback_enabled:
            primary_model = str(prepared["codex_primary_model"])
            fallback_model = str(prepared["codex_fallback_model"])
            reasoning_effort = str(prepared["codex_reasoning_effort"])
            if entrypoint_label == "codex-review":
                (
                    child_returncode,
                    _stdout_tail,
                    stderr_tail,
                ) = _run_streaming_codex_attempt(
                    command=command,
                    workspace_root=pathlib.Path(str(workspace_root)),
                    child_env=child_env,
                    stdin_bytes=prepared["stdin_bytes"],
                )
                should_fallback = (
                    child_returncode != 0
                    and _codex_model_fallback_error_output(
                        stdout_tail=_stdout_tail,
                        stderr_tail=stderr_tail,
                        primary_model=primary_model,
                        fallback_model=fallback_model,
                    )
                )
            else:
                completed, stdout_path, stderr_path = _run_captured_codex_attempt(
                    command=command,
                    workspace_root=pathlib.Path(str(workspace_root)),
                    child_env=child_env,
                    stdin_bytes=prepared["stdin_bytes"],
                    container_dir=pathlib.Path(str(prepared["container_dir"])),
                    attempt="primary",
                )
                child_returncode = completed.returncode
                should_fallback = (
                    child_returncode != 0
                    and _codex_model_fallback_error(
                        stdout_path=stdout_path,
                        stderr_path=stderr_path,
                        primary_model=primary_model,
                        fallback_model=fallback_model,
                    )
                )
                if child_returncode != 0 and not should_fallback:
                    _emit_binary_file(stdout_path, sys.stdout)
                if child_returncode != 0:
                    _emit_binary_file(stderr_path, sys.stderr)
            if should_fallback:
                print(
                    "codex model fallback: "
                    f"{primary_model} -> {fallback_model} "
                    f"(reasoning {reasoning_effort})",
                    file=sys.stderr,
                )
                final_path_raw = prepared.get("final_path")
                if final_path_raw is not None:
                    pathlib.Path(str(final_path_raw)).unlink(missing_ok=True)
                fallback_command = _replace_codex_model(
                    command,
                    primary_model=primary_model,
                    fallback_model=fallback_model,
                )
                if entrypoint_label == "codex-review":
                    (
                        child_returncode,
                        _stdout_tail,
                        _stderr_tail,
                    ) = _run_streaming_codex_attempt(
                        command=fallback_command,
                        workspace_root=pathlib.Path(str(workspace_root)),
                        child_env=child_env,
                        stdin_bytes=prepared["stdin_bytes"],
                    )
                else:
                    completed, stdout_path, stderr_path = _run_captured_codex_attempt(
                        command=fallback_command,
                        workspace_root=pathlib.Path(str(workspace_root)),
                        child_env=child_env,
                        stdin_bytes=prepared["stdin_bytes"],
                        container_dir=pathlib.Path(str(prepared["container_dir"])),
                        attempt="fallback",
                    )
                    child_returncode = completed.returncode
                    if child_returncode != 0:
                        _emit_binary_file(stdout_path, sys.stdout)
                        _emit_binary_file(stderr_path, sys.stderr)
        else:
            capture_child_output = entrypoint_label == "codex-readonly"
            completed = subprocess.run(
                command,
                cwd=str(workspace_root),
                env=child_env,
                input=prepared["stdin_bytes"],
                stdout=subprocess.PIPE if capture_child_output else None,
                stderr=subprocess.PIPE if capture_child_output else None,
                check=False,
            )
            child_returncode = completed.returncode
            if capture_child_output and child_returncode != 0:
                if completed.stdout:
                    sys.stdout.write(completed.stdout.decode("utf-8", errors="replace"))
                if completed.stderr:
                    sys.stderr.write(completed.stderr.decode("utf-8", errors="replace"))
        if child_returncode == 0 and entrypoint_label == "codex-readonly":
            final_path = pathlib.Path(str(prepared["final_path"]))
            if not final_path.is_file():
                raise UserError(
                    f"codex-readonly did not produce a final reviewer message: {final_path}"
                )
            sys.stdout.write(
                _normalize_codex_readonly_final_text(
                    final_path.read_text(encoding="utf-8")
                )
            )
    except UserError as error:
        print(str(error), file=sys.stderr)
        child_returncode = 1
    finally:
        cleanup_error = _cleanup_prepared_workspace(
            prepared,
            child_returncode=child_returncode,
            cleanup_error=cleanup_error,
        )

    if cleanup_error is not None:
        print(str(cleanup_error), file=sys.stderr)
        return child_returncode if child_returncode != 0 else 1
    return child_returncode


def _write_runner_terminal_state_unlocked(
    exit_code_path: pathlib.Path,
    *,
    exit_code: int,
    pid_path: pathlib.Path | None = None,
) -> None:
    exit_code_path.parent.mkdir(parents=True, exist_ok=True)
    exit_code_path.write_text(f"{exit_code}\n", encoding="utf-8")
    if pid_path is not None and pid_path.is_file():
        pid_path.unlink()


def _write_runner_terminal_state(
    lock_path: pathlib.Path,
    exit_code_path: pathlib.Path,
    *,
    exit_code: int,
    pid_path: pathlib.Path | None = None,
) -> None:
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a+b") as lock_handle:
        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX)
        _write_runner_terminal_state_unlocked(
            exit_code_path,
            exit_code=exit_code,
            pid_path=pid_path,
        )


def _start_prepared_review(prepared: dict[str, object]) -> int:
    args: argparse.Namespace = prepared["args"]  # type: ignore[assignment]
    if args.prepare_only:
        raise UserError("`start` does not support --prepare-only")

    state_dir = pathlib.Path(str(prepared["container_dir"]))
    stdout_path = state_dir / "stdout.log"
    stderr_path = state_dir / "stderr.log"
    exit_code_path = state_dir / "exit_code"
    pid_path = state_dir / "pid"
    lock_path = state_dir / "runner.lock"
    spec_path = state_dir / "runner-spec.json"
    launcher_log_path = state_dir / "launcher.log"
    model_fallback_path = state_dir / "model-fallback.json"
    stdin_path: pathlib.Path | None = None
    stdin_bytes = prepared["stdin_bytes"]
    _reset_stateful_artifacts(
        state_dir,
        workspace_root=pathlib.Path(str(prepared["workspace_root"])),
        current_final_path=(
            pathlib.Path(str(prepared["final_path"]))
            if prepared["final_path"] is not None
            else None
        ),
        current_report_path=(
            pathlib.Path(str(prepared["placeholders"]["{report_file}"]))
            if prepared["placeholders"]["{report_file}"] is not None
            else None
        ),
    )
    if stdin_bytes is not None:
        stdin_path = state_dir / "stdin.txt"
        stdin_path.write_bytes(stdin_bytes)
    env_overrides = {
        key: value
        for key, value in dict(prepared["child_env"]).items()
        if os.environ.get(key) != value
    }

    runner_spec = {
        "command": prepared["command"],
        "cwd": str(prepared["workspace_root"]),
        "env_overrides": env_overrides,
        "stdout_path": str(stdout_path),
        "stderr_path": str(stderr_path),
        "exit_code_path": str(exit_code_path),
        "pid_path": str(pid_path),
        "stdin_path": str(stdin_path) if stdin_path is not None else None,
        "codex_model_fallback_enabled": bool(
            prepared.get("codex_model_fallback_enabled")
        ),
        "codex_primary_model": prepared.get("codex_primary_model"),
        "codex_fallback_model": prepared.get("codex_fallback_model"),
        "codex_reasoning_effort": prepared.get("codex_reasoning_effort"),
        "final_path": (
            str(prepared["final_path"])
            if prepared.get("final_path") is not None
            else None
        ),
        "model_fallback_path": str(model_fallback_path),
    }
    _write_json(spec_path, runner_spec)
    spec_sha256 = hashlib.sha256(spec_path.read_bytes()).hexdigest()

    state = {
        "source_root": str(prepared["source_root"]),
        "workspace_root": str(prepared["workspace_root"]),
        "entrypoint": prepared["entrypoint_label"],
        "lane": args.lane,
        "base_ref": prepared["base_ref"],
        "head_ref": prepared["head_ref"],
        "review_range": prepared["placeholders"]["{review_range}"],
        "diff_file": prepared["placeholders"].get("{diff_file}"),
        "report_file": prepared["placeholders"]["{report_file}"],
        "final_path": str(prepared["final_path"]) if prepared["final_path"] is not None else None,
        "prompt_delivery": prepared["prompt_delivery"],
        "reuse_workspace": args.reuse_workspace,
        "keep_workspace": args.keep_workspace,
        "keep_on_failure": args.keep_on_failure,
        "cleanup_submodule_worktrees": bool(prepared["cleanup_submodule_worktrees"]),
        "workspace_cleaned": False,
        "stdout_path": str(stdout_path),
        "stderr_path": str(stderr_path),
        "exit_code_path": str(exit_code_path),
        "pid_path": str(pid_path),
        "lock_path": str(lock_path),
        "runner_spec_path": str(spec_path),
        "model_fallback_path": str(model_fallback_path),
        "codex_primary_model": prepared.get("codex_primary_model"),
        "codex_fallback_model": prepared.get("codex_fallback_model"),
        "codex_reasoning_effort": prepared.get("codex_reasoning_effort"),
        "started_at": time.time(),
    }
    if prepared["entrypoint_label"] in {"codex-review", "codex-readonly"}:
        policy_loader = (
            _maybe_populate_codex_review_timeout_policy
            if prepared["entrypoint_label"] == "codex-review"
            else _maybe_populate_codex_readonly_timeout_policy
        )
        policy_loader(
            state_dir,
            state,
            repo_root=pathlib.Path(str(prepared["workspace_root"])),
        )
        state = _load_state(state_dir)
    _save_state(state_dir, state)

    runner_cmd = [
        sys.executable,
        str(pathlib.Path(__file__).resolve()),
        "__run-child",
        str(spec_path),
        spec_sha256,
    ]
    runner_env = (
        _build_stateful_runner_env(dict(prepared["child_env"]))
        if prepared["entrypoint_label"] in {"codex-review", "codex-readonly"}
        else dict(prepared["child_env"])
    )
    with launcher_log_path.open("wb") as launcher_log:
        process = subprocess.Popen(
            runner_cmd,
            cwd=str(state_dir),
            env=runner_env,
            stdin=subprocess.DEVNULL,
            stdout=launcher_log,
            stderr=launcher_log,
            start_new_session=True,
        )
    if process.poll() is not None:
        _write_runner_terminal_state(
            lock_path,
            exit_code_path,
            exit_code=process.returncode,
            pid_path=pid_path,
        )
    print(state_dir)
    return 0


def _run_child_from_spec(spec_path: pathlib.Path, *, expected_sha256: str) -> int:
    exit_code = 1
    exit_code_path = spec_path.parent / "exit_code"
    stderr_path = spec_path.parent / "stderr.log"
    pid_path = spec_path.parent / "pid"
    lock_path = spec_path.parent / "runner.lock"
    try:
        spec_bytes = spec_path.read_bytes()
        actual_sha256 = hashlib.sha256(spec_bytes).hexdigest()
        if actual_sha256 != expected_sha256:
            raise UserError(f"runner spec hash mismatch: {spec_path}")
        try:
            spec = json.loads(spec_bytes.decode("utf-8"))
        except json.JSONDecodeError as error:
            raise UserError(f"invalid JSON file: {spec_path}") from error
        if not isinstance(spec, dict):
            raise UserError(f"invalid runner spec format: {spec_path}")
        exit_code_path = pathlib.Path(str(spec.get("exit_code_path", exit_code_path)))
        stderr_path = pathlib.Path(str(spec.get("stderr_path", stderr_path)))
        stdout_path = pathlib.Path(str(spec["stdout_path"]))
        pid_path = pathlib.Path(str(spec["pid_path"]))
        lock_path = pathlib.Path(str(spec.get("lock_path", lock_path)))
        stdout_path.parent.mkdir(parents=True, exist_ok=True)
        stderr_path.parent.mkdir(parents=True, exist_ok=True)
        lock_path.parent.mkdir(parents=True, exist_ok=True)
        with lock_path.open("a+b") as lock_handle:
            fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX)
            pid_path.write_text(f"{os.getpid()}\n", encoding="utf-8")
            try:
                stdin_bytes = None
                stdin_path = spec.get("stdin_path")
                if stdin_path:
                    stdin_bytes = pathlib.Path(str(stdin_path)).read_bytes()

                child_env = os.environ.copy()
                if "env" in spec:
                    child_env = {
                        str(key): str(value) for key, value in dict(spec["env"]).items()
                    }
                else:
                    child_env.update(
                        {
                            str(key): str(value)
                            for key, value in dict(spec.get("env_overrides", {})).items()
                        }
                    )

                with stdout_path.open("wb") as stdout_handle, stderr_path.open("wb") as stderr_handle:
                    try:
                        exit_code = subprocess.run(
                            list(spec["command"]),
                            cwd=str(spec["cwd"]),
                            env=child_env,
                            input=stdin_bytes,
                            stdout=stdout_handle,
                            stderr=stderr_handle,
                            check=False,
                        ).returncode
                        stdout_handle.flush()
                        stderr_handle.flush()
                        fallback_enabled = bool(
                            spec.get("codex_model_fallback_enabled")
                        )
                        primary_model = str(spec.get("codex_primary_model") or "")
                        fallback_model = str(spec.get("codex_fallback_model") or "")
                        if (
                            fallback_enabled
                            and exit_code != 0
                            and _codex_model_fallback_error(
                                stdout_path=stdout_path,
                                stderr_path=stderr_path,
                                primary_model=primary_model,
                                fallback_model=fallback_model,
                            )
                        ):
                            reasoning_effort = str(
                                spec.get("codex_reasoning_effort") or ""
                            )
                            stderr_handle.write(
                                (
                                    "codex model fallback: "
                                    f"{primary_model} -> {fallback_model} "
                                    f"(reasoning {reasoning_effort})\n"
                                ).encode("utf-8")
                            )
                            stderr_handle.flush()
                            model_fallback_path_raw = spec.get(
                                "model_fallback_path"
                            )
                            if model_fallback_path_raw:
                                _write_json(
                                    pathlib.Path(str(model_fallback_path_raw)),
                                    {
                                        "primary_model": primary_model,
                                        "fallback_model": fallback_model,
                                        "reasoning_effort": reasoning_effort,
                                    },
                                )
                            final_path_raw = spec.get("final_path")
                            if final_path_raw:
                                pathlib.Path(str(final_path_raw)).unlink(
                                    missing_ok=True
                                )
                            fallback_command = _replace_codex_model(
                                list(spec["command"]),
                                primary_model=primary_model,
                                fallback_model=fallback_model,
                            )
                            exit_code = subprocess.run(
                                fallback_command,
                                cwd=str(spec["cwd"]),
                                env=child_env,
                                input=stdin_bytes,
                                stdout=stdout_handle,
                                stderr=stderr_handle,
                                check=False,
                            ).returncode
                    except Exception as error:  # pragma: no cover - defensive crash path
                        stderr_handle.write(
                            f"runner failed: {error}\n".encode("utf-8", errors="replace")
                        )
                        exit_code = 1
            finally:
                _write_runner_terminal_state_unlocked(
                    exit_code_path,
                    exit_code=exit_code,
                    pid_path=pid_path,
                )
    except Exception as error:  # pragma: no cover - defensive crash path
        stderr_path.parent.mkdir(parents=True, exist_ok=True)
        with stderr_path.open("ab") as stderr_handle:
            stderr_handle.write(
                f"runner bootstrap failed: {error}\n".encode("utf-8", errors="replace")
            )
        exit_code = 1
        _write_runner_terminal_state(
            lock_path,
            exit_code_path,
            exit_code=exit_code,
            pid_path=pid_path,
        )
    return exit_code


def _state_kind(state: dict[str, object]) -> str:
    raw_kind = state.get("state_kind")
    if not isinstance(raw_kind, str) or not raw_kind:
        return "single"
    return raw_kind


def _parallel_child_state_dir(
    state: dict[str, object],
    lane_name: str,
) -> pathlib.Path | None:
    child_states = state.get("child_states")
    if not isinstance(child_states, dict):
        return None
    child_state_dir = child_states.get(lane_name)
    if not isinstance(child_state_dir, str) or not child_state_dir:
        return None
    resolved_child_state_dir = pathlib.Path(child_state_dir).resolve(strict=False)
    source_root_raw = state.get("source_root")
    if isinstance(source_root_raw, str) and source_root_raw:
        allowed_root = pathlib.Path(source_root_raw).resolve(strict=False) / ".codex-tmp"
        if not _is_relative_to(resolved_child_state_dir, allowed_root):
            raise UserError(
                "parallel child state_dir must live under the source repo's .codex-tmp directory: "
                f"{resolved_child_state_dir}"
            )
    return resolved_child_state_dir


def _parallel_child_summary(
    *,
    child_state_dir: pathlib.Path,
    cleanup_terminal: bool,
) -> tuple[dict[str, object], dict[str, object]]:
    child_state = _load_state(child_state_dir)
    summary = _state_summary(child_state_dir, child_state)
    if cleanup_terminal and summary["exit_code"] is not None:
        cleanup_error: UserError | None = None
        try:
            _maybe_cleanup_stateful_workspace(
                child_state_dir,
                child_state,
                exit_code=int(summary["exit_code"]),
            )
        except UserError as error:
            cleanup_error = error
        if cleanup_error is not None:
            summary = dict(summary)
            summary["cleanup_error"] = str(cleanup_error)
        else:
            child_state = _load_state(child_state_dir)
            summary = _state_summary(child_state_dir, child_state)
    return child_state, summary


def _append_stateful_stderr_note(stderr_path: pathlib.Path, message: str) -> None:
    stderr_path.parent.mkdir(parents=True, exist_ok=True)
    with stderr_path.open("ab") as handle:
        handle.write((message.rstrip() + "\n").encode("utf-8", errors="replace"))


def _force_stateful_terminal_exit(
    child_state_dir: pathlib.Path,
    child_state: dict[str, object],
    *,
    exit_code: int,
    stderr_note: str | None = None,
) -> None:
    stderr_path = pathlib.Path(str(_require_state_field(child_state, "stderr_path")))
    if stderr_note:
        _append_stateful_stderr_note(stderr_path, stderr_note)
    lock_path = pathlib.Path(
        str(child_state.get("lock_path", child_state_dir / "runner.lock"))
    )
    exit_code_path = pathlib.Path(str(_require_state_field(child_state, "exit_code_path")))
    pid_path = pathlib.Path(str(_require_state_field(child_state, "pid_path")))
    _write_runner_terminal_state(
        lock_path,
        exit_code_path,
        exit_code=exit_code,
        pid_path=pid_path,
    )


def _stateful_runner_running(
    state_dir: pathlib.Path,
    state: dict[str, object],
) -> tuple[bool, int | None]:
    pid_path = pathlib.Path(str(_require_state_field(state, "pid_path")))
    exit_code_path = pathlib.Path(str(_require_state_field(state, "exit_code_path")))
    if _read_exit_code(exit_code_path) is not None:
        return False, _read_pid(pid_path)
    lock_path = pathlib.Path(str(state.get("lock_path", state_dir / "runner.lock")))
    pid = _read_pid(pid_path)
    launch_pending = _state_launch_pending(
        state_dir,
        state,
        pid=pid,
        exit_code=None,
    )
    return _state_lock_is_held(lock_path) or launch_pending, pid


def _maybe_finalize_timed_out_stateful_review(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    timeout_message: str,
) -> bool:
    exit_code_path = pathlib.Path(str(_require_state_field(state, "exit_code_path")))
    if _read_exit_code(exit_code_path) is not None:
        return True
    running, _ = _stateful_runner_running(state_dir, state)
    if running:
        return False
    _force_stateful_terminal_exit(
        state_dir,
        state,
        exit_code=CODEX_PARALLEL_AGENTIC_TIMEOUT_EXIT_CODE,
        stderr_note=timeout_message,
    )
    return True


def _settle_timed_out_stateful_review(
    state_dir: pathlib.Path,
    *,
    timeout_message: str,
    deadline: float,
) -> bool:
    while True:
        state = _load_state(state_dir)
        if _maybe_finalize_timed_out_stateful_review(
            state_dir,
            state,
            timeout_message=timeout_message,
        ):
            return True
        if time.time() >= deadline:
            return False
        time.sleep(min(WAIT_POLL_INTERVAL_SECONDS, 0.1))


def _terminate_parallel_runner_process_group(pid: int, *, sig: signal.Signals) -> None:
    try:
        os.killpg(pid, sig)
    except ProcessLookupError:
        return


def _stateful_output_snapshot(state: dict[str, object]) -> dict[str, int]:
    snapshot: dict[str, int] = {}
    for label in ("stdout", "stderr"):
        path = pathlib.Path(str(_require_state_field(state, f"{label}_path")))
        try:
            stat_result = path.stat()
        except OSError:
            snapshot[f"{label}_size"] = 0
            snapshot[f"{label}_mtime_ns"] = 0
            continue
        snapshot[f"{label}_size"] = int(stat_result.st_size)
        snapshot[f"{label}_mtime_ns"] = int(stat_result.st_mtime_ns)
    return snapshot


def _stateful_output_activity_at(snapshot: dict[str, int]) -> float | None:
    output_mtime_ns = max(
        (
            snapshot.get(f"{label}_mtime_ns", 0)
            for label in ("stdout", "stderr")
            if snapshot.get(f"{label}_size", 0) > 0
        ),
        default=0,
    )
    if output_mtime_ns <= 0:
        return None
    return output_mtime_ns / 1_000_000_000.0


def _track_stateful_output_activity(
    state_dir: pathlib.Path,
    state: dict[str, object],
    observed_state: dict[str, object],
    *,
    snapshot_key: str,
    last_output_key: str,
) -> None:
    snapshot = _stateful_output_snapshot(observed_state)
    output_activity_at = _stateful_output_activity_at(snapshot)
    previous_snapshot = state.get(snapshot_key)
    changed = False
    if previous_snapshot != snapshot:
        state[snapshot_key] = snapshot
        changed = True
    previous_output_at = state.get(last_output_key)
    if output_activity_at is not None and (
        previous_output_at is None or output_activity_at > float(previous_output_at)
    ):
        state[last_output_key] = output_activity_at
        changed = True
    if changed:
        _save_state(state_dir, state)


def _track_parallel_agentic_output_activity(
    state_dir: pathlib.Path,
    state: dict[str, object],
    child_state: dict[str, object],
) -> None:
    _track_stateful_output_activity(
        state_dir,
        state,
        child_state,
        snapshot_key="agentic_output_snapshot",
        last_output_key="agentic_last_output_at",
    )


def _maybe_enforce_stateful_codex_review_timeout(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    settle_timeout: bool = False,
) -> None:
    _maybe_enforce_stateful_codex_timeout(
        state_dir,
        state,
        entrypoint="codex-review",
        settle_timeout=settle_timeout,
    )


def _maybe_enforce_stateful_codex_readonly_timeout(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    settle_timeout: bool = False,
) -> None:
    _maybe_enforce_stateful_codex_timeout(
        state_dir,
        state,
        entrypoint="codex-readonly",
        settle_timeout=settle_timeout,
    )


def _maybe_enforce_stateful_codex_timeout(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    entrypoint: str,
    settle_timeout: bool = False,
) -> None:
    if str(state.get("entrypoint") or "") != entrypoint:
        return

    keys = _stateful_codex_timeout_keys(entrypoint)
    _maybe_populate_stateful_codex_timeout_policy(
        state_dir,
        state,
        entrypoint=entrypoint,
    )
    state = _load_state(state_dir)

    exit_code_path = pathlib.Path(str(_require_state_field(state, "exit_code_path")))
    if _read_exit_code(exit_code_path) is not None:
        return

    _track_stateful_output_activity(
        state_dir,
        state,
        state,
        snapshot_key=keys["output_snapshot"],
        last_output_key=keys["last_output_at"],
    )
    state = _load_state(state_dir)

    started_at_raw = state.get("started_at")
    try:
        started_at = float(started_at_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        return

    timeout_budget_raw = state.get(
        keys["budget"],
        CODEX_PARALLEL_AGENTIC_TIMEOUT_SECONDS,
    )
    initial_quiet_raw = state.get(
        keys["initial_quiet"],
        CODEX_PARALLEL_AGENTIC_INITIAL_QUIET_SECONDS,
    )
    progress_lease_raw = state.get(
        keys["progress_lease"],
        CODEX_PARALLEL_AGENTIC_PROGRESS_LEASE_SECONDS,
    )
    try:
        timeout_budget_seconds = float(timeout_budget_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        timeout_budget_seconds = CODEX_PARALLEL_AGENTIC_TIMEOUT_SECONDS
    try:
        initial_quiet_seconds = float(initial_quiet_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        initial_quiet_seconds = CODEX_PARALLEL_AGENTIC_INITIAL_QUIET_SECONDS
    try:
        progress_lease_seconds = float(progress_lease_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        progress_lease_seconds = CODEX_PARALLEL_AGENTIC_PROGRESS_LEASE_SECONDS

    now = time.time()
    elapsed = now - started_at
    term_sent_at_raw = state.get(keys["term_sent_at"])
    kill_sent_at_raw = state.get(keys["kill_sent_at"])
    last_output_at_raw = state.get(keys["last_output_at"])
    term_sent_at = (
        float(term_sent_at_raw)
        if isinstance(term_sent_at_raw, (float, int))
        else None
    )
    kill_sent_at = (
        float(kill_sent_at_raw)
        if isinstance(kill_sent_at_raw, (float, int))
        else None
    )
    last_output_at = (
        float(last_output_at_raw)
        if isinstance(last_output_at_raw, (float, int))
        else None
    )

    timeout_message: str | None = None
    if elapsed >= timeout_budget_seconds:
        timeout_message = (
            f"helper terminated {entrypoint} after "
            f"{int(timeout_budget_seconds)}s total budget "
            "without a clean runner exit code"
        )
    elif last_output_at is None:
        if elapsed < initial_quiet_seconds:
            return
        timeout_message = (
            f"helper terminated {entrypoint} after "
            f"{int(initial_quiet_seconds)}s without reviewer output"
        )
    elif (now - last_output_at) < progress_lease_seconds:
        return
    else:
        timeout_message = (
            f"helper terminated {entrypoint} after "
            f"{int(progress_lease_seconds)}s without new reviewer output"
        )

    running, pid = _stateful_runner_running(state_dir, state)
    if not running and term_sent_at is not None:
        _maybe_finalize_timed_out_stateful_review(
            state_dir,
            state,
            timeout_message=timeout_message,
        )
        return

    if not running:
        state[keys["timed_out"]] = True
        if term_sent_at is None:
            state[keys["term_sent_at"]] = time.time()
        _save_state(state_dir, state)
        _maybe_finalize_timed_out_stateful_review(
            state_dir,
            state,
            timeout_message=timeout_message,
        )
        return

    if not isinstance(pid, int):
        return

    if term_sent_at is None:
        _terminate_parallel_runner_process_group(pid, sig=signal.SIGTERM)
        state[keys["timed_out"]] = True
        state[keys["term_sent_at"]] = time.time()
        _save_state(state_dir, state)
        if _maybe_finalize_timed_out_stateful_review(
            state_dir,
            state,
            timeout_message=timeout_message,
        ):
            return
        if not settle_timeout:
            return
        state = _load_state(state_dir)
        term_sent_at_raw = state.get(keys["term_sent_at"])
        term_sent_at = (
            float(term_sent_at_raw)
            if isinstance(term_sent_at_raw, (float, int))
            else time.time()
        )
        if _settle_timed_out_stateful_review(
            state_dir,
            timeout_message=timeout_message,
            deadline=term_sent_at + CODEX_PARALLEL_AGENTIC_TERM_GRACE_SECONDS,
        ):
            return
        state = _load_state(state_dir)
        running, pid = _stateful_runner_running(state_dir, state)
        kill_sent_at_raw = state.get(keys["kill_sent_at"])
        kill_sent_at = (
            float(kill_sent_at_raw)
            if isinstance(kill_sent_at_raw, (float, int))
            else None
        )
        if isinstance(pid, int) and running and kill_sent_at is None:
            _terminate_parallel_runner_process_group(pid, sig=signal.SIGKILL)
            state[keys["kill_sent_at"]] = time.time()
            _save_state(state_dir, state)
        _settle_timed_out_stateful_review(
            state_dir,
            timeout_message=timeout_message,
            deadline=time.time() + 1.0,
        )
        return

    if kill_sent_at is None and (time.time() - term_sent_at) >= CODEX_PARALLEL_AGENTIC_TERM_GRACE_SECONDS:
        _terminate_parallel_runner_process_group(pid, sig=signal.SIGKILL)
        state[keys["kill_sent_at"]] = time.time()
        _save_state(state_dir, state)
        _maybe_finalize_timed_out_stateful_review(
            state_dir,
            state,
            timeout_message=timeout_message,
        )
        return

    if settle_timeout and kill_sent_at is not None:
        _settle_timed_out_stateful_review(
            state_dir,
            timeout_message=timeout_message,
            deadline=time.time() + 1.0,
        )


def _maybe_enforce_parallel_agentic_timeout(
    state_dir: pathlib.Path,
    state: dict[str, object],
) -> None:
    agentic_state_dir = _parallel_child_state_dir(state, "agentic")
    if agentic_state_dir is None:
        return

    child_state, summary = _parallel_child_summary(
        child_state_dir=agentic_state_dir,
        cleanup_terminal=False,
    )
    if summary["exit_code"] is not None:
        return
    _track_parallel_agentic_output_activity(state_dir, state, child_state)

    started_at_raw = child_state.get("started_at")
    try:
        started_at = float(started_at_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        return

    timeout_budget_raw = state.get(
        "agentic_timeout_budget_seconds",
        CODEX_PARALLEL_AGENTIC_TIMEOUT_SECONDS,
    )
    initial_quiet_raw = state.get(
        "agentic_initial_quiet_seconds",
        CODEX_PARALLEL_AGENTIC_INITIAL_QUIET_SECONDS,
    )
    progress_lease_raw = state.get(
        "agentic_progress_lease_seconds",
        CODEX_PARALLEL_AGENTIC_PROGRESS_LEASE_SECONDS,
    )
    try:
        timeout_budget_seconds = float(timeout_budget_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        timeout_budget_seconds = CODEX_PARALLEL_AGENTIC_TIMEOUT_SECONDS
    try:
        initial_quiet_seconds = float(initial_quiet_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        initial_quiet_seconds = CODEX_PARALLEL_AGENTIC_INITIAL_QUIET_SECONDS
    try:
        progress_lease_seconds = float(progress_lease_raw)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        progress_lease_seconds = CODEX_PARALLEL_AGENTIC_PROGRESS_LEASE_SECONDS

    now = time.time()
    elapsed = now - started_at
    term_sent_at_raw = state.get("agentic_term_sent_at")
    kill_sent_at_raw = state.get("agentic_kill_sent_at")
    last_output_at_raw = state.get("agentic_last_output_at")
    term_sent_at = (
        float(term_sent_at_raw)
        if isinstance(term_sent_at_raw, (float, int))
        else None
    )
    kill_sent_at = (
        float(kill_sent_at_raw)
        if isinstance(kill_sent_at_raw, (float, int))
        else None
    )
    last_output_at = (
        float(last_output_at_raw)
        if isinstance(last_output_at_raw, (float, int))
        else None
    )

    timeout_message: str | None = None
    if elapsed >= timeout_budget_seconds:
        timeout_message = (
            "helper terminated the agentic lane after "
            f"{int(timeout_budget_seconds)}s total budget "
            "without a clean runner exit code"
        )
    elif last_output_at is None:
        if elapsed < initial_quiet_seconds:
            return
        timeout_message = (
            "helper terminated the agentic lane after "
            f"{int(initial_quiet_seconds)}s without reviewer output"
        )
    elif (now - last_output_at) < progress_lease_seconds:
        return
    else:
        timeout_message = (
            "helper terminated the agentic lane after "
            f"{int(progress_lease_seconds)}s without new reviewer output"
        )
    if not bool(summary["running"]) and term_sent_at is not None:
        _force_stateful_terminal_exit(
            agentic_state_dir,
            child_state,
            exit_code=CODEX_PARALLEL_AGENTIC_TIMEOUT_EXIT_CODE,
            stderr_note=timeout_message,
        )
        return

    if not bool(summary["running"]):
        state["agentic_timed_out"] = True
        if term_sent_at is None:
            state["agentic_term_sent_at"] = time.time()
        _save_state(state_dir, state)
        _force_stateful_terminal_exit(
            agentic_state_dir,
            child_state,
            exit_code=CODEX_PARALLEL_AGENTIC_TIMEOUT_EXIT_CODE,
            stderr_note=timeout_message,
        )
        return

    pid = summary["pid"]
    if not isinstance(pid, int):
        return

    if term_sent_at is None:
        _terminate_parallel_runner_process_group(pid, sig=signal.SIGTERM)
        state["agentic_timed_out"] = True
        state["agentic_term_sent_at"] = time.time()
        _save_state(state_dir, state)
        return

    if kill_sent_at is None and (time.time() - term_sent_at) >= CODEX_PARALLEL_AGENTIC_TERM_GRACE_SECONDS:
        _terminate_parallel_runner_process_group(pid, sig=signal.SIGKILL)
        state["agentic_kill_sent_at"] = time.time()
        _save_state(state_dir, state)


def _maybe_abort_parallel_agentic_after_primary_failure(
    state_dir: pathlib.Path,
    state: dict[str, object],
) -> None:
    # Keep the agentic lane available as supplemental coverage even when the
    # readonly lane fails due to helper/runtime infrastructure. The aggregate
    # summary now waits for the advisory lane to reach a terminal state or time
    # out naturally instead of force-aborting it on primary-lane failure.
    return


def _refresh_state(
    state_dir: pathlib.Path,
    *,
    settle_timeout: bool = False,
) -> dict[str, object]:
    state = _load_state(state_dir)
    if _state_kind(state) == "parallel":
        return _refresh_parallel_state(state_dir, settle_timeout=settle_timeout)
    if str(state.get("entrypoint") or "") == "codex-review":
        _maybe_enforce_stateful_codex_review_timeout(
            state_dir,
            state,
            settle_timeout=settle_timeout,
        )
        return _load_state(state_dir)
    if str(state.get("entrypoint") or "") == "codex-readonly":
        _maybe_enforce_stateful_codex_readonly_timeout(
            state_dir,
            state,
            settle_timeout=settle_timeout,
        )
        return _load_state(state_dir)
    return state


def _refresh_parallel_state(
    state_dir: pathlib.Path,
    *,
    settle_timeout: bool = False,
) -> dict[str, object]:
    state = _load_state(state_dir)
    readonly_state_dir = _parallel_child_state_dir(state, "readonly")
    if readonly_state_dir is not None:
        _refresh_state(readonly_state_dir, settle_timeout=settle_timeout)
    _maybe_enforce_parallel_agentic_timeout(state_dir, state)
    state = _load_state(state_dir)
    _maybe_abort_parallel_agentic_after_primary_failure(state_dir, state)
    return _load_state(state_dir)


def _parallel_state_summary(
    state_dir: pathlib.Path,
    state: dict[str, object],
) -> dict[str, object]:
    children: dict[str, object] = {}

    readonly_state_dir = _parallel_child_state_dir(state, "readonly")
    readonly_summary: dict[str, object] | None = None
    if readonly_state_dir is not None:
        _, readonly_summary = _parallel_child_summary(
            child_state_dir=readonly_state_dir,
            cleanup_terminal=True,
        )
        children["readonly"] = readonly_summary

    agentic_state_dir = _parallel_child_state_dir(state, "agentic")
    agentic_summary: dict[str, object] | None = None
    if agentic_state_dir is not None:
        _, agentic_summary = _parallel_child_summary(
            child_state_dir=agentic_state_dir,
            cleanup_terminal=True,
        )
        children["agentic"] = agentic_summary

    agentic_start_error = state.get("agentic_start_error")
    if isinstance(agentic_start_error, str) and agentic_summary is None:
        agentic_summary = {
            "state_dir": None,
            "entrypoint": "codex-review",
            "status": "inconclusive",
            "running": False,
            "exit_code": 1,
            "final_available": False,
            "report_available": False,
            "workspace_cleaned": False,
            "stdout_tail": "",
            "stderr_tail": agentic_start_error,
        }
        children["agentic"] = agentic_summary

    readonly_exit_code = (
        readonly_summary.get("exit_code") if readonly_summary is not None else 1
    )
    readonly_running = (
        bool(readonly_summary.get("running")) if readonly_summary is not None else False
    )
    agentic_running = (
        bool(agentic_summary.get("running")) if agentic_summary is not None else False
    )

    status = "failed"
    exit_code: int | None = None
    running = False
    if readonly_summary is None:
        status = "failed"
        exit_code = 1
    elif readonly_exit_code is None:
        running = readonly_running or agentic_running
        if readonly_summary.get("status") == "launching":
            status = "launching"
        elif readonly_running:
            status = "running"
        else:
            status = "unknown"
    elif int(readonly_exit_code) != 0:
        if agentic_summary is not None and agentic_summary.get("exit_code") is None:
            running = True
            if agentic_summary.get("status") == "launching":
                status = "launching"
            else:
                status = "running"
        else:
            status = "failed"
            exit_code = int(readonly_exit_code)
    elif agentic_summary is not None and agentic_summary.get("exit_code") is None:
        if agentic_running:
            running = True
            if bool(state.get("agentic_timed_out")) and not bool(state.get("agentic_kill_sent_at")):
                status = "running"
            elif agentic_summary.get("status") == "launching":
                status = "launching"
            else:
                status = "running"
        else:
            running = True
            if agentic_summary.get("status") == "launching":
                status = "launching"
            else:
                status = "running"
    else:
        status = "passed"
        exit_code = 0

    stdout_sections: list[str] = []
    stderr_sections: list[str] = []
    for lane_name in ("readonly", "agentic"):
        lane_summary = children.get(lane_name)
        if not isinstance(lane_summary, dict):
            continue
        stdout_tail = str(lane_summary.get("stdout_tail") or "").strip()
        stderr_tail = str(lane_summary.get("stderr_tail") or "").strip()
        if stdout_tail:
            stdout_sections.append(f"[{lane_name}]\n{stdout_tail}")
        if stderr_tail:
            stderr_sections.append(f"[{lane_name}]\n{stderr_tail}")

    return {
        "state_dir": str(state_dir),
        "workspace_root": str(_require_state_field(state, "workspace_root")),
        "entrypoint": _require_state_field(state, "entrypoint"),
        "review_range": state.get("review_range"),
        "pid": None,
        "running": running,
        "exit_code": exit_code,
        "status": status,
        "final_available": exit_code is not None,
        "report_available": exit_code is not None,
        "workspace_cleaned": bool(state.get("workspace_cleaned")),
        "stdout_tail": "\n\n".join(stdout_sections),
        "stderr_tail": "\n\n".join(stderr_sections),
        "children": children,
        "agentic_timed_out": bool(state.get("agentic_timed_out")),
    }


def _maybe_cleanup_parallel_workspace(
    state_dir: pathlib.Path,
    state: dict[str, object],
    *,
    exit_code: int,
) -> None:
    if bool(state.get("workspace_cleaned")):
        return
    if state.get("keep_workspace"):
        return
    if exit_code != 0 and state.get("keep_on_failure"):
        return

    workspace_root = pathlib.Path(str(_require_state_field(state, "workspace_root")))
    source_root = pathlib.Path(str(_require_state_field(state, "source_root")))
    if not workspace_root.exists():
        _prune_missing_workspace_registration(
            source_root,
            workspace_root,
            require_known=True,
        )
        if bool(state.get("cleanup_submodule_worktrees")):
            _prune_missing_submodule_workspace_registrations(
                source_root,
                workspace_root,
            )
        state["workspace_cleaned"] = True
        _save_state(state_dir, state)
        return

    if not _source_root_recognizes_workspace(source_root, workspace_root):
        raise UserError(
            "parallel source_root does not recognize workspace_root; refusing cleanup: "
            f"{source_root} -> {workspace_root}"
        )

    _cleanup_worktree(
        source_root,
        workspace_root,
        cleanup_submodule_worktrees=bool(state.get("cleanup_submodule_worktrees")),
        preserve_container_dir=False,
    )
    state["workspace_cleaned"] = True
    _save_state(state_dir, state)


def _start_parallel_review(args: argparse.Namespace) -> int:
    _reject_codex_parallel_customizations(args)
    codex_model = getattr(args, "codex_model", CODEX_MODEL_DEFAULT)
    codex_fallback_model = getattr(
        args,
        "codex_fallback_model",
        CODEX_FALLBACK_MODEL_DEFAULT,
    )
    codex_reasoning_effort = getattr(
        args,
        "codex_reasoning_effort",
        CODEX_REASONING_EFFORT_DEFAULT,
    )
    no_codex_model_fallback = bool(
        getattr(args, "no_codex_model_fallback", False)
    )
    (
        source_root,
        base_ref,
        head_ref,
        shared_container_dir,
        shared_workspace_root,
        shared_created_workspace,
        shared_cleanup_submodule_worktrees,
    ) = _prepare_workspace(args)
    temp_parent = source_root / ".codex-tmp"
    temp_parent.mkdir(parents=True, exist_ok=True)
    state_dir = pathlib.Path(
        tempfile.mkdtemp(prefix="isolated-review-parallel-", dir=temp_parent)
    )
    state: dict[str, object] = {
        "state_kind": "parallel",
        "workspace_root": str(shared_workspace_root),
        "source_root": str(source_root),
        "entrypoint": "codex-parallel",
        "lane": args.lane,
        "base_ref": base_ref,
        "head_ref": head_ref,
        "review_range": (
            f"{base_ref}..{head_ref}" if base_ref is not None and head_ref is not None else None
        ),
        "child_states": {},
        "agentic_timed_out": False,
        "cleanup_submodule_worktrees": shared_cleanup_submodule_worktrees,
        "keep_on_failure": args.keep_on_failure,
        "keep_workspace": args.keep_workspace,
        "workspace_cleaned": False,
        "started_at": time.time(),
    }
    state["agentic_output_snapshot"] = None
    state["agentic_last_output_at"] = None
    _save_state(state_dir, state)

    script_path = pathlib.Path(__file__).resolve()

    def start_child(entrypoint: str) -> pathlib.Path:
        child_state_dir = pathlib.Path(
            tempfile.mkdtemp(prefix="isolated-review-", dir=temp_parent)
        )
        command = [
            sys.executable,
            str(script_path),
            STATEFUL_CONTROL_NAMESPACE,
            "start",
            "--repo",
            str(source_root),
            "--state-dir",
            str(child_state_dir),
            "--reuse-workspace",
            str(shared_workspace_root),
            "--entrypoint",
            entrypoint,
            "--lane",
            args.lane,
            "--codex-model",
            codex_model,
            "--codex-fallback-model",
            codex_fallback_model,
            "--codex-reasoning-effort",
            codex_reasoning_effort,
        ]
        if no_codex_model_fallback:
            command.append("--no-codex-model-fallback")
        if base_ref is not None and head_ref is not None:
            command.extend(["--base-ref", base_ref, "--head-ref", head_ref])
        if args.keep_on_failure:
            command.append("--keep-on-failure")
        if args.keep_workspace:
            command.append("--keep-workspace")
        completed = subprocess.run(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=False,
        )
        if completed.returncode != 0:
            shutil.rmtree(child_state_dir, ignore_errors=True)
            raise UserError(
                f"{entrypoint} child start failed: {completed.stderr.strip() or 'unknown error'}"
            )
        lines = [line.strip() for line in completed.stdout.splitlines() if line.strip()]
        if not lines:
            shutil.rmtree(child_state_dir, ignore_errors=True)
            raise UserError(f"{entrypoint} child start returned no state dir")
        returned_state_dir = pathlib.Path(lines[-1])
        if returned_state_dir != child_state_dir:
            shutil.rmtree(child_state_dir, ignore_errors=True)
            raise UserError(
                f"{entrypoint} child start returned unexpected state dir: {returned_state_dir}"
            )
        return returned_state_dir

    try:
        readonly_state_dir = start_child("codex-readonly")
    except UserError as error:
        cleanup_error = _cleanup_failed_workspace_setup(
            source_root,
            shared_workspace_root,
            container_dir=shared_container_dir,
            created_workspace=shared_created_workspace,
            cleanup_submodule_worktrees=shared_cleanup_submodule_worktrees,
        )
        shutil.rmtree(state_dir, ignore_errors=True)
        if cleanup_error is not None:
            raise UserError(f"{error}\n{cleanup_error}") from error
        raise
    state = _load_state(state_dir)
    child_states = dict(state.get("child_states", {}))
    child_states["readonly"] = str(readonly_state_dir)
    state["child_states"] = child_states
    try:
        readonly_state = _load_state(readonly_state_dir)
        readonly_diff_file_raw = readonly_state.get("diff_file")
        readonly_diff_file = (
            pathlib.Path(str(readonly_diff_file_raw))
            if isinstance(readonly_diff_file_raw, str) and readonly_diff_file_raw
            else None
        )
        state.update(
            _parallel_agentic_review_policy(
                source_root,
                base_ref=base_ref,
                head_ref=head_ref,
                diff_file=readonly_diff_file,
            )
        )
    except (UserError, OSError) as error:
        state["agentic_policy_error"] = str(error)
    _save_state(state_dir, state)

    try:
        agentic_state_dir = start_child("codex-review")
    except UserError as error:
        state = _load_state(state_dir)
        state["agentic_start_error"] = str(error)
        _save_state(state_dir, state)
    else:
        state = _load_state(state_dir)
        child_states = dict(state.get("child_states", {}))
        child_states["agentic"] = str(agentic_state_dir)
        state["child_states"] = child_states
        _save_state(state_dir, state)

    print(state_dir)
    return 0


def _handle_status(state_dir: pathlib.Path) -> int:
    state = _refresh_state(state_dir, settle_timeout=False)
    print(json.dumps(_state_summary(state_dir, state), sort_keys=True))
    return 0


def _handle_wait(state_dir: pathlib.Path, *, timeout_seconds: float | None) -> int:
    deadline = None if timeout_seconds is None else time.monotonic() + timeout_seconds
    while True:
        state = _refresh_state(state_dir, settle_timeout=True)
        summary = _state_summary(state_dir, state)
        if summary["exit_code"] is not None:
            if _state_kind(state) == "parallel":
                cleanup_error: UserError | None = None
                try:
                    _maybe_cleanup_parallel_workspace(
                        state_dir,
                        state,
                        exit_code=int(summary["exit_code"]),
                    )
                except UserError as error:
                    cleanup_error = error
                if cleanup_error is not None:
                    print(str(cleanup_error), file=sys.stderr)
            else:
                cleanup_error: UserError | None = None
                try:
                    _maybe_cleanup_stateful_workspace(
                        state_dir,
                        state,
                        exit_code=int(summary["exit_code"]),
                    )
                except UserError as error:
                    cleanup_error = error
                if cleanup_error is not None:
                    print(str(cleanup_error), file=sys.stderr)
            print(json.dumps(_state_summary(state_dir, _load_state(state_dir)), sort_keys=True))
            return 0 if int(summary["exit_code"]) == 0 else int(summary["exit_code"])
        if summary["status"] == "unknown":
            raise UserError(
                f"review state became unknown without exit code: {state_dir}"
            )
        if deadline is not None and time.monotonic() >= deadline:
            raise UserError(f"timed out waiting for review state: {state_dir}")
        time.sleep(WAIT_POLL_INTERVAL_SECONDS)


def _read_stateful_final_text(
    state_dir: pathlib.Path,
    state: dict[str, object],
) -> str:
    entrypoint = str(state.get("entrypoint") or "")
    final_path = state.get("final_path")
    if final_path:
        final_source = _resolve_stateful_output_source(
            state_dir=state_dir,
            state=state,
            source_path=pathlib.Path(str(final_path)),
        )
        if final_source is not None:
            _, final_file = final_source
            final_text = final_file.read_text(encoding="utf-8")
            if entrypoint == "codex-readonly":
                return _normalize_codex_readonly_final_text(final_text)
            return final_text
        if entrypoint == "codex-readonly":
            raise UserError(
                f"codex-readonly final artifact is unavailable: {state_dir}"
            )
    elif entrypoint == "codex-readonly":
        raise UserError(f"codex-readonly final artifact is unavailable: {state_dir}")

    report_file = state.get("report_file")
    if report_file:
        report_source = _resolve_stateful_output_source(
            state_dir=state_dir,
            state=state,
            source_path=pathlib.Path(str(report_file)),
        )
        if report_source is not None:
            _, report_path = report_source
            return report_path.read_text(encoding="utf-8")

    stdout_path = pathlib.Path(str(_require_state_field(state, "stdout_path")))
    if entrypoint == "codex-review":
        final_message = _extract_codex_review_stdout_message(stdout_path)
        if final_message is not None:
            return final_message
    for line in reversed(_tail_text(stdout_path, line_count=20).splitlines()):
        if line.strip():
            return f"{line}\n"

    raise UserError(f"no final reviewer message available: {state_dir}")


def _format_parallel_child_result(
    *,
    label: str,
    summary: dict[str, object] | None,
    final_text: str | None,
    advisory: bool,
) -> str:
    if final_text is not None and (
        summary is None or summary.get("exit_code") in (None, 0)
    ):
        return f"## {label}\n{final_text.rstrip()}\n"

    if summary is None:
        message = "Lane did not start."
    elif summary["exit_code"] is None:
        status = str(summary.get("status") or "")
        stderr_tail = str(summary.get("stderr_tail") or "").strip()
        stdout_tail = str(summary.get("stdout_tail") or "").strip()
        detail = stderr_tail or stdout_tail
        if status in {"inconclusive", "unknown"}:
            fallback = (
                "lane did not start cleanly"
                if status == "inconclusive"
                else "lane ended without a terminal exit code"
            )
            message = f"Inconclusive: {detail or fallback}"
        elif status == "launching":
            message = "Lane is still launching."
        else:
            message = "Lane is still running."
    else:
        if int(summary["exit_code"]) == 0:
            message = "Completed, but no final reviewer message was available."
            return f"## {label}\n{message}\n"
        stderr_tail = str(summary.get("stderr_tail") or "").strip()
        stdout_tail = str(summary.get("stdout_tail") or "").strip()
        detail = stderr_tail or stdout_tail or f"exit_code={summary['exit_code']}"
        prefix = "Inconclusive" if advisory else "Failed"
        message = f"{prefix}: {detail}"
    return f"## {label}\n{message}\n"


def _read_parallel_final_text(
    state_dir: pathlib.Path,
    state: dict[str, object],
) -> str:
    readonly_summary: dict[str, object] | None = None
    readonly_text: str | None = None
    readonly_state_dir = _parallel_child_state_dir(state, "readonly")
    if readonly_state_dir is not None:
        readonly_state, readonly_summary = _parallel_child_summary(
            child_state_dir=readonly_state_dir,
            cleanup_terminal=True,
        )
        if readonly_summary["exit_code"] == 0:
            try:
                readonly_text = _read_stateful_final_text(readonly_state_dir, readonly_state)
            except UserError:
                readonly_text = None

    agentic_summary: dict[str, object] | None = None
    agentic_text: str | None = None
    agentic_state_dir = _parallel_child_state_dir(state, "agentic")
    if agentic_state_dir is not None:
        agentic_state, agentic_summary = _parallel_child_summary(
            child_state_dir=agentic_state_dir,
            cleanup_terminal=True,
        )
        if agentic_summary["exit_code"] == 0:
            try:
                agentic_text = _read_stateful_final_text(agentic_state_dir, agentic_state)
            except UserError:
                agentic_text = None
    elif isinstance(state.get("agentic_start_error"), str):
        agentic_summary = {
            "exit_code": 1,
            "status": "inconclusive",
            "running": False,
            "stderr_tail": state["agentic_start_error"],
            "stdout_tail": "",
        }

    parts = [
        "# Internal Review Report",
        "",
        _format_parallel_child_result(
            label="Readonly",
            summary=readonly_summary,
            final_text=readonly_text,
            advisory=False,
        ).rstrip(),
        "",
        _format_parallel_child_result(
            label="Agentic",
            summary=agentic_summary,
            final_text=agentic_text,
            advisory=True,
        ).rstrip(),
        "",
    ]
    return "\n".join(parts)


def _handle_final(state_dir: pathlib.Path) -> int:
    state = _refresh_state(state_dir, settle_timeout=True)
    summary = _state_summary(state_dir, state)
    if summary["exit_code"] is None:
        raise UserError(f"review is still running: {state_dir}")
    if _state_kind(state) == "parallel":
        sys.stdout.write(_read_parallel_final_text(state_dir, state))
        return 0
    sys.stdout.write(_read_stateful_final_text(state_dir, state))
    return 0


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description=(
            "Create a detached review workspace, either sync the current repo snapshot "
            "(including recursive submodules and untracked files) or freeze a specific commit range, "
            "run the chosen review CLI there, and clean up afterward."
        )
    )
    parser.add_argument("--repo", default=".", help="Source repository path.")
    parser.add_argument(
        "--prepare-only",
        action="store_true",
        help="Prepare the isolated workspace, print its path, and exit without running the child command.",
    )
    parser.add_argument(
        "--reuse-workspace",
        help="Reuse an existing isolated workspace created by this helper instead of creating a new one.",
    )
    parser.add_argument(
        "--state-dir",
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--entrypoint",
        default="auto",
        choices=(
            "auto",
            "codex-parallel",
            "codex-readonly",
            "codex-review",
            "opencode",
            "agent",
            "copilot",
            "gh-copilot",
        ),
        help="Review CLI entrypoint to invoke inside the isolated workspace.",
    )
    parser.add_argument(
        "--lane",
        default="custom",
        choices=tuple(LANE_AUTO_PRIORITIES.keys()),
        help=(
            "High-level runtime recommendation. "
            "`custom` preserves the legacy helper behavior; "
            "`bounded-semantic`, `deep-semantic`, `baseline`, and `super-large` "
            "package the current recommended entrypoint priorities."
        ),
    )
    parser.add_argument(
        "--codex-model",
        default=CODEX_MODEL_DEFAULT,
        help="Primary model for helper-managed Codex review lanes.",
    )
    parser.add_argument(
        "--codex-fallback-model",
        default=CODEX_FALLBACK_MODEL_DEFAULT,
        help=(
            "Fallback model for helper-managed Codex review lanes when the primary "
            "model is unavailable, unsupported, or not entitled."
        ),
    )
    parser.add_argument(
        "--codex-reasoning-effort",
        default=CODEX_REASONING_EFFORT_DEFAULT,
        help="Reasoning effort shared by the primary and fallback Codex models.",
    )
    parser.add_argument(
        "--no-codex-model-fallback",
        action="store_true",
        help="Disable helper-managed Codex model fallback for this review.",
    )
    parser.add_argument(
        "--base-ref",
        help="Optional frozen review base commit-ish. Must be paired with --head-ref.",
    )
    parser.add_argument(
        "--head-ref",
        help=(
            "Optional frozen review head commit-ish. Must be paired with --base-ref. "
            "When set, the helper checks out that commit instead of copying the live working tree."
        ),
    )
    parser.add_argument(
        "--prompt-file",
        help="Optional prompt template file to copy into the isolated workspace.",
    )
    parser.add_argument(
        "--prompt-delivery",
        default="auto",
        choices=("auto", "inline", "bootstrap"),
        help=(
            "How to pass {prompt_text} to the child review CLI when --prompt-file is used. "
            "`auto` keeps short prompts inline but switches agentic entrypoints to a tiny "
            "bootstrap prompt that points at {prompt_file} when the rendered prompt exceeds "
            "--prompt-inline-max-bytes."
        ),
    )
    parser.add_argument(
        "--prompt-inline-max-bytes",
        type=int,
        default=PROMPT_INLINE_MAX_BYTES_DEFAULT,
        help=(
            "Inline prompt byte budget for --prompt-delivery=auto. Longer rendered prompt "
            "templates switch agentic lanes to bootstrap delivery."
        ),
    )
    parser.add_argument(
        "--diff-file",
        help="Optional diff file to copy into the isolated workspace.",
    )
    parser.add_argument(
        "--copy-path",
        action="append",
        default=[],
        help="Additional file or directory to copy into the isolated workspace.",
    )
    parser.add_argument(
        "--report-path",
        help=(
            "Optional report file path, relative to the isolated workspace. "
            "Exposes {report_file} and defaults {final_reply} to `WROTE <report-path>`."
        ),
    )
    parser.add_argument(
        "--final-reply",
        help=(
            "Optional exact final reply contract. Supports placeholders such as "
            "{report_file} and {final_reply}."
        ),
    )
    parser.add_argument(
        "--opencode-compaction",
        default="default",
        choices=("default", "no-auto", "auto", "auto-hardened"),
        help=(
            "OpenCode compaction mode override. "
            "`default` maps from the selected lane."
        ),
    )
    parser.add_argument(
        "--opencode-reserved",
        type=int,
        default=4096,
        help=(
            "Reserved-token budget for the `auto-hardened` OpenCode mode."
        ),
    )
    parser.add_argument(
        "--keep-on-failure",
        action="store_true",
        help="Keep the isolated workspace when the child review command fails.",
    )
    parser.add_argument(
        "--keep-workspace",
        action="store_true",
        help="Keep the isolated workspace even when the command succeeds.",
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Print the isolated workspace path and child command.",
    )
    parser.add_argument(
        "review_args",
        nargs=argparse.REMAINDER,
        help=(
            "Arguments passed to the chosen review CLI entrypoint. "
            "Supports placeholders such as {workspace}, {prompt_file}, "
            "{diff_file}, {prompt_text}, {base_ref}, {head_ref}, and {review_range}."
        ),
    )
    return parser


def _dispatch_action(argv: list[str]) -> int:
    action_argv = argv
    action = argv[0]
    if action == STATEFUL_CONTROL_NAMESPACE:
        if len(argv) < 2:
            raise UserError(
                f"`{STATEFUL_CONTROL_NAMESPACE}` requires one of: "
                + ", ".join(sorted(STATEFUL_ACTIONS))
            )
        action = argv[1]
        action_argv = argv[1:]
    if action == "__run-child":
        if len(action_argv) != 3:
            raise UserError("__run-child requires a runner spec path and sha256")
        return _run_child_from_spec(
            pathlib.Path(action_argv[1]).resolve(),
            expected_sha256=action_argv[2],
        )

    if action == "status":
        args = _build_state_parser(action).parse_args(action_argv[1:])
        return _handle_status(pathlib.Path(args.state_dir).resolve())

    if action == "wait":
        args = _build_state_parser(action).parse_args(action_argv[1:])
        return _handle_wait(
            pathlib.Path(args.state_dir).resolve(),
            timeout_seconds=args.timeout_seconds,
        )

    if action == "final":
        args = _build_state_parser(action).parse_args(action_argv[1:])
        return _handle_final(pathlib.Path(args.state_dir).resolve())

    if action == "start":
        args = _build_parser().parse_args(action_argv[1:])
        if args.entrypoint == "codex-parallel":
            return _start_parallel_review(args)
        return _start_prepared_review(_prepare_review_execution(args))

    raise UserError(f"unsupported action: {action}")


def main() -> int:
    argv = sys.argv[1:]
    try:
        action = _maybe_stateful_action(argv)
        if action is not None:
            return _dispatch_action(argv)
        args = _build_parser().parse_args(argv)
        if args.entrypoint == "codex-parallel":
            raise UserError(
                "codex-parallel currently requires `stateful start|status|wait|final`"
            )
        return _run_prepared_review(_prepare_review_execution(args))
    except UserError as error:
        print(str(error), file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
