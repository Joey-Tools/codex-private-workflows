#!/usr/bin/env python3

from __future__ import annotations

import os
import pathlib
import sys


def main() -> int:
    target = pathlib.Path(__file__).resolve().with_name("isolated_external_review")
    os.execv(sys.executable, [sys.executable, str(target), *sys.argv[1:]])
    return 127


if __name__ == "__main__":
    raise SystemExit(main())
